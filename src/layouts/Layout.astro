---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Cuesseler Web — Websites for Local Businesses",
  description = "I build fast, modern websites for local businesses in Gainesville and beyond. Affordable monthly hosting included.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-slate-950 text-slate-100 antialiased">
    <slot />
  </body>
</html>
