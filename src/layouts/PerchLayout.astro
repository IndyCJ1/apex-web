---
import "../styles/global.css";

interface Props {
  title?: string;
  page?: string;
}
const { title = "The Perch Coffee Co. — Gainesville, GA", page = "" } = Astro.props;

const nav = [
  { label: "Menu", href: "/demos/plus/menu" },
  { label: "Blog", href: "/demos/plus/blog" },
  { label: "Events", href: "/demos/plus/index#events" },
  { label: "About", href: "/demos/plus/index#about" },
  { label: "Visit", href: "/demos/plus/index#visit" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
    <style>
      :root {
        --p-bg: #FAF8F5;
        --p-bg-alt: #F0EBE3;
        --p-bg-dark: #1C1208;
        --p-brown: #1C1208;
        --p-mid: #6B4C2A;
        --p-green: #3D6B35;
        --p-gold: #C4893A;
        --p-border: #DDD5C8;
        --p-muted: #8A7A6A;
        --font-serif: 'Playfair Display', Georgia, serif;
        --font-sans: 'DM Sans', system-ui, sans-serif;
      }
      body { background: var(--p-bg); color: var(--p-brown); font-family: var(--font-sans); overflow-x: hidden; }
      .nav-link { color: var(--p-muted); font-size: 0.8125rem; transition: color 0.2s; }
      .nav-link:hover, .nav-link.active { color: var(--p-brown); }
      .mobile-nav-toggle { background: transparent; border: none; cursor: pointer; padding: 0.5rem; color: var(--p-brown); }
      .mobile-nav-panel { display: none; }
      .mobile-nav-panel.is-open { display: block; }
      @media (min-width: 768px) {
        .mobile-nav-toggle { display: none; }
        .mobile-nav-panel { display: none !important; }
      }
    </style>
  </head>
  <body>
    <!-- Nav -->
    <nav style="background: var(--p-bg); border-bottom: 1px solid var(--p-border);" class="sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-6 h-14 flex items-center justify-between">
        <div class="hidden md:flex items-center gap-6">
          <a href="/demos/plus/menu" class="nav-link text-xs uppercase tracking-[0.18em]">Menu</a>
          <a href="/demos/plus/blog" class="nav-link text-xs uppercase tracking-[0.18em]">Blog</a>
          <a href="/demos/plus/index#events" class="nav-link text-xs uppercase tracking-[0.18em]">Events</a>
        </div>
        <button class="mobile-nav-toggle md:hidden" aria-label="Toggle menu" id="perchNavToggle">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <a href="/demos/plus" style="font-family: var(--font-serif); letter-spacing: 0.2em; font-size: 1.1rem;" class="font-bold uppercase md:absolute md:left-1/2 md:-translate-x-1/2">
          The Perch
        </a>
        <div class="hidden md:flex items-center gap-6">
          <a href="/demos/plus/index#about" class="nav-link text-xs uppercase tracking-[0.18em]">About</a>
          <a href="/demos/plus/index#visit" class="nav-link text-xs uppercase tracking-[0.18em]">Visit</a>
          <a href="/demos/plus/menu" style="border: 1px solid var(--p-gold); color: var(--p-gold); font-size: 0.7rem; letter-spacing: 0.15em;" class="px-4 py-1.5 uppercase hover:opacity-80 transition-opacity">
            Order
          </a>
        </div>
        <div class="md:hidden" style="width: 22px;"></div>
      </div>
      <div class="mobile-nav-panel" id="perchNavPanel" style="border-top: 1px solid var(--p-border); background: var(--p-bg);">
        <div class="px-6 py-4 flex flex-col gap-3">
          <a href="/demos/plus/menu" class="nav-link text-sm uppercase tracking-[0.18em]">Menu</a>
          <a href="/demos/plus/blog" class="nav-link text-sm uppercase tracking-[0.18em]">Blog</a>
          <a href="/demos/plus/index#events" class="nav-link text-sm uppercase tracking-[0.18em]">Events</a>
          <a href="/demos/plus/index#about" class="nav-link text-sm uppercase tracking-[0.18em]">About</a>
          <a href="/demos/plus/index#visit" class="nav-link text-sm uppercase tracking-[0.18em]">Visit</a>
          <a href="/demos/plus/menu" style="border: 1px solid var(--p-gold); color: var(--p-gold); font-size: 0.7rem; letter-spacing: 0.15em;" class="self-start px-4 py-1.5 uppercase mt-2">
            Order
          </a>
        </div>
      </div>
    </nav>

    <slot />

    <!-- Footer -->
    <footer style="background: var(--p-bg-dark); color: rgba(255,255,255,0.45); font-size: 0.8125rem;" class="px-6 py-10">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between gap-4">
        <div>
          <p style="font-family: var(--font-serif); color: rgba(255,255,255,0.85);" class="text-lg font-semibold mb-1">The Perch Coffee Co.</p>
          <p>412 Bradford St NE, Gainesville, GA 30501</p>
          <p class="mt-1">Mon–Fri 7am–7pm · Sat–Sun 8am–6pm</p>
        </div>
        <div class="text-right">
          <p style="color: rgba(255,255,255,0.25); font-size: 0.7rem;" class="mt-4 md:mt-0">
            Demo site — built by <a href="/" style="color: rgba(255,255,255,0.45);" class="hover:underline">Apex Web</a>
          </p>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function() {
        var io = new IntersectionObserver(
          function(entries) { entries.forEach(function(e) { if (e.isIntersecting) e.target.classList.add('is-visible'); }); },
          { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('.reveal').forEach(function(el) { io.observe(el); });

        var toggle = document.getElementById('perchNavToggle');
        var panel = document.getElementById('perchNavPanel');
        if (toggle && panel) {
          toggle.addEventListener('click', function() {
            panel.classList.toggle('is-open');
          });
        }
      })();
    </script>
  </body>
</html>
