---
import "../styles/global.css";

interface Props {
  title?: string;
  page?: string;
}
const { title = "Solé Wellness Studio — Gainesville, GA", page = "" } = Astro.props;

const nav = [
  { label: "Services", href: "/demos/pro/services" },
  { label: "Book", href: "/demos/pro/book" },
  { label: "Shop", href: "/demos/pro/index#shop" },
  { label: "About", href: "/demos/pro/index#about" },
  { label: "Contact", href: "/demos/pro/index#contact" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="robots" content="noindex,follow" />
    <meta name="description" content="Demo wellness-studio website built by Lanier Web for the Pro package preview." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
    <style>
      :root {
        --s-bg: #EBF2EB;
        --s-bg-alt: #DDE8DD;
        --s-bg-dark: #2A4533;
        --s-ink: #162016;
        --s-muted: #5A6E5A;
        --s-sage: #3D6B3D;
        --s-sage-dark: #2C502C;
        --s-gold: #A87C4F;
        --s-border: #C0D4C0;
        --font-serif: 'Cormorant Garamond', Georgia, serif;
        --font-sans: 'DM Sans', system-ui, sans-serif;
      }
      body { background: var(--s-bg); color: var(--s-ink); font-family: var(--font-sans); overflow-x: hidden; }
      .nav-link { color: var(--s-muted); font-size: 0.8125rem; letter-spacing: 0.05em; transition: color 0.2s; }
      .nav-link:hover, .nav-link.active { color: var(--s-ink); }
      .s-option { border: 1px solid var(--s-border); background: var(--s-bg-alt); transition: border-color 0.2s; }
      .s-option:hover { border-color: var(--s-sage); }
      .s-button { transition: opacity 0.2s; }
      .s-button:hover { opacity: 0.85; }
      .mobile-nav-toggle { background: transparent; border: none; cursor: pointer; padding: 0.5rem; color: var(--s-ink); }
      .mobile-nav-panel { display: none; }
      .mobile-nav-panel.is-open { display: block; }
      @media (min-width: 768px) {
        .mobile-nav-toggle { display: none; }
        .mobile-nav-panel { display: none !important; }
      }
    </style>
  </head>
  <body>
    <!-- Nav -->
    <nav style="background: var(--s-bg); border-bottom: 1px solid var(--s-border);" class="sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/demos/pro" style="font-family: var(--font-serif);" class="text-xl font-medium tracking-wide italic">
          Solé
        </a>
        <div class="hidden md:flex items-center gap-7">
          {nav.map((n) => (
            <a href={n.href} class={`nav-link ${page === n.label ? 'active font-medium' : ''}`}>{n.label}</a>
          ))}
        </div>
        <a href="/demos/pro/book"
          style="background: var(--s-sage); color: #fff; font-size: 0.8125rem; letter-spacing: 0.08em;"
          class="hidden md:inline-flex px-5 py-2.5 font-medium uppercase tracking-wider hover:opacity-90 transition-opacity text-xs">
          Book Now
        </a>
        <button class="mobile-nav-toggle md:hidden" aria-label="Toggle menu" id="soleNavToggle">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </div>
      <div class="mobile-nav-panel" id="soleNavPanel" style="border-top: 1px solid var(--s-border); background: var(--s-bg);">
        <div class="px-6 py-4 flex flex-col gap-3">
          {nav.map((n) => (
            <a href={n.href} class={`nav-link text-sm ${page === n.label ? 'active font-medium' : ''}`}>{n.label}</a>
          ))}
          <a href="/demos/pro/book" style="background: var(--s-sage); color: #fff; font-size: 0.75rem; letter-spacing: 0.08em;" class="self-start px-5 py-2.5 font-medium uppercase tracking-wider mt-2">
            Book Now
          </a>
        </div>
      </div>
    </nav>

    <slot />

    <!-- Footer -->
    <footer style="background: var(--s-bg-dark); color: rgba(255,255,255,0.4); font-size: 0.8125rem;" class="px-6 py-12">
      <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-8">
        <div>
          <p style="font-family: var(--font-serif); color: rgba(255,255,255,0.85); font-style: italic;" class="text-2xl mb-2">Solé</p>
          <p>1804 Green St NW<br/>Gainesville, GA 30501</p>
        </div>
        <div>
          <p style="color: rgba(255,255,255,0.6);" class="text-xs uppercase tracking-widest mb-3">Hours</p>
          <p>Tue–Fri &nbsp; 9am–7pm</p>
          <p>Sat &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; 9am–5pm</p>
          <p>Sun–Mon &nbsp; Closed</p>
        </div>
        <div class="md:text-right">
          <a href="/demos/pro/book"
            style="background: var(--s-sage); color: #fff;"
            class="inline-flex px-6 py-3 text-sm font-medium hover:opacity-90 transition-opacity mb-4">
            Book an Appointment
          </a>
          <p style="color: rgba(255,255,255,0.2); font-size: 0.7rem;" class="mt-4">
            Demo site — built by <a href="/" style="color: rgba(255,255,255,0.35);" class="hover:underline">Lanier Web</a>
          </p>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function() {
        var io = new IntersectionObserver(
          function(entries) { entries.forEach(function(e) { if (e.isIntersecting) e.target.classList.add('is-visible'); }); },
          { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('.reveal').forEach(function(el) { io.observe(el); });

        var toggle = document.getElementById('soleNavToggle');
        var panel = document.getElementById('soleNavPanel');
        if (toggle && panel) {
          toggle.addEventListener('click', function() {
            panel.classList.toggle('is-open');
          });
        }
      })();
    </script>
  </body>
</html>
