---
import "../styles/global.css";

interface Props {
  title?: string;
  page?: string;
}
const { title = "Solé Wellness Studio — Gainesville, GA", page = "" } = Astro.props;

const nav = [
  { label: "Services", href: "/demos/pro/services" },
  { label: "Book", href: "/demos/pro/book" },
  { label: "Shop", href: "/demos/pro/index#shop" },
  { label: "About", href: "/demos/pro/index#about" },
  { label: "Contact", href: "/demos/pro/index#contact" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
    <style>
      :root {
        --s-bg: #F9F9F7;
        --s-bg-alt: #F2F2EE;
        --s-bg-dark: #1C1C1A;
        --s-ink: #1A1A1A;
        --s-muted: #888884;
        --s-sage: #6B8C6B;
        --s-sage-dark: #4E6B4E;
        --s-gold: #B8916A;
        --s-border: #E2E2DC;
        --font-serif: 'Cormorant Garamond', Georgia, serif;
        --font-sans: 'DM Sans', system-ui, sans-serif;
      }
      body { background: var(--s-bg); color: var(--s-ink); font-family: var(--font-sans); }
      .nav-link { color: var(--s-muted); font-size: 0.8125rem; letter-spacing: 0.05em; transition: color 0.2s; }
      .nav-link:hover, .nav-link.active { color: var(--s-ink); }
    </style>
  </head>
  <body>
    <!-- Nav -->
    <nav style="background: var(--s-bg); border-bottom: 1px solid var(--s-border);" class="sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/demos/pro" style="font-family: var(--font-serif);" class="text-xl font-medium tracking-wide italic">
          Solé
        </a>
        <div class="hidden md:flex items-center gap-7">
          {nav.map((n) => (
            <a href={n.href} class={`nav-link ${page === n.label ? 'active font-medium' : ''}`}>{n.label}</a>
          ))}
        </div>
        <a href="/demos/pro/book"
          style="background: var(--s-sage); color: #fff; font-size: 0.8125rem; letter-spacing: 0.08em;"
          class="hidden md:inline-flex px-5 py-2.5 font-medium uppercase tracking-wider hover:opacity-90 transition-opacity text-xs">
          Book Now
        </a>
      </div>
    </nav>

    <slot />

    <!-- Footer -->
    <footer style="background: var(--s-bg-dark); color: rgba(255,255,255,0.4); font-size: 0.8125rem;" class="px-6 py-12">
      <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-8">
        <div>
          <p style="font-family: var(--font-serif); color: rgba(255,255,255,0.85); font-style: italic;" class="text-2xl mb-2">Solé</p>
          <p>1804 Green St NW<br/>Gainesville, GA 30501</p>
        </div>
        <div>
          <p style="color: rgba(255,255,255,0.6);" class="text-xs uppercase tracking-widest mb-3">Hours</p>
          <p>Tue–Fri &nbsp; 9am–7pm</p>
          <p>Sat &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; 9am–5pm</p>
          <p>Sun–Mon &nbsp; Closed</p>
        </div>
        <div class="md:text-right">
          <a href="/demos/pro/book"
            style="background: var(--s-sage); color: #fff;"
            class="inline-flex px-6 py-3 text-sm font-medium hover:opacity-90 transition-opacity mb-4">
            Book an Appointment
          </a>
          <p style="color: rgba(255,255,255,0.2); font-size: 0.7rem;" class="mt-4">
            Demo site — built by <a href="/" style="color: rgba(255,255,255,0.35);" class="hover:underline">Apex Web</a>
          </p>
        </div>
      </div>
    </footer>

    <script>
      const io = new IntersectionObserver(
        (entries) => entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('is-visible'); }),
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
