---
import Layout from "../layouts/Layout.astro";

const packages = [
  {
    name: "Starter",
    price: "$1,500",
    monthly: "$50",
    description: "Perfect for a clean, modern presence online.",
    features: ["5-page custom website", "Mobile responsive design", "Contact form", "Basic on-page SEO", "Hosting & SSL included", "1 hr edits/month"],
    highlight: false,
  },
  {
    name: "Plus",
    price: "$3,500",
    monthly: "$125",
    description: "Best for businesses that need to stay current.",
    features: ["Everything in Starter", "Up to 10 pages", "Blog or CMS", "Google Business setup", "Monthly content updates", "Analytics dashboard"],
    highlight: true,
  },
  {
    name: "Pro",
    price: "$6,000+",
    monthly: "$300",
    description: "For growing businesses ready to scale online.",
    features: ["Everything in Plus", "Online booking or e-commerce", "Custom integrations", "Priority support", "Monthly performance reports", "Quarterly strategy calls"],
    highlight: false,
  },
];
---

<Layout title="Apex Web — Websites for Local Businesses">
  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-edge" style="background: rgba(7,7,15,0.8); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="text-lg font-bold tracking-tight text-text" style="font-family: var(--font-display)">
        Apex<span class="gradient-text">Web</span>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm text-muted">
        <a href="#services" class="hover:text-text transition-colors">Services</a>
        <a href="#packages" class="hover:text-text transition-colors">Packages</a>
        <a href="#work" class="hover:text-text transition-colors">Work</a>
        <a href="#about" class="hover:text-text transition-colors">About</a>
        <a href="#contact" class="hover:text-text transition-colors">Contact</a>
      </div>
      <a href="#contact" class="hidden md:inline-flex gradient-bg text-white px-5 py-2.5 text-sm font-semibold rounded-lg hover:opacity-90 transition-opacity">
        Get a Quote
      </a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative min-h-screen flex items-center px-6 pt-32 pb-24 dot-grid overflow-hidden">
    <!-- Glow blobs -->
    <div class="absolute -top-32 -left-32 w-[700px] h-[700px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(124,58,237,0.12) 0%, transparent 65%); filter: blur(60px);"></div>
    <div class="absolute bottom-0 right-0 w-[500px] h-[500px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(6,182,212,0.1) 0%, transparent 65%); filter: blur(60px);"></div>

    <div class="relative max-w-6xl mx-auto w-full">
      <div class="reveal inline-flex items-center gap-2.5 border border-edge rounded-full px-4 py-2 mb-10 text-xs text-muted" style="font-family: var(--font-mono); background: rgba(255,255,255,0.03)">
        <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse flex-shrink-0"></span>
        actively_booking · Gainesville, GA
      </div>

      <h1 class="reveal reveal-delay-1 leading-[1.05] mb-8" style="font-family: var(--font-display)">
        <span class="block text-5xl md:text-7xl lg:text-8xl font-extrabold text-text">Websites that</span>
        <span class="block text-5xl md:text-7xl lg:text-8xl font-extrabold gradient-text">actually work</span>
        <span class="block text-5xl md:text-7xl lg:text-8xl font-extrabold text-text">for your business.</span>
      </h1>

      <p class="reveal reveal-delay-2 text-lg text-muted max-w-xl mb-10 leading-relaxed">
        Custom-built websites for local businesses. Fast, mobile-ready, and affordable.
        I handle the tech so you can run your business.
      </p>

      <div class="reveal reveal-delay-3 flex flex-col sm:flex-row gap-4 mb-16">
        <a href="#contact" class="gradient-bg text-white px-8 py-4 font-semibold rounded-lg hover:opacity-90 transition-opacity text-center text-sm">
          Get a Free Quote
        </a>
        <a href="#work" class="glass text-text px-8 py-4 font-semibold rounded-lg hover:border-edge-2 transition-colors text-center text-sm">
          See Our Work
        </a>
      </div>

      <div class="reveal reveal-delay-4 flex flex-wrap gap-4 pt-8 border-t border-edge">
        {[
          { value: "7 days", label: "avg. launch time" },
          { value: "100%", label: "mobile responsive" },
          { value: "A+", label: "page speed score" },
        ].map((stat) => (
          <div class="glass rounded-xl px-5 py-3">
            <div class="text-2xl font-bold text-text" style="font-family: var(--font-display)">{stat.value}</div>
            <div class="text-xs text-muted mt-0.5">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="px-6 py-24 bg-surface">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <p class="text-xs font-medium uppercase tracking-[0.25em] mb-3 text-muted" style="font-family: var(--font-mono)">// services</p>
        <h2 class="text-4xl md:text-5xl font-bold text-text" style="font-family: var(--font-display)">
          Everything you need<br/>to get online.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        {[
          {
            title: "Custom Web Design",
            desc: "Built from scratch for your brand. No templates, no cookie-cutter layouts. Every pixel intentional.",
            icon: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
          },
          {
            title: "Lightning Fast Hosting",
            desc: "Loads in under a second. Hosting, SSL, CDN, and automatic backups — all handled.",
            icon: "M13 10V3L4 14h7v7l9-11h-7z",
          },
          {
            title: "Ongoing Maintenance",
            desc: "Updates, security patches, and edits included. One monthly bill, no surprises.",
            icon: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15",
          },
        ].map((svc, i) => (
          <div class={`reveal reveal-delay-${i} glass rounded-xl p-7 group hover:border-violet/30 transition-all duration-300 hover:-translate-y-1`}>
            <div class="w-10 h-10 gradient-bg rounded-lg flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={svc.icon}/>
              </svg>
            </div>
            <h3 class="text-base font-semibold text-text mb-2" style="font-family: var(--font-display)">{svc.title}</h3>
            <p class="text-sm text-muted leading-relaxed">{svc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Packages -->
  <section id="packages" class="px-6 py-24 bg-bg dot-grid">
    <div class="max-w-6xl mx-auto">
      <div class="reveal text-center mb-16">
        <p class="text-xs font-medium uppercase tracking-[0.25em] mb-3 text-muted" style="font-family: var(--font-mono)">// pricing</p>
        <h2 class="text-4xl md:text-5xl font-bold text-text" style="font-family: var(--font-display)">Simple, honest pricing.</h2>
        <p class="text-muted mt-3 max-w-sm mx-auto text-sm">No hidden fees. No upsells. Pick the package that fits.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        {packages.map((pkg, i) => (
          <div class={`reveal reveal-delay-${i} flex flex-col rounded-2xl p-8 transition-all duration-300 hover:-translate-y-1 ${pkg.highlight ? 'glass-violet' : 'glass'}`}
            style={pkg.highlight ? 'box-shadow: 0 0 60px rgba(124,58,237,0.15)' : ''}>
            {pkg.highlight && (
              <div class="inline-flex self-start gradient-bg text-white text-xs font-bold px-3 py-1 rounded-full tracking-wide uppercase mb-4">
                Most Popular
              </div>
            )}
            <p class="text-xs font-semibold uppercase tracking-[0.2em] mb-3 text-muted" style="font-family: var(--font-mono)">{pkg.name}</p>
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-5xl font-extrabold text-text" style="font-family: var(--font-display)">{pkg.price}</span>
              <span class="text-sm text-faint">upfront</span>
            </div>
            <p class="text-sm text-faint mb-5">+ {pkg.monthly}/mo hosting & maintenance</p>
            <p class="text-sm text-muted mb-6 leading-relaxed">{pkg.description}</p>

            <ul class="space-y-2.5 mb-8 flex-1">
              {pkg.features.map((f) => (
                <li class="flex items-start gap-3 text-sm text-text">
                  <svg class="w-4 h-4 flex-shrink-0 mt-0.5 text-violet" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

            <a href={`/packages/${pkg.name.toLowerCase()}`}
              class={`block text-center w-full py-3.5 text-sm font-semibold rounded-xl transition-all duration-200 ${pkg.highlight ? 'gradient-bg text-white hover:opacity-90' : 'glass text-text hover:border-violet/30'}`}>
              See What's Included
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Work -->
  <section id="work" class="px-6 py-24 bg-surface">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-12">
        <p class="text-xs font-medium uppercase tracking-[0.25em] mb-3 text-muted" style="font-family: var(--font-mono)">// our work</p>
        <h2 class="text-4xl md:text-5xl font-bold text-text" style="font-family: var(--font-display)">Live demos. Real sites.</h2>
        <p class="text-muted mt-3 max-w-lg text-sm leading-relaxed">Click into any package to see a fully interactive example of what we build.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        {[
          { tier: "Starter", name: "Hogtown Smoke BBQ", industry: "Restaurant", href: "/packages/starter", tag: "$1,500" },
          { tier: "Plus", name: "The Perch Coffee Co.", industry: "Coffee Shop", href: "/packages/plus", tag: "$3,500", accent: true },
          { tier: "Pro", name: "Solé Wellness Studio", industry: "Spa & Wellness", href: "/packages/pro", tag: "$6,000+" },
        ].map((item, i) => (
          <a href={item.href} class={`reveal reveal-delay-${i} block group rounded-xl p-6 transition-all duration-300 hover:-translate-y-1 ${item.accent ? 'glass-violet' : 'glass'}`}>
            <div class="flex items-center justify-between mb-4">
              <span class="text-xs font-mono text-muted" style="font-family: var(--font-mono)">{item.tier}</span>
              <span class="text-xs font-semibold text-muted glass px-2.5 py-1 rounded-full">{item.tag}</span>
            </div>
            <p class="font-semibold text-text mb-0.5" style="font-family: var(--font-display)">{item.name}</p>
            <p class="text-xs text-muted mb-5">{item.industry}</p>
            <span class="text-xs font-medium text-violet group-hover:underline">View demo & details →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="px-6 py-24 bg-bg">
    <div class="max-w-6xl mx-auto md:grid md:grid-cols-5 md:gap-16 items-center">
      <div class="reveal md:col-span-2 mb-10 md:mb-0">
        <p class="text-xs font-medium uppercase tracking-[0.25em] mb-4 text-muted" style="font-family: var(--font-mono)">// about</p>
        <div class="text-8xl font-extrabold gradient-text leading-none select-none" style="font-family: var(--font-display)">&lt;/&gt;</div>
      </div>
      <div class="reveal reveal-delay-1 md:col-span-3">
        <p class="text-2xl md:text-3xl font-semibold text-text leading-snug mb-6" style="font-family: var(--font-display)">
          Local developer. Modern stack. Fair prices.
        </p>
        <div class="space-y-4 text-muted leading-relaxed text-sm">
          <p>I'm based in Gainesville, GA and build modern websites for local businesses who deserve better than a free template or a $10,000 agency quote.</p>
          <p>Every site is fast, mobile-ready, and actually works — no fluff, no jargon, no surprise invoices. Just clean code and a site you'll be proud to share.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="px-6 py-24 bg-surface">
    <div class="max-w-2xl mx-auto">
      <div class="reveal mb-12 text-center">
        <p class="text-xs font-medium uppercase tracking-[0.25em] mb-3 text-muted" style="font-family: var(--font-mono)">// contact</p>
        <h2 class="text-4xl md:text-5xl font-bold text-text" style="font-family: var(--font-display)">Let's build something.</h2>
        <p class="mt-3 text-sm text-muted">Tell me about your business. I'll get back to you within 24 hours.</p>
      </div>

      <form action="https://formspree.io/f/mzdojrav" method="POST" class="reveal space-y-4">
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-medium uppercase tracking-[0.15em] text-muted mb-2">Your Name</label>
            <input type="text" name="name" required placeholder="Jane Smith"
              class="w-full glass rounded-lg px-4 py-3 text-sm text-text placeholder:text-faint focus:outline-none focus:border-violet/50 transition-colors" />
          </div>
          <div>
            <label class="block text-xs font-medium uppercase tracking-[0.15em] text-muted mb-2">Email</label>
            <input type="email" name="email" required placeholder="jane@business.com"
              class="w-full glass rounded-lg px-4 py-3 text-sm text-text placeholder:text-faint focus:outline-none focus:border-violet/50 transition-colors" />
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium uppercase tracking-[0.15em] text-muted mb-2">Business Name</label>
          <input type="text" name="business" placeholder="Your Business"
            class="w-full glass rounded-lg px-4 py-3 text-sm text-text placeholder:text-faint focus:outline-none focus:border-violet/50 transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-medium uppercase tracking-[0.15em] text-muted mb-2">Tell me about your project</label>
          <textarea name="message" rows="5" required placeholder="What kind of site do you need? What does your business do?"
            class="w-full glass rounded-lg px-4 py-3 text-sm text-text placeholder:text-faint focus:outline-none focus:border-violet/50 transition-colors resize-none"></textarea>
        </div>
        <button type="submit" class="w-full gradient-bg text-white font-semibold py-4 rounded-lg hover:opacity-90 transition-opacity text-sm">
          Send Message
        </button>
      </form>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-edge px-6 py-8 bg-bg">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-faint">
      <div class="font-semibold text-muted" style="font-family: var(--font-display)">Apex<span class="gradient-text">Web</span></div>
      <div>© 2026 Apex Web · Gainesville, GA</div>
      <div>Built with Astro + Tailwind</div>
    </div>
  </footer>
</Layout>
