---
import Layout from "../layouts/Layout.astro";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Lanier Web",
  "image": "https://lanierweb.com/og.png",
  "@id": "https://lanierweb.com",
  "url": "https://lanierweb.com",
  "email": "info@lanierweb.com",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Gainesville",
    "addressRegion": "GA",
    "postalCode": "30501",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 34.2979,
    "longitude": -83.8241
  },
  "areaServed": [
    { "@type": "City", "name": "Gainesville" },
    { "@type": "City", "name": "Oakwood" },
    { "@type": "City", "name": "Flowery Branch" },
    { "@type": "City", "name": "Dahlonega" },
    { "@type": "City", "name": "Cumming" }
  ],
  "description": "Modern, custom-built websites for local businesses in Gainesville, Georgia and the surrounding North Georgia area. Hosting, SSL, and monthly edits included.",
  "sameAs": []
};

const packages = [
  {
    name: "Starter",
    price: "$1,500",
    monthly: "$50",
    features: ["5-page custom website", "Mobile responsive", "Contact form", "Basic SEO", "Hosting & SSL", "1 hr edits/month"],
    highlight: false,
  },
  {
    name: "Plus",
    price: "$3,500",
    monthly: "$125",
    features: ["Everything in Starter", "Up to 10 pages", "Blog or CMS", "Google Business setup", "Monthly content updates", "Analytics"],
    highlight: true,
  },
  {
    name: "Pro",
    price: "$6,000+",
    monthly: "$300",
    features: ["Everything in Plus", "Online booking / e-commerce", "Custom integrations", "Priority support", "Monthly reports", "Quarterly strategy calls"],
    highlight: false,
  },
];
---

<Layout>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(localBusinessSchema)} />
  </Fragment>

  <!-- Nav -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-border">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-lg font-extrabold text-ink tracking-tight">
        <span class="w-2.5 h-2.5 rounded-full bg-accent flex-shrink-0"></span>
        Lanier Web
      </a>
      <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-muted" aria-label="Primary">
        <a href="#services" class="hover:text-ink transition-colors">Services</a>
        <a href="#packages" class="hover:text-ink transition-colors">Packages</a>
        <a href="#work" class="hover:text-ink transition-colors">Work</a>
        <a href="#about" class="hover:text-ink transition-colors">About</a>
        <a href="#contact" class="hover:text-ink transition-colors">Contact</a>
      </nav>
      <a href="#contact" class="hidden md:inline-flex items-center bg-accent text-white px-5 py-2.5 text-sm font-bold rounded-full hover:bg-accent-dark transition-colors">
        Get a Quote
      </a>
      <button id="navToggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="navPanel" class="md:hidden p-2 -mr-2 text-ink">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
    <div id="navPanel" class="md:hidden hidden border-t border-border bg-white">
      <nav class="px-6 py-4 flex flex-col gap-3 text-sm font-medium text-ink" aria-label="Mobile">
        <a href="#services">Services</a>
        <a href="#packages">Packages</a>
        <a href="#work">Work</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
        <a href="#contact" class="bg-accent text-white px-5 py-2.5 font-bold rounded-full self-start mt-2">Get a Quote</a>
      </nav>
    </div>
  </header>

  <script is:inline>
    (function() {
      var btn = document.getElementById('navToggle');
      var panel = document.getElementById('navPanel');
      if (btn && panel) {
        btn.addEventListener('click', function() {
          var open = panel.classList.toggle('hidden') ? 'false' : 'true';
          btn.setAttribute('aria-expanded', open);
        });
        panel.addEventListener('click', function(e) {
          if (e.target.tagName === 'A') {
            panel.classList.add('hidden');
            btn.setAttribute('aria-expanded', 'false');
          }
        });
      }
    })();
  </script>

  <!-- Hero -->
  <section class="px-6 pt-24 pb-16 bg-white overflow-hidden relative">
    <div class="relative max-w-6xl mx-auto w-full">
      <!-- Big background number — clamped so it doesn't overlap content on small laptops -->
      <div aria-hidden="true" class="absolute right-0 top-1/2 -translate-y-1/2 font-extrabold leading-none select-none pointer-events-none hidden lg:block"
        style="color: #F0F0F0; font-size: clamp(8rem, 14vw, 16rem); line-height: 0.85;">01</div>

      <div class="reveal inline-flex items-center gap-2 bg-accent-light border border-accent/20 rounded-full px-4 py-2 text-xs font-semibold text-accent mb-8 uppercase tracking-widest">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
        Booking new clients · Gainesville, GA
      </div>

      <h1 class="reveal reveal-delay-1 font-extrabold leading-[1.05] mb-6 max-w-3xl relative" style="font-size: clamp(2rem, 4vw, 3.25rem)">
        Modern websites<br/>
        for the businesses<br/>
        that <span class="text-accent">built Gainesville</span>.
      </h1>

      <p class="reveal reveal-delay-2 text-base text-muted max-w-lg mb-8 leading-relaxed relative">
        Custom-built sites for local restaurants, gyms, contractors, and shops. Fast, mobile-first, and built to bring customers in. You run the business — I handle the rest.
      </p>

      <div class="reveal reveal-delay-3 flex flex-col sm:flex-row gap-3 mb-12 relative">
        <a href="#contact" class="bg-accent text-white px-8 py-4 font-bold text-sm rounded-full hover:bg-accent-dark transition-colors text-center">
          Get a Free Quote →
        </a>
        <a href="#work" class="bg-off text-ink px-8 py-4 font-bold text-sm rounded-full hover:bg-border transition-colors text-center">
          See Live Examples
        </a>
      </div>

      <div class="reveal reveal-delay-4 grid grid-cols-3 gap-8 pt-10 border-t border-border max-w-lg relative">
        {[
          { n: "7", unit: "days", label: "avg. launch time" },
          { n: "100", unit: "%", label: "mobile-first build" },
          { n: "A+", unit: "", label: "page-speed score" },
        ].map((s) => (
          <div>
            <div class="text-3xl font-extrabold text-ink leading-none">{s.n}<span class="text-accent">{s.unit}</span></div>
            <div class="text-xs text-muted mt-1">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="px-6 py-24 bg-off">
    <div class="max-w-6xl mx-auto">
      <div class="reveal flex flex-col md:flex-row md:items-end justify-between mb-16 gap-4">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-3">Services</p>
          <h2 class="text-4xl md:text-5xl font-extrabold text-ink">What you get.</h2>
        </div>
        <p class="text-muted max-w-xs text-sm leading-relaxed">A site that works the way your customers actually use the internet — under one monthly plan.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        {[
          { num: "01", title: "Designed around your customers", desc: "Built for what your visitors actually want to do — call, book, order, or stop in. No templates. No filler pages." },
          { num: "02", title: "Fast on every device", desc: "Modern static-site tech and Cloudflare hosting. Loads in under a second on a slow phone, on a fast laptop, anywhere." },
          { num: "03", title: "Maintained every month", desc: "Edits, security patches, and content updates are part of your plan. No tickets, no surprise invoices, no out-of-date plugins." },
        ].map((svc, i) => (
          <div class={`reveal reveal-delay-${i} bg-white rounded-2xl p-8 border border-border hover:border-accent/30 hover:shadow-lg transition-all duration-300 group`}>
            <p class="text-5xl font-extrabold text-border mb-6 group-hover:text-accent-light transition-colors">{svc.num}</p>
            <h3 class="text-lg font-bold text-ink mb-3">{svc.title}</h3>
            <p class="text-sm text-muted leading-relaxed">{svc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Packages -->
  <section id="packages" class="px-6 py-24 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="reveal text-center mb-16">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-3">Pricing</p>
        <h2 class="text-4xl md:text-5xl font-extrabold text-ink">Three plans. No surprises.</h2>
        <p class="text-muted mt-3 text-sm">Pick what fits your business today. You can always move up later.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-5 items-start">
        {packages.map((pkg, i) => (
          <div class={`reveal reveal-delay-${i} flex flex-col rounded-2xl p-8 transition-all duration-300 hover:-translate-y-1 ${pkg.highlight ? 'bg-ink text-white shadow-2xl' : 'bg-off border border-border'}`}>
            {pkg.highlight && (
              <div class="inline-flex self-start bg-accent text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-widest mb-4">
                Most Popular
              </div>
            )}
            <p class={`text-xs font-bold uppercase tracking-[0.2em] mb-3 ${pkg.highlight ? 'text-accent' : 'text-muted'}`}>{pkg.name}</p>
            <div class="flex items-baseline gap-2 mb-1">
              <span class={`text-5xl font-extrabold ${pkg.highlight ? 'text-white' : 'text-ink'}`}>{pkg.price}</span>
              <span class={`text-sm ${pkg.highlight ? 'text-white/50' : 'text-faint'}`}>upfront</span>
            </div>
            <p class={`text-sm mb-6 ${pkg.highlight ? 'text-white/50' : 'text-faint'}`}>+ {pkg.monthly}/mo hosting</p>

            <ul class="space-y-2.5 mb-8 flex-1">
              {pkg.features.map((f) => (
                <li class="flex items-start gap-3 text-sm">
                  <svg class={`w-4 h-4 flex-shrink-0 mt-0.5 ${pkg.highlight ? 'text-accent' : 'text-accent'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                  <span class={pkg.highlight ? 'text-white/80' : 'text-ink'}>{f}</span>
                </li>
              ))}
            </ul>

            <a href={`/packages/${pkg.name.toLowerCase()}`}
              class={`block text-center w-full py-3.5 text-sm font-bold rounded-full transition-all duration-200 ${pkg.highlight ? 'bg-accent text-white hover:bg-accent-dark' : 'bg-ink text-white hover:bg-accent'}`}>
              See What's Included →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Work -->
  <section id="work" class="px-6 py-24 bg-off">
    <div class="max-w-6xl mx-auto">
      <div class="reveal flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-3">Live Examples</p>
          <h2 class="text-4xl md:text-5xl font-extrabold text-ink">See what each plan builds.</h2>
        </div>
        <p class="text-muted text-sm max-w-xs leading-relaxed">Each package below opens to a live, working example. Click around the way a real customer would.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        {[
          { tier: "Starter", name: "Hogtown Smoke BBQ", industry: "Restaurant", href: "/packages/starter", price: "$1,500" },
          { tier: "Plus", name: "The Perch Coffee Co.", industry: "Coffee Shop", href: "/packages/plus", price: "$3,500", accent: true },
          { tier: "Pro", name: "Solé Wellness Studio", industry: "Spa & Wellness", href: "/packages/pro", price: "$6,000+" },
        ].map((item, i) => (
          <a href={item.href} class={`reveal reveal-delay-${i} block group rounded-2xl p-6 border transition-all duration-300 hover:-translate-y-1 hover:shadow-lg ${item.accent ? 'bg-ink border-ink' : 'bg-white border-border'}`}>
            <div class="flex items-center justify-between mb-4">
              <span class={`text-xs font-bold uppercase tracking-widest ${item.accent ? 'text-accent' : 'text-muted'}`}>{item.tier}</span>
              <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${item.accent ? 'bg-white/10 text-white/60' : 'bg-off text-muted'}`}>{item.price}</span>
            </div>
            <p class={`font-bold text-base mb-0.5 ${item.accent ? 'text-white' : 'text-ink'}`}>{item.name}</p>
            <p class={`text-xs mb-5 ${item.accent ? 'text-white/50' : 'text-muted'}`}>{item.industry}</p>
            <span class={`text-xs font-bold group-hover:underline ${item.accent ? 'text-accent' : 'text-accent'}`}>View demo & details →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About — dark bold section -->
  <section id="about" class="px-6 py-24 bg-ink-2">
    <div class="max-w-6xl mx-auto md:grid md:grid-cols-2 gap-20 items-center">
      <div class="reveal mb-12 md:mb-0">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-4">About</p>
        <h2 class="text-4xl md:text-5xl font-extrabold text-white leading-tight mb-6">
          Local dev.<br/>Modern sites.<br/><span class="text-accent">No agency markup.</span>
        </h2>
        <a href="#contact" class="inline-flex bg-accent text-white px-7 py-3.5 font-bold text-sm rounded-full hover:bg-accent-dark transition-colors">
          Let's Talk →
        </a>
      </div>
      <div class="reveal reveal-delay-1 space-y-6">
        <p class="text-white/70 leading-relaxed">
          Lanier Web is based in Gainesville, GA. I build modern sites for the local restaurants, gyms, contractors, and shops who want better than a template — and don't want to pay an out-of-state agency for it.
        </p>
        <p class="text-white/70 leading-relaxed">
          One person handling design, build, and the monthly upkeep. No subcontractors, no ticket queues, no surprise invoices. When you call, I pick up.
        </p>
        <div class="grid grid-cols-3 gap-4 pt-6 border-t border-white/10">
          {[{ n: "7 days", l: "to launch" }, { n: "100%", l: "mobile-first" }, { n: "1 person", l: "no handoffs" }].map((s) => (
            <div>
              <div class="text-2xl font-extrabold text-accent">{s.n}</div>
              <div class="text-xs text-white/40 mt-0.5">{s.l}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="px-6 py-24 bg-white">
    <div class="max-w-2xl mx-auto">
      <div class="reveal text-center mb-12">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-3">Contact</p>
        <h2 class="text-4xl md:text-5xl font-extrabold text-ink">Tell me about your business.</h2>
        <p class="text-muted mt-3 text-sm">A reply within one business day. Or email <a href="mailto:info@lanierweb.com" class="text-accent hover:underline">info@lanierweb.com</a> directly.</p>
      </div>

      <form action="https://formspree.io/f/mzdojrav" method="POST" class="reveal space-y-4" autocomplete="on">
        <!-- Honeypot — bots fill this, real users won't see it -->
        <div style="position: absolute; left: -9999px; height: 0; width: 0; overflow: hidden;" aria-hidden="true">
          <label>Don't fill this in if you're human: <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" /></label>
        </div>

        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label for="contact-name" class="block text-xs font-bold uppercase tracking-[0.15em] text-ink mb-2">Name</label>
            <input id="contact-name" type="text" name="name" required maxlength="100" autocomplete="name" placeholder="Jane Smith"
              class="w-full bg-off border border-border rounded-xl px-4 py-3 text-sm text-ink placeholder:text-faint focus:outline-none focus:border-accent transition-colors" />
          </div>
          <div>
            <label for="contact-email" class="block text-xs font-bold uppercase tracking-[0.15em] text-ink mb-2">Email</label>
            <input id="contact-email" type="email" name="email" required maxlength="254" autocomplete="email" placeholder="jane@yourbusiness.com"
              class="w-full bg-off border border-border rounded-xl px-4 py-3 text-sm text-ink placeholder:text-faint focus:outline-none focus:border-accent transition-colors" />
          </div>
        </div>
        <div>
          <label for="contact-business" class="block text-xs font-bold uppercase tracking-[0.15em] text-ink mb-2">Business Name</label>
          <input id="contact-business" type="text" name="business" maxlength="100" autocomplete="organization" placeholder="Your Business"
            class="w-full bg-off border border-border rounded-xl px-4 py-3 text-sm text-ink placeholder:text-faint focus:outline-none focus:border-accent transition-colors" />
        </div>
        <div>
          <label for="contact-message" class="block text-xs font-bold uppercase tracking-[0.15em] text-ink mb-2">Project Details</label>
          <textarea id="contact-message" name="message" rows="5" required maxlength="5000" placeholder="What kind of site do you need? What does your business do?"
            class="w-full bg-off border border-border rounded-xl px-4 py-3 text-sm text-ink placeholder:text-faint focus:outline-none focus:border-accent transition-colors resize-none"></textarea>
        </div>
        <button type="submit" class="w-full bg-accent text-white font-bold py-4 rounded-full hover:bg-accent-dark transition-colors text-sm">
          Send Message →
        </button>
      </form>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-border px-6 py-10 bg-white">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row md:items-center justify-between gap-6 text-sm">
      <div>
        <div class="flex items-center gap-2 font-extrabold text-ink mb-2">
          <span class="w-2 h-2 rounded-full bg-accent"></span>
          Lanier Web
        </div>
        <div class="text-faint text-xs">Gainesville, GA · serving North Georgia</div>
      </div>
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-xs text-muted">
        <a href="mailto:info@lanierweb.com" class="hover:text-ink transition-colors">info@lanierweb.com</a>
        <a href="#packages" class="hover:text-ink transition-colors">Packages</a>
        <a href="#work" class="hover:text-ink transition-colors">Work</a>
        <a href="#contact" class="hover:text-ink transition-colors">Contact</a>
      </div>
      <div class="text-faint text-xs">© 2026 Lanier Web</div>
    </div>
  </footer>
</Layout>
