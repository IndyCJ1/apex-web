---
import Layout from "../layouts/Layout.astro";

const packages = [
  {
    name: "Starter",
    price: "$1,500",
    monthly: "$50",
    description: "Perfect for a clean, modern presence online.",
    features: [
      "5-page custom website",
      "Mobile responsive design",
      "Contact form",
      "Basic on-page SEO",
      "Hosting & SSL included",
      "1 hour of edits per month",
    ],
    highlight: false,
    accentClass: "border-t-4 border-t-ink/20",
    labelColor: "text-ink-muted",
  },
  {
    name: "Plus",
    price: "$3,500",
    monthly: "$125",
    description: "Best for businesses that need to stay current.",
    features: [
      "Everything in Starter",
      "Up to 10 pages",
      "Blog or CMS for easy editing",
      "Google Business setup",
      "Monthly content updates",
      "Analytics dashboard",
    ],
    highlight: true,
    accentClass: "border-t-4 border-t-terracotta",
    labelColor: "text-terracotta",
  },
  {
    name: "Pro",
    price: "$6,000+",
    monthly: "$300",
    description: "For growing businesses ready to scale online.",
    features: [
      "Everything in Plus",
      "Online booking or e-commerce",
      "Custom integrations",
      "Priority support",
      "Monthly performance reports",
      "Quarterly strategy calls",
    ],
    highlight: false,
    accentClass: "border-t-4 border-t-forest",
    labelColor: "text-forest",
  },
];

const demos = [
  {
    name: "Hogtown Smoke BBQ",
    industry: "Restaurant · Starter",
    url: "https://hogtown-smoke.pages.dev",
    description: "Custom restaurant site with hero, full menu, hours, location, and online ordering links.",
    features: {
      starter: ["Custom design & branding", "Mobile responsive layout", "Location, hours & contact"],
      plus: ["Full menu by section", "Easy content updates", "Google Maps embed"],
      pro: ["Online ordering buttons", "Delivery integrations", "Third-party links"],
    },
  },
  {
    name: "The Perch Coffee Co.",
    industry: "Coffee Shop · Plus",
    url: "/demos/plus",
    description: "Multi-page coffee shop site with full menu, blog, events calendar, and Google Maps.",
    features: {
      starter: ["Custom design & branding", "Mobile responsive layout", "Hours & contact"],
      plus: ["6-page site (menu, blog, events)", "CMS blog with 6 posts", "Google Maps & events calendar"],
      pro: ["Online ordering add-on", "Loyalty program integration", "Merch e-commerce"],
    },
  },
  {
    name: "Solé Wellness Studio",
    industry: "Spa & Wellness · Pro",
    url: "/demos/pro",
    description: "Full-featured wellness studio site with online booking, service catalog, shop, and testimonials.",
    features: {
      starter: ["Custom design & branding", "Mobile responsive layout", "Location & contact info"],
      plus: ["Full service catalog pages", "Google Business setup", "Monthly content updates"],
      pro: ["Online booking system", "Product shop with cart", "Testimonials & reviews"],
    },
  },
];
---

<Layout title="Apex Web — Websites for Local Businesses">
  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-border" style="background: rgba(247,242,233,0.88); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="text-xl font-bold tracking-tight text-ink" style="font-family: var(--font-display)">
        Apex Web
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm font-medium text-ink-muted">
        <a href="#services" class="hover:text-ink transition-colors">Services</a>
        <a href="#packages" class="hover:text-ink transition-colors">Packages</a>
        <a href="#work" class="hover:text-ink transition-colors">Work</a>
        <a href="#about" class="hover:text-ink transition-colors">About</a>
        <a href="#contact" class="hover:text-ink transition-colors">Contact</a>
      </div>
      <a href="#contact" class="hidden md:inline-flex items-center bg-ink text-cream px-5 py-2.5 text-sm font-semibold hover:bg-terracotta transition-colors duration-300">
        Get a Quote
      </a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="min-h-screen flex items-center px-6 pt-32 pb-24 bg-cream">
    <div class="max-w-6xl mx-auto w-full">
      <div class="reveal inline-flex items-center gap-2.5 text-sm text-ink-muted border border-border px-4 py-2 mb-10">
        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse flex-shrink-0"></span>
        Now booking projects in Gainesville, GA
      </div>

      <h1 class="reveal reveal-delay-1 leading-none mb-8" style="font-family: var(--font-display)">
        <span class="block text-5xl md:text-6xl lg:text-7xl font-medium text-ink tracking-tight">Websites that</span>
        <span class="block text-7xl md:text-9xl lg:text-[10rem] font-bold italic text-terracotta leading-[0.9] my-1 md:my-2">actually work</span>
        <span class="block text-5xl md:text-6xl lg:text-7xl font-medium text-ink tracking-tight">for your business.</span>
      </h1>

      <p class="reveal reveal-delay-2 text-lg text-ink-muted max-w-xl mb-10 leading-relaxed">
        Custom-built websites for local businesses. Fast, mobile-friendly, and affordable.
        I handle the tech so you can focus on running your business.
      </p>

      <div class="reveal reveal-delay-3 flex flex-col sm:flex-row gap-4 mb-16">
        <a href="#contact" class="bg-terracotta text-cream px-8 py-4 font-medium hover:bg-terracotta-dark transition-colors text-center text-sm tracking-wide">
          Get a Free Quote
        </a>
        <a href="#work" class="border border-ink text-ink px-8 py-4 font-medium hover:bg-ink hover:text-cream transition-colors text-center text-sm tracking-wide">
          See Our Work
        </a>
      </div>

      <div class="reveal reveal-delay-4 flex flex-wrap gap-10 pt-8 border-t border-border">
        <div>
          <div class="text-3xl font-semibold text-ink" style="font-family: var(--font-display)">7 days</div>
          <div class="text-sm text-ink-muted mt-0.5">Average launch time</div>
        </div>
        <div>
          <div class="text-3xl font-semibold text-ink" style="font-family: var(--font-display)">100%</div>
          <div class="text-sm text-ink-muted mt-0.5">Mobile responsive</div>
        </div>
        <div>
          <div class="text-3xl font-semibold text-ink" style="font-family: var(--font-display)">A+</div>
          <div class="text-sm text-ink-muted mt-0.5">Page speed scores</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="px-6 py-24 bg-ink">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <p class="text-xs font-medium uppercase tracking-[0.2em] mb-3" style="color: rgba(247,242,233,0.45)">What I Do</p>
        <h2 class="text-4xl md:text-5xl font-semibold text-cream" style="font-family: var(--font-display)">
          Everything your business<br class="hidden md:block" /> needs to get online.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="reveal p-8 rounded-lg hover:-translate-y-1 transition-transform duration-300" style="background: rgba(247,242,233,0.06); border: 1px solid rgba(247,242,233,0.1);">
          <div class="w-10 h-10 bg-terracotta/20 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-5 h-5 text-terracotta" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3 text-cream" style="font-family: var(--font-display)">Custom Web Design</h3>
          <p class="text-sm leading-relaxed" style="color: rgba(247,242,233,0.6)">Built from scratch for your brand. No templates, no cookie-cutter layouts.</p>
        </div>

        <div class="reveal reveal-delay-1 p-8 rounded-lg hover:-translate-y-1 transition-transform duration-300" style="background: rgba(247,242,233,0.06); border: 1px solid rgba(247,242,233,0.1);">
          <div class="w-10 h-10 bg-terracotta/20 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-5 h-5 text-terracotta" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3 text-cream" style="font-family: var(--font-display)">Lightning Fast Hosting</h3>
          <p class="text-sm leading-relaxed" style="color: rgba(247,242,233,0.6)">Loads in under a second. Hosting, SSL, and backups all handled and included.</p>
        </div>

        <div class="reveal reveal-delay-2 p-8 rounded-lg hover:-translate-y-1 transition-transform duration-300" style="background: rgba(247,242,233,0.06); border: 1px solid rgba(247,242,233,0.1);">
          <div class="w-10 h-10 bg-terracotta/20 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-5 h-5 text-terracotta" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3 text-cream" style="font-family: var(--font-display)">Ongoing Maintenance</h3>
          <p class="text-sm leading-relaxed" style="color: rgba(247,242,233,0.6)">Updates, security patches, and edits — all included in your monthly plan.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Packages -->
  <section id="packages" class="px-6 py-24 bg-cream">
    <div class="max-w-6xl mx-auto">
      <div class="reveal text-center mb-16">
        <p class="text-xs font-medium text-ink-muted uppercase tracking-[0.2em] mb-3">Pricing</p>
        <h2 class="text-4xl md:text-5xl font-semibold" style="font-family: var(--font-display)">
          Simple, honest pricing.
        </h2>
        <p class="text-ink-muted mt-3 max-w-md mx-auto text-sm">No hidden fees. No upsells. Pick the package that fits.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {packages.map((pkg, i) => (
          <div class={`reveal reveal-delay-${i} flex flex-col rounded-xl p-8 transition-all duration-300 hover:-translate-y-1 ${pkg.highlight ? 'bg-ink text-cream' : 'bg-white border border-border'}`}
            style={pkg.highlight ? 'box-shadow: 0 12px 40px rgba(26,21,18,0.2)' : 'box-shadow: 0 2px 12px rgba(26,21,18,0.06)'}>
            {pkg.highlight && (
              <div class="inline-flex self-start bg-terracotta text-cream text-xs font-bold px-3 py-1 tracking-widest uppercase mb-4 rounded-full">
                Most Popular
              </div>
            )}
            <div class="mb-6">
              <p class={`text-xs font-semibold uppercase tracking-[0.15em] mb-3 ${pkg.highlight ? 'text-terracotta' : pkg.labelColor}`}>{pkg.name}</p>
              <div class="flex items-baseline gap-2 mb-1" style="font-family: var(--font-display)">
                <span class="text-5xl font-bold">{pkg.price}</span>
                <span class={`text-sm ${pkg.highlight ? 'opacity-50' : 'text-ink-muted'}`}>upfront</span>
              </div>
              <p class={`text-sm ${pkg.highlight ? 'opacity-50' : 'text-ink-muted'}`}>+ {pkg.monthly}/mo hosting & maintenance</p>
            </div>

            <p class={`text-sm mb-6 leading-relaxed ${pkg.highlight ? 'opacity-60' : 'text-ink-muted'}`}>{pkg.description}</p>

            <ul class="space-y-3 mb-8 flex-1">
              {pkg.features.map((feature) => (
                <li class="flex items-start gap-3 text-sm">
                  <svg class="w-4 h-4 flex-shrink-0 mt-0.5 text-terracotta" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                  <span class={pkg.highlight ? 'text-cream' : 'text-ink'}>{feature}</span>
                </li>
              ))}
            </ul>

            <a
              href={`/packages/${pkg.name.toLowerCase()}`}
              class={`block text-center w-full py-3.5 text-sm font-semibold rounded-lg transition-all duration-200 ${pkg.highlight ? 'bg-terracotta text-cream hover:bg-terracotta-dark' : 'bg-ink text-cream hover:bg-terracotta'}`}
            >
              See What's Included
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Work -->
  <section id="work" class="px-6 py-24 bg-cream-dark">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-12">
        <p class="text-xs font-medium text-ink-muted uppercase tracking-[0.2em] mb-3">Our Work</p>
        <h2 class="text-4xl md:text-5xl font-semibold" style="font-family: var(--font-display)">
          Live demos. Real sites.
        </h2>
        <p class="text-ink-muted mt-3 max-w-lg text-sm leading-relaxed">
          Each package comes with a live example you can click through. See exactly what you'd get.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        {[
          { tier: "Starter", industry: "Restaurant", name: "Hogtown Smoke BBQ", href: "/packages/starter", color: "text-ink-muted", border: "border-border" },
          { tier: "Plus", industry: "Coffee Shop", name: "The Perch Coffee Co.", href: "/packages/plus", color: "text-terracotta", border: "border-terracotta/30" },
          { tier: "Pro", industry: "Spa & Wellness", name: "Solé Wellness Studio", href: "/packages/pro", color: "text-forest", border: "border-forest/30" },
        ].map((item, i) => (
          <a href={item.href} class={`reveal reveal-delay-${i} block group bg-white border ${item.border} p-6 hover:shadow-md transition-shadow`}>
            <p class={`text-xs font-semibold uppercase tracking-[0.15em] mb-1 ${item.color}`}>{item.tier}</p>
            <p class="font-semibold text-ink mb-0.5" style="font-family: var(--font-display)">{item.name}</p>
            <p class="text-xs text-ink-muted mb-4">{item.industry}</p>
            <span class={`text-xs font-medium ${item.color} group-hover:underline`}>View demo & details →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- UNUSED_CAROUSEL_START -->
  <div class="hidden">
      <!-- Carousel -->
      <div class="relative">
        <button id="demo-prev" aria-label="Previous demo"
          class="absolute left-0 top-[270px] -translate-x-5 z-10 w-10 h-10 bg-ink text-cream flex items-center justify-center hover:bg-terracotta transition-colors hidden md:flex">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>
        <button id="demo-next" aria-label="Next demo"
          class="absolute right-0 top-[270px] translate-x-5 z-10 w-10 h-10 bg-ink text-cream flex items-center justify-center hover:bg-terracotta transition-colors hidden md:flex">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </button>

        {demos.map((demo, i) => (
          <div class={`demo-slide${i !== 0 ? ' hidden' : ''}`} data-index={i}>
            <!-- Browser mockup -->
            <div class="border border-border shadow-xl bg-white overflow-hidden reveal">
              <!-- Chrome bar -->
              <div class="flex items-center gap-3 px-4 py-3 bg-cream-dark border-b border-border">
                <div class="flex gap-1.5">
                  <div class="w-3 h-3 rounded-full bg-red-400/70"></div>
                  <div class="w-3 h-3 rounded-full bg-yellow-400/70"></div>
                  <div class="w-3 h-3 rounded-full bg-green-400/70"></div>
                </div>
                <div class="flex-1 bg-white border border-border rounded px-3 py-1.5 text-xs text-ink-muted font-mono truncate">
                  {demo.url}
                </div>
                <a href={demo.url} target="_blank" rel="noopener"
                  class="text-ink-faint hover:text-ink transition-colors flex-shrink-0" title="Open in new tab">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                </a>
              </div>
              <!-- iframe -->
              <div class="h-[520px] overflow-hidden bg-white">
                <iframe src={demo.url} title={`${demo.name} demo`} loading="lazy"
                  class="w-full h-full border-0"></iframe>
              </div>
            </div>

            <!-- Callout arrows -->
            <div class="grid md:grid-cols-3 gap-0 mt-1">
              {['text-ink-muted', 'text-terracotta', 'text-forest'].map((color) => (
                <div class="flex justify-center py-2">
                  <svg class={`w-4 h-4 ${color} opacity-50`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
                  </svg>
                </div>
              ))}
            </div>

            <!-- Feature callout columns -->
            <div class="grid md:grid-cols-3 gap-4 reveal">
              <div class="border border-border bg-white p-5">
                <div class="flex items-center gap-2 mb-4">
                  <div class="w-1.5 h-1.5 rounded-full bg-ink-muted"></div>
                  <span class="text-xs font-semibold uppercase tracking-[0.15em] text-ink-muted">Starter — $1,500</span>
                </div>
                <ul class="space-y-2">
                  {demo.features.starter.map((f) => (
                    <li class="flex items-start gap-2 text-sm text-ink">
                      <svg class="w-3.5 h-3.5 text-ink-muted flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                      </svg>
                      {f}
                    </li>
                  ))}
                </ul>
                <a href="/packages/starter" class="mt-4 inline-block text-xs text-ink-muted hover:text-ink transition-colors">Details →</a>
              </div>

              <div class="border border-terracotta/30 bg-white p-5">
                <div class="flex items-center gap-2 mb-4">
                  <div class="w-1.5 h-1.5 rounded-full bg-terracotta"></div>
                  <span class="text-xs font-semibold uppercase tracking-[0.15em] text-terracotta">Plus — $3,500</span>
                </div>
                <ul class="space-y-2">
                  {demo.features.plus.map((f) => (
                    <li class="flex items-start gap-2 text-sm text-ink">
                      <svg class="w-3.5 h-3.5 text-terracotta flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                      </svg>
                      {f}
                    </li>
                  ))}
                </ul>
                <a href="/packages/plus" class="mt-4 inline-block text-xs text-terracotta hover:text-terracotta-dark transition-colors">Details →</a>
              </div>

              <div class="border border-forest/30 bg-white p-5">
                <div class="flex items-center gap-2 mb-4">
                  <div class="w-1.5 h-1.5 rounded-full bg-forest"></div>
                  <span class="text-xs font-semibold uppercase tracking-[0.15em] text-forest">Pro — $6,000+</span>
                </div>
                <ul class="space-y-2">
                  {demo.features.pro.map((f) => (
                    <li class="flex items-start gap-2 text-sm text-ink">
                      <svg class="w-3.5 h-3.5 text-forest flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                      </svg>
                      {f}
                    </li>
                  ))}
                </ul>
                <a href="/packages/pro" class="mt-4 inline-block text-xs text-forest hover:text-forest-dark transition-colors">Details →</a>
              </div>
            </div>

            <!-- Demo info + dots -->
            <div class="mt-5 flex items-center justify-between">
              <div>
                <p class="text-xs font-medium text-ink-muted uppercase tracking-[0.15em] mb-0.5">{demo.industry}</p>
                <p class="font-semibold text-ink" style="font-family: var(--font-display)">{demo.name}</p>
                <p class="text-sm text-ink-muted mt-0.5">{demo.description}</p>
              </div>
              {demos.length > 1 && (
                <div class="flex gap-2">
                  {demos.map((_, j) => (
                    <button class={`demo-dot w-2 h-2 rounded-full transition-colors ${j === i ? 'bg-ink' : 'bg-border-dark hover:bg-ink-muted'}`}
                      data-index={j} aria-label={`Demo ${j + 1}`}></button>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
  <!-- UNUSED_CAROUSEL_END -->

  <!-- About -->
  <section id="about" class="px-6 py-24 bg-cream">
    <div class="max-w-6xl mx-auto">
      <div class="reveal md:grid md:grid-cols-5 md:gap-16 items-start">
        <div class="md:col-span-2 mb-8 md:mb-0">
          <p class="text-xs font-medium text-ink-muted uppercase tracking-[0.2em] mb-4">About</p>
          <div class="text-[7rem] leading-none font-bold text-cream-deeper select-none" style="font-family: var(--font-display)">"</div>
        </div>
        <div class="md:col-span-3">
          <p class="text-2xl md:text-3xl font-medium leading-snug text-ink mb-8" style="font-family: var(--font-display)">
            I'm a developer based in Gainesville, building modern websites for local businesses who deserve better than a free template.
          </p>
          <div class="space-y-4 text-ink-muted leading-relaxed">
            <p>Most small businesses don't need a 6-figure agency. They need a working website, fair pricing, and someone who picks up the phone. That's what I do.</p>
            <p>Every site I build is custom, fast, and easy to update. No fluff, no jargon, no surprise invoices.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="px-6 py-24 bg-forest">
    <div class="max-w-2xl mx-auto">
      <div class="reveal mb-12 text-center">
        <p class="text-xs font-medium text-forest-dark/0 uppercase tracking-[0.2em] mb-3" style="color: rgba(255,255,255,0.4)">Get In Touch</p>
        <h2 class="text-4xl md:text-5xl font-semibold text-cream" style="font-family: var(--font-display)">
          Let's talk.
        </h2>
        <p class="mt-3 text-sm leading-relaxed" style="color: rgba(255,255,255,0.8)">
          Tell me about your business. I'll get back to you within 24 hours.
        </p>
      </div>

