---
import PerchLayout from "../../../layouts/PerchLayout.astro";

const posts = [
  { title: "Our summer cold brew is finally here", date: "May 2", category: "Menu", slug: "/demos/plus/blog" },
  { title: "The story behind our Ethiopian single-origin", date: "Apr 18", category: "Coffee", slug: "/demos/plus/blog" },
  { title: "Perch x Cade Museum: Art & Coffee Night", date: "Apr 5", category: "Events", slug: "/demos/plus/blog" },
];

const events = [
  { num: "01", title: "Latte Art Workshop", date: "May 17", time: "10am–12pm", spots: "6 spots left" },
  { num: "02", title: "Pour-Over Brewing Basics", date: "May 24", time: "11am–1pm", spots: "4 spots left" },
  { num: "03", title: "Coffee & Vinyl Morning", date: "June 1", time: "9am–11am", spots: "Open" },
];
---

<PerchLayout>
  <!-- Hero -->
  <section style="background: var(--p-bg-dark); border-bottom: 1px solid var(--p-border); min-height: 92vh;" class="flex flex-col items-center justify-center px-6 py-24 text-center relative overflow-hidden">
    <!-- Big background text -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none overflow-hidden">
      <span style="font-family: var(--font-serif); font-size: clamp(8rem, 20vw, 18rem); font-weight: 700; color: rgba(255,255,255,0.02); line-height: 1; white-space: nowrap;">COFFEE</span>
    </div>

    <div class="relative z-10">
      <p class="reveal text-xs uppercase tracking-[0.35em] mb-8" style="color: var(--p-gold);">Est. 2019 · Gainesville, GA</p>

      <h1 class="reveal reveal-delay-1" style="font-family: var(--font-serif); font-size: clamp(3.5rem, 10vw, 8rem); font-weight: 700; line-height: 0.9; letter-spacing: -0.02em; color: var(--p-brown);">
        The<br/><em style="color: var(--p-gold);">Perch</em>
      </h1>

      <div class="reveal reveal-delay-2 flex items-center justify-center gap-4 my-8">
        <div style="height: 1px; width: 60px; background: var(--p-border);"></div>
        <p class="text-xs uppercase tracking-[0.25em]" style="color: var(--p-muted);">Specialty Coffee · Community · Good Company</p>
        <div style="height: 1px; width: 60px; background: var(--p-border);"></div>
      </div>

      <div class="reveal reveal-delay-3 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/demos/plus/menu" style="background: var(--p-gold); color: var(--p-bg-dark); font-size: 0.75rem; letter-spacing: 0.15em; font-weight: 600;" class="px-8 py-3.5 uppercase hover:opacity-90 transition-opacity">
          See the Menu
        </a>
        <a href="#visit" style="border: 1px solid var(--p-border); color: var(--p-muted); font-size: 0.75rem; letter-spacing: 0.15em;" class="px-8 py-3.5 uppercase hover:border-current hover:text-current transition-colors" style="color: var(--p-brown)">
          Find Us
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2" style="color: var(--p-muted)">
      <span class="text-xs uppercase tracking-[0.2em]">Scroll</span>
      <div style="width: 1px; height: 40px; background: var(--p-border);"></div>
    </div>
  </section>

  <!-- 01 — What's Good -->
  <section style="background: var(--p-bg); border-bottom: 1px solid var(--p-border);" class="px-6 py-20">
    <div class="max-w-7xl mx-auto">
      <div class="reveal flex items-baseline gap-4 mb-12 pb-4" style="border-bottom: 1px solid var(--p-border);">
        <span class="text-xs uppercase tracking-[0.25em]" style="color: var(--p-gold);">01</span>
        <h2 class="text-xs uppercase tracking-[0.25em]" style="color: var(--p-muted);">What's Good</h2>
        <div class="flex-1"></div>
        <a href="/demos/plus/menu" class="text-xs uppercase tracking-[0.2em]" style="color: var(--p-gold);">Full Menu →</a>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-px" style="background: var(--p-border);">
        {[
          { name: "Oat Honey Latte", price: "$6.50", note: "Espresso, oat milk, raw honey, sea salt" },
          { name: "Cold Brew Tonic", price: "$5.75", note: "Nitro cold brew over sparkling tonic" },
          { name: "Ethiopian Pour-Over", price: "$5.50", note: "Washed Yirgacheffe · bright & floral" },
          { name: "Lavender Matcha", price: "$6.25", note: "Ceremonial matcha, lavender, oat milk" },
        ].map((drink, i) => (
          <div class={`reveal reveal-delay-${i % 3} p-6 flex flex-col justify-between`} style={`background: var(--p-bg); min-height: 160px;`}>
            <div>
              <p class="font-bold leading-tight mb-2" style="font-family: var(--font-serif); color: var(--p-brown);">{drink.name}</p>
              <p class="text-xs leading-relaxed" style="color: var(--p-muted);">{drink.note}</p>
            </div>
            <p class="text-sm font-semibold mt-4" style="color: var(--p-gold);">{drink.price}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 02 — From the Blog -->
  <section style="background: var(--p-bg-alt); border-bottom: 1px solid var(--p-border);" class="px-6 py-20">
    <div class="max-w-7xl mx-auto">
      <div class="reveal flex items-baseline gap-4 mb-12 pb-4" style="border-bottom: 1px solid var(--p-border);">
        <span class="text-xs uppercase tracking-[0.25em]" style="color: var(--p-gold);">02</span>
        <h2 class="text-xs uppercase tracking-[0.25em]" style="color: var(--p-muted);">From the Blog</h2>
        <div class="flex-1"></div>
        <a href="/demos/plus/blog" class="text-xs uppercase tracking-[0.2em]" style="color: var(--p-gold);">All Posts →</a>
      </div>

      <div class="grid md:grid-cols-3 gap-px" style="background: var(--p-border);">
        {posts.map((post, i) => (
          <a href={post.slug} class={`reveal reveal-delay-${i} block p-6 group`} style="background: var(--p-bg-alt); text-decoration: none;">
            <p class="text-xs uppercase tracking-[0.2em] mb-4" style="color: var(--p-gold);">{post.category} — {post.date}</p>
            <h3 class="font-semibold leading-snug group-hover:opacity-70 transition-opacity" style="font-family: var(--font-serif); font-size: 1.2rem; color: var(--p-brown);">{post.title}</h3>
            <p class="text-xs uppercase tracking-[0.15em] mt-4" style="color: var(--p-muted);">Read →</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 03 — Events -->
  <section id="events" style="background: var(--p-bg); border-bottom: 1px solid var(--p-border);" class="px-6 py-20">
    <div class="max-w-7xl mx-auto">
      <div class="reveal flex items-baseline gap-4 mb-12 pb-4" style="border-bottom: 1px solid var(--p-border);">
        <span class="text-xs uppercase tracking-[0.25em]" style="color: var(--p-gold);">03</span>
        <h2 class="text-xs uppercase tracking-[0.25em]" style="color: var(--p-muted);">Upcoming Events</h2>
      </div>

      <div class="space-y-px" style="border: 1px solid var(--p-border);">
        {events.map((ev, i) => (
          <div class={`reveal reveal-delay-${i} flex items-center justify-between px-6 py-5 group`} style={`background: var(--p-bg); ${i < events.length - 1 ? `border-bottom: 1px solid var(--p-border);` : ''}`}>
            <div class="flex items-center gap-8">
              <span class="text-xs tabular-nums" style="color: var(--p-gold);">{ev.num}</span>
              <div>
                <p class="font-semibold" style="font-family: var(--font-serif); color: var(--p-brown);">{ev.title}</p>
                <p class="text-xs mt-0.5" style="color: var(--p-muted);">{ev.date} · {ev.time}</p>
              </div>
            </div>
            <div class="flex items-center gap-6">
              <span class="text-xs" style="color: var(--p-green);">{ev.spots}</span>
              <a href="#" style="border: 1px solid var(--p-border); color: var(--p-muted); font-size: 0.7rem; letter-spacing: 0.12em;" class="px-4 py-1.5 uppercase hover:border-current transition-colors whitespace-nowrap">
                Register
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 04 — Our Story -->
  <section id="about" style="background: var(--p-bg-alt);" class="px-6 py-24">
    <div class="max-w-7xl mx-auto">
      <div class="reveal flex items-baseline gap-4 mb-16 pb-4" style="border-bottom: 1px solid var(--p-border);">
        <span class="text-xs uppercase tracking-[0.25em]" style="color: var(--p-gold);">04</span>
        <h2 class="text-xs uppercase tracking-[0.25em]" style="color: var(--p-muted);">Our Story</h2>
      </div>

      <div class="md:grid md:grid-cols-2 gap-20 items-start">
        <div class="reveal">
          <blockquote style="font-family: var(--font-serif); font-size: clamp(1.75rem, 3vw, 2.5rem); font-style: italic; line-height: 1.3; color: var(--p-brown);">
            "A place to slow down, sip something good, and remember what offline feels like."
          </blockquote>
        </div>
        <div class="reveal reveal-delay-1 space-y-4 text-sm leading-relaxed mt-8 md:mt-0" style="color: var(--p-muted);">
          <p>The Perch opened in 2019 in a renovated bungalow off 13th Street. We work with small farms to source single-origin beans roasted fresh every week.</p>
          <p>Our baristas take coffee seriously — but not so seriously that we forget it's supposed to be fun. Come as you are, stay as long as you need.</p>
          <p>We're also proud to host events, workshops, and collaborations with local artists and makers throughout the year.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Visit -->
  <section id="visit" style="background: var(--p-bg-dark); border-top: 1px solid var(--p-border);" class="px-6 py-20">
    <div class="max-w-7xl mx-auto">
      <div class="reveal flex items-baseline gap-4 mb-12 pb-4" style="border-bottom: 1px solid var(--p-border);">
        <span class="text-xs uppercase tracking-[0.25em]" style="color: var(--p-gold);">05</span>
        <h2 class="text-xs uppercase tracking-[0.25em]" style="color: var(--p-muted);">Visit Us</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-12">
        <div class="reveal space-y-6 text-sm" style="color: var(--p-muted);">
          {[
            { label: "Address", value: "412 Bradford St NE\nGainesville, GA 30501" },
            { label: "Hours", value: "Mon–Fri: 7am–7pm\nSat–Sun: 8am–6pm" },
            { label: "Phone", value: "(762) 555-0148" },
          ].map((item) => (
            <div style="border-bottom: 1px solid var(--p-border); padding-bottom: 1rem;">
              <p class="text-xs uppercase tracking-[0.2em] mb-2" style="color: var(--p-gold);">{item.label}</p>
              <p class="whitespace-pre-line" style="color: var(--p-brown);">{item.value}</p>
            </div>
          ))}
        </div>

        <div class="reveal reveal-delay-1 flex items-center justify-center" style="background: var(--p-bg); border: 1px solid var(--p-border); min-height: 220px;">
          <div class="text-center" style="color: var(--p-muted);">
            <p class="text-xs uppercase tracking-[0.2em]">Google Maps</p>
            <p class="text-xs mt-1">412 Bradford St NE</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</PerchLayout>
