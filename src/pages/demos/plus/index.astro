---
import PerchLayout from "../../../layouts/PerchLayout.astro";

const posts = [
  { title: "Our new cold brew is here for summer", date: "May 2, 2026", category: "Menu News", slug: "/demos/plus/blog" },
  { title: "The story behind our single-origin Ethiopian", date: "Apr 18, 2026", category: "Coffee Education", slug: "/demos/plus/blog" },
  { title: "Perch x Cade Museum: Art & Coffee Night", date: "Apr 5, 2026", category: "Events", slug: "/demos/plus/blog" },
];

const events = [
  { title: "Latte Art Workshop", date: "May 17", time: "10am–12pm", spots: "6 spots left" },
  { title: "Pour-Over Brewing Basics", date: "May 24", time: "11am–1pm", spots: "4 spots left" },
  { title: "Coffee & Vinyl Morning", date: "June 1", time: "9am–11am", spots: "Open" },
];
---

<PerchLayout>
  <!-- Hero -->
  <section style="background: var(--p-bg); border-bottom: 1px solid var(--p-border);" class="px-6 py-24 md:py-36">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="reveal text-xs font-medium uppercase tracking-[0.2em] mb-4" style="color: var(--p-green)">Gainesville's Corner Coffee</p>
        <h1 class="reveal reveal-delay-1 leading-tight mb-6" style="font-family: var(--font-serif); font-size: clamp(2.5rem, 5vw, 4rem); color: var(--p-brown);">
          A place to slow<br/><em>down and sip.</em>
        </h1>
        <p class="reveal reveal-delay-2 leading-relaxed mb-8" style="color: var(--p-muted); max-width: 440px;">
          Specialty coffee, seasonal drinks, and good company — right here on 13th Street. Single-origin beans, brewed with care.
        </p>
        <div class="reveal reveal-delay-3 flex flex-wrap gap-4">
          <a href="/demos/plus/menu"
            style="background: var(--p-brown); color: #FAF7F2;"
            class="px-7 py-3.5 text-sm font-medium hover:opacity-90 transition-opacity">
            See the Menu
          </a>
          <a href="#visit"
            style="border: 1px solid var(--p-border); color: var(--p-muted);"
            class="px-7 py-3.5 text-sm font-medium hover:border-current hover:text-current transition-colors" style="color: var(--p-brown)">
            Find Us
          </a>
        </div>
      </div>
      <div class="reveal reveal-delay-2 hidden md:block">
        <div style="background: var(--p-bg-alt); border: 1px solid var(--p-border); aspect-ratio: 4/3;" class="flex items-center justify-center rounded-sm">
          <div class="text-center" style="color: var(--p-muted);">
            <div style="font-family: var(--font-serif); font-size: 5rem; line-height: 1; color: var(--p-border);">☕</div>
            <p class="text-xs mt-2 uppercase tracking-widest">Photo Goes Here</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured drinks -->
  <section style="background: var(--p-bg-alt); border-bottom: 1px solid var(--p-border);" class="px-6 py-20">
    <div class="max-w-6xl mx-auto">
      <div class="reveal flex items-end justify-between mb-10">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] mb-2" style="color: var(--p-green)">What's Good</p>
          <h2 class="text-3xl font-semibold" style="font-family: var(--font-serif); color: var(--p-brown);">Staff picks this week</h2>
        </div>
        <a href="/demos/plus/menu" class="text-sm hidden md:inline" style="color: var(--p-gold);">Full menu →</a>
      </div>
      <div class="grid md:grid-cols-4 gap-4">
        {[
          { name: "Oat Honey Latte", price: "$6.50", note: "Espresso, oat milk, raw honey, sea salt" },
          { name: "Cold Brew Tonic", price: "$5.75", note: "Nitro cold brew over sparkling tonic" },
          { name: "Ethiopian Pour-Over", price: "$5.50", note: "Washed Yirgacheffe, bright & floral" },
          { name: "Lavender Matcha", price: "$6.25", note: "Ceremonial matcha, lavender, oat milk" },
        ].map((drink, i) => (
          <div class={`reveal reveal-delay-${i % 3}`} style="background: var(--p-bg); border: 1px solid var(--p-border); padding: 1.5rem;">
            <p class="font-semibold text-sm mb-1" style="color: var(--p-brown); font-family: var(--font-serif);">{drink.name}</p>
            <p class="text-xs leading-relaxed mb-3" style="color: var(--p-muted);">{drink.note}</p>
            <p class="text-sm font-medium" style="color: var(--p-gold);">{drink.price}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog / CMS section -->
  <section style="background: var(--p-bg); border-bottom: 1px solid var(--p-border);" class="px-6 py-20">
    <div class="max-w-6xl mx-auto">
      <div class="reveal flex items-end justify-between mb-10">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] mb-2" style="color: var(--p-green)">From the Blog</p>
          <h2 class="text-3xl font-semibold" style="font-family: var(--font-serif); color: var(--p-brown);">Latest from The Perch</h2>
        </div>
        <a href="/demos/plus/blog" class="text-sm hidden md:inline" style="color: var(--p-gold);">All posts →</a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {posts.map((post, i) => (
          <a href={post.slug} class={`reveal reveal-delay-${i} block group`} style="border: 1px solid var(--p-border); padding: 1.5rem; background: var(--p-bg-alt); text-decoration: none; transition: border-color 0.2s;" onmouseover="this.style.borderColor='var(--p-brown)'" onmouseout="this.style.borderColor='var(--p-border)'">
            <p class="text-xs uppercase tracking-wider mb-3" style="color: var(--p-green);">{post.category}</p>
            <h3 class="font-semibold mb-3 leading-snug" style="font-family: var(--font-serif); color: var(--p-brown);">{post.title}</h3>
            <p class="text-xs" style="color: var(--p-muted);">{post.date}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Events -->
  <section id="events" style="background: var(--p-bg-alt); border-bottom: 1px solid var(--p-border);" class="px-6 py-20">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-10">
        <p class="text-xs uppercase tracking-[0.2em] mb-2" style="color: var(--p-green)">Upcoming</p>
        <h2 class="text-3xl font-semibold" style="font-family: var(--font-serif); color: var(--p-brown);">Events at The Perch</h2>
      </div>
      <div class="space-y-px" style="border: 1px solid var(--p-border);">
        {events.map((ev, i) => (
          <div class={`reveal reveal-delay-${i} flex items-center justify-between px-6 py-5`} style="background: var(--p-bg); border-bottom: 1px solid var(--p-border);">
            <div class="flex items-center gap-6">
              <div class="text-center min-w-[48px]">
                <p class="text-2xl font-bold leading-none" style="font-family: var(--font-serif); color: var(--p-brown);">{ev.date.split(' ')[1]}</p>
                <p class="text-xs uppercase tracking-wide mt-0.5" style="color: var(--p-muted);">{ev.date.split(' ')[0]}</p>
              </div>
              <div>
                <p class="font-semibold text-sm" style="color: var(--p-brown);">{ev.title}</p>
                <p class="text-xs mt-0.5" style="color: var(--p-muted);">{ev.time}</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <span class="text-xs" style="color: var(--p-green);">{ev.spots}</span>
              <a href="#" style="border: 1px solid var(--p-border); color: var(--p-muted); font-size: 0.75rem;" class="px-4 py-1.5 font-medium hover:border-current transition-colors whitespace-nowrap">
                Register
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" style="background: var(--p-bg);" class="px-6 py-20">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
      <div class="reveal">
        <div style="background: var(--p-bg-alt); border: 1px solid var(--p-border); aspect-ratio: 1; max-width: 420px;" class="flex items-center justify-center">
          <div class="text-center" style="color: var(--p-border);">
            <div style="font-size: 6rem; line-height: 1;">🌿</div>
            <p class="text-xs mt-2 uppercase tracking-widest" style="color: var(--p-muted);">Interior Photo</p>
          </div>
        </div>
      </div>
      <div class="reveal reveal-delay-1">
        <p class="text-xs uppercase tracking-[0.2em] mb-4" style="color: var(--p-green)">Our Story</p>
        <h2 class="text-3xl font-semibold mb-6 leading-tight" style="font-family: var(--font-serif); color: var(--p-brown);">
          A neighborhood spot that cares about the cup.
        </h2>
        <div class="space-y-4 text-sm leading-relaxed" style="color: var(--p-muted);">
          <p>The Perch opened in 2019 in a renovated bungalow off 13th Street. We work with small farms to source single-origin beans and roast them fresh every week.</p>
          <p>Our baristas take coffee seriously — but not so seriously that we forget it's supposed to be fun. Come as you are, stay as long as you need.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Visit / Google Maps placeholder -->
  <section id="visit" style="background: var(--p-bg-alt); border-top: 1px solid var(--p-border);" class="px-6 py-20">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-10">
        <p class="text-xs uppercase tracking-[0.2em] mb-2" style="color: var(--p-green)">Come See Us</p>
        <h2 class="text-3xl font-semibold" style="font-family: var(--font-serif); color: var(--p-brown);">Find The Perch</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="reveal" style="border: 1px solid var(--p-border); background: var(--p-bg-alt); height: 320px; display: flex; align-items: center; justify-content: center;">
          <!-- Real implementation: Google Maps embed iframe here -->
          <div class="text-center" style="color: var(--p-muted);">
            <svg class="w-10 h-10 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--p-border);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <p class="text-sm">Google Maps Embed</p>
            <p class="text-xs mt-1">412 NW 13th St, Gainesville</p>
          </div>
        </div>
        <div class="reveal reveal-delay-1 flex flex-col justify-center space-y-5">
          {[
            { label: "Address", value: "412 NW 13th St\nGainesville, FL 32601" },
            { label: "Hours", value: "Mon–Fri: 7am–7pm\nSat–Sun: 8am–6pm" },
            { label: "Phone", value: "(352) 555-0148" },
            { label: "Parking", value: "Free lot behind the building\n+ street parking on 13th St" },
          ].map((item) => (
            <div style="border-bottom: 1px solid var(--p-border); padding-bottom: 1rem;">
              <p class="text-xs uppercase tracking-[0.15em] mb-1" style="color: var(--p-muted);">{item.label}</p>
              <p class="text-sm whitespace-pre-line" style="color: var(--p-brown);">{item.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</PerchLayout>
