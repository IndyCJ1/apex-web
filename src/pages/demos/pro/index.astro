---
import SoleLayout from "../../../layouts/SoleLayout.astro";

const services = [
  { name: "Swedish Massage", duration: "60 or 90 min", price: "from $95", note: "Full-body relaxation, tension relief" },
  { name: "Deep Tissue Massage", duration: "60 or 90 min", price: "from $110", note: "Targets chronic muscle tension" },
  { name: "Signature Facial", duration: "60 min", price: "$115", note: "Custom to your skin type, deep cleanse + mask" },
  { name: "Hot Stone Therapy", duration: "90 min", price: "$140", note: "Heated basalt stones, full body" },
  { name: "Prenatal Massage", duration: "60 min", price: "$105", note: "Safe, comfortable support for expecting mothers" },
  { name: "Couples Retreat", duration: "90 min", price: "$240", note: "Side-by-side massage for two" },
];

const products = [
  { name: "Recovery Body Oil", price: "$42", category: "Body" },
  { name: "Lavender Sleep Balm", price: "$28", category: "Sleep" },
  { name: "Exfoliating Sugar Scrub", price: "$34", category: "Body" },
  { name: "Hydrating Face Serum", price: "$68", category: "Skin" },
];

const testimonials = [
  { name: "Rachel M.", text: "Best massage I've had in Gainesville. The therapist actually listened to where I carry tension. Already booked my next appointment.", stars: 5 },
  { name: "James T.", text: "I've been coming to Solé for two years. Consistent, professional, and the booking system makes it so easy to get on the schedule.", stars: 5 },
  { name: "Priya K.", text: "The signature facial completely transformed my skin. Worth every penny. The studio itself is beautiful and so calming.", stars: 5 },
];
---

<SoleLayout>
  <!-- Hero -->
  <section style="background: var(--s-bg); border-bottom: 1px solid var(--s-border);" class="px-6 py-24 md:py-36">
    <div class="max-w-6xl mx-auto grid md:grid-cols-5 gap-12 items-center">
      <div class="md:col-span-3">
        <p class="reveal text-xs font-medium uppercase tracking-[0.25em] mb-5" style="color: var(--s-sage)">Gainesville Wellness Studio</p>
        <h1 class="reveal reveal-delay-1 leading-tight mb-6" style="font-family: var(--font-serif); font-size: clamp(2.75rem, 5vw, 4.5rem); color: var(--s-ink);">
          Your body knows<br/>when it needs<br/><em style="color: var(--s-sage)">to rest.</em>
        </h1>
        <p class="reveal reveal-delay-2 text-sm leading-relaxed mb-10" style="color: var(--s-muted); max-width: 400px;">
          Therapeutic massage and skincare in a calm, unhurried space. Licensed therapists. Easy online booking.
        </p>
        <div class="reveal reveal-delay-3 flex flex-wrap gap-4">
          <a href="/demos/pro/book"
            style="background: var(--s-sage); color: #fff; letter-spacing: 0.08em;"
            class="px-8 py-4 text-xs font-medium uppercase tracking-wider hover:opacity-90 transition-opacity">
            Book an Appointment
          </a>
          <a href="/demos/pro/services"
            style="border: 1px solid var(--s-border); color: var(--s-muted);"
            class="px-8 py-4 text-xs font-medium uppercase tracking-wider hover:border-current transition-colors" style="color: var(--s-ink)">
            View Services
          </a>
        </div>
      </div>
      <div class="md:col-span-2 reveal reveal-delay-2 hidden md:block">
        <div style="background: var(--s-bg-alt); border: 1px solid var(--s-border); aspect-ratio: 3/4; display: flex; align-items: center; justify-content: center;">
          <div class="text-center" style="color: var(--s-border);">
            <svg class="w-12 h-12 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
            <p class="text-xs uppercase tracking-widest" style="color: var(--s-muted);">Studio Photo</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services overview -->
  <section style="background: var(--s-bg-alt); border-bottom: 1px solid var(--s-border);" class="px-6 py-20">
    <div class="max-w-6xl mx-auto">
      <div class="reveal flex items-end justify-between mb-10">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] mb-2" style="color: var(--s-sage)">What We Offer</p>
          <h2 class="text-3xl font-semibold" style="font-family: var(--font-serif); color: var(--s-ink);">Our Services</h2>
        </div>
        <a href="/demos/pro/services" class="text-xs uppercase tracking-wider hidden md:inline" style="color: var(--s-sage);">All services →</a>
      </div>
      <div class="grid md:grid-cols-3 gap-4">
        {services.map((svc, i) => (
          <div class={`reveal reveal-delay-${i % 3}`} style="background: var(--s-bg); border: 1px solid var(--s-border); padding: 1.5rem;">
            <h3 class="font-semibold mb-1" style="font-family: var(--font-serif); color: var(--s-ink);">{svc.name}</h3>
            <p class="text-xs mb-3" style="color: var(--s-muted);">{svc.duration} · {svc.note}</p>
            <div class="flex items-center justify-between">
              <span class="text-sm font-medium" style="color: var(--s-gold);">{svc.price}</span>
              <a href="/demos/pro/book"
                style="background: var(--s-sage); color: #fff; font-size: 0.7rem; letter-spacing: 0.08em;"
                class="px-3 py-1.5 uppercase tracking-wider hover:opacity-90 transition-opacity">
                Book
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Booking CTA banner -->
  <section style="background: var(--s-sage);" class="px-6 py-14">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="reveal text-center md:text-left">
        <h2 class="text-2xl font-semibold text-white mb-2" style="font-family: var(--font-serif);">
          <em>Ready to book?</em>
        </h2>
        <p class="text-sm" style="color: rgba(255,255,255,0.75);">Choose your service, pick a time, and you're set. No phone tag, no waiting.</p>
      </div>
      <div class="reveal flex-shrink-0">
        <a href="/demos/pro/book"
          style="background: white; color: var(--s-sage-dark); letter-spacing: 0.08em;"
          class="inline-flex px-8 py-4 text-xs font-semibold uppercase tracking-wider hover:bg-opacity-90 transition-opacity">
          Book Online Now
        </a>
      </div>
    </div>
  </section>

  <!-- Shop preview -->
  <section id="shop" style="background: var(--s-bg); border-bottom: 1px solid var(--s-border);" class="px-6 py-20">
    <div class="max-w-6xl mx-auto">
      <div class="reveal flex items-end justify-between mb-10">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] mb-2" style="color: var(--s-sage)">Take It Home</p>
          <h2 class="text-3xl font-semibold" style="font-family: var(--font-serif); color: var(--s-ink);">The Shop</h2>
        </div>
        <a href="#shop" class="text-xs uppercase tracking-wider hidden md:inline" style="color: var(--s-sage);">View all →</a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {products.map((product, i) => (
          <div class={`reveal reveal-delay-${i % 3}`}>
            <div style="background: var(--s-bg-alt); border: 1px solid var(--s-border); aspect-ratio: 1; display: flex; align-items: center; justify-content: center; margin-bottom: 0.75rem;">
              <p class="text-xs uppercase tracking-widest" style="color: var(--s-border);">{product.category}</p>
            </div>
            <p class="text-sm font-medium mb-0.5" style="color: var(--s-ink);">{product.name}</p>
            <div class="flex items-center justify-between">
              <span class="text-sm" style="color: var(--s-gold);">{product.price}</span>
              <button style="border: 1px solid var(--s-border); color: var(--s-muted); font-size: 0.7rem;" class="px-3 py-1 hover:border-current transition-colors">
                Add to Cart
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section style="background: var(--s-bg-alt); border-bottom: 1px solid var(--s-border);" class="px-6 py-20">
    <div class="max-w-6xl mx-auto">
      <div class="reveal text-center mb-12">
        <p class="text-xs uppercase tracking-[0.2em] mb-2" style="color: var(--s-sage)">Reviews</p>
        <h2 class="text-3xl font-semibold" style="font-family: var(--font-serif); color: var(--s-ink);">What clients say</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {testimonials.map((t, i) => (
          <div class={`reveal reveal-delay-${i} p-6`} style="background: var(--s-bg); border: 1px solid var(--s-border);">
            <div class="flex gap-0.5 mb-4">
              {Array(t.stars).fill(null).map(() => (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" style="color: var(--s-gold);">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-sm leading-relaxed mb-4" style="color: var(--s-muted);">"{t.text}"</p>
            <p class="text-xs font-medium" style="color: var(--s-ink);">{t.name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" style="background: var(--s-bg);" class="px-6 py-20">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12">
      <div class="reveal">
        <p class="text-xs uppercase tracking-[0.2em] mb-3" style="color: var(--s-sage)">Visit Us</p>
        <h2 class="text-3xl font-semibold mb-6" style="font-family: var(--font-serif); color: var(--s-ink);">Find Solé</h2>
        <div style="background: var(--s-bg-alt); border: 1px solid var(--s-border); height: 260px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem;">
          <div class="text-center" style="color: var(--s-border);">
            <svg class="w-8 h-8 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <p class="text-xs uppercase tracking-widest" style="color: var(--s-muted);">Google Maps Embed</p>
          </div>
        </div>
        <div class="space-y-3 text-sm" style="color: var(--s-muted);">
          <p><strong style="color: var(--s-ink);">1804 NW 2nd Ave, Gainesville, FL 32603</strong></p>
          <p>Tue–Fri: 9am–7pm · Sat: 9am–5pm · Closed Sun–Mon</p>
          <p>(352) 555-0192 · hello@solewellness.com</p>
        </div>
      </div>
      <div class="reveal reveal-delay-1">
        <p class="text-xs uppercase tracking-[0.2em] mb-3" style="color: var(--s-sage)">Get in Touch</p>
        <h2 class="text-3xl font-semibold mb-6" style="font-family: var(--font-serif); color: var(--s-ink);">Send a message</h2>
        <form class="space-y-4">
          <div>
            <label class="block text-xs uppercase tracking-[0.12em] mb-1.5" style="color: var(--s-muted);">Name</label>
            <input type="text" placeholder="Your name" style="width: 100%; background: var(--s-bg-alt); border: 1px solid var(--s-border); color: var(--s-ink); padding: 0.75rem 1rem; font-size: 0.875rem; outline: none;" />
          </div>
          <div>
            <label class="block text-xs uppercase tracking-[0.12em] mb-1.5" style="color: var(--s-muted);">Email</label>
            <input type="email" placeholder="your@email.com" style="width: 100%; background: var(--s-bg-alt); border: 1px solid var(--s-border); color: var(--s-ink); padding: 0.75rem 1rem; font-size: 0.875rem; outline: none;" />
          </div>
          <div>
            <label class="block text-xs uppercase tracking-[0.12em] mb-1.5" style="color: var(--s-muted);">Message</label>
            <textarea rows="4" placeholder="How can we help?" style="width: 100%; background: var(--s-bg-alt); border: 1px solid var(--s-border); color: var(--s-ink); padding: 0.75rem 1rem; font-size: 0.875rem; outline: none; resize: none;"></textarea>
          </div>
          <button type="submit" style="width: 100%; background: var(--s-sage); color: white; padding: 1rem; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; border: none; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>
</SoleLayout>
