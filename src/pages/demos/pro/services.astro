---
import SoleLayout from "../../../layouts/SoleLayout.astro";

const categories = [
  {
    name: "Massage Therapy",
    services: [
      { name: "Swedish Massage", duration: "60 min / 90 min", price: "$95 / $130", description: "Classic relaxation massage using long, flowing strokes to ease tension and improve circulation. Perfect for first-timers or those needing full-body stress relief." },
      { name: "Deep Tissue Massage", duration: "60 min / 90 min", price: "$110 / $145", description: "Targets the deeper layers of muscle and connective tissue. Ideal for chronic pain, knots, and athletes recovering from training." },
      { name: "Hot Stone Therapy", duration: "90 min", price: "$140", description: "Smooth, heated basalt stones are placed on key points and used as an extension of the therapist's hands. Deeply warming and relaxing." },
      { name: "Prenatal Massage", duration: "60 min", price: "$105", description: "Specially adapted for expecting mothers. Side-lying positioning with supportive pillows. Safe from the second trimester onward." },
      { name: "Couples Retreat", duration: "90 min", price: "$240 for two", description: "Side-by-side massages in our couples suite. Swedish or deep tissue, your choice. Champagne and fruit available on request." },
    ],
  },
  {
    name: "Facial Treatments",
    services: [
      { name: "Signature Facial", duration: "60 min", price: "$115", description: "Our most popular treatment. Custom to your skin type — includes deep cleanse, exfoliation, extractions, mask, and massage." },
      { name: "Brightening Vitamin C Facial", duration: "60 min", price: "$125", description: "Targets dullness and uneven tone using a professional-grade Vitamin C serum. Leaves skin visibly radiant." },
      { name: "Hydrating Moisture Facial", duration: "60 min", price: "$115", description: "For dry or dehydrated skin. Hyaluronic acid, barrier repair, and a nourishing mask restore suppleness." },
      { name: "Acne-Clarifying Facial", duration: "75 min", price: "$130", description: "Salicylic acid exfoliation, deep extractions, and a calming mask. Safe for most acne-prone skin types." },
    ],
  },
  {
    name: "Add-On Enhancements",
    services: [
      { name: "CBD Muscle Relief Add-On", duration: "15 min", price: "+$25", description: "Topical CBD oil applied to areas of tension. Anti-inflammatory, fast-absorbing." },
      { name: "Scalp Massage", duration: "15 min", price: "+$20", description: "Tension-releasing scalp and neck work added to any massage." },
      { name: "Foot & Reflexology", duration: "15 min", price: "+$20", description: "Warm towel wrap and targeted pressure point work on the feet." },
      { name: "Eye Contour Treatment", duration: "15 min", price: "+$25", description: "Depuffing, brightening eye treatment added to any facial." },
    ],
  },
];
---

<SoleLayout title="Services — Solé Wellness Studio" page="Services">
  <!-- Header -->
  <section style="background: var(--s-bg); border-bottom: 1px solid var(--s-border);" class="px-6 py-16">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.2em] mb-3" style="color: var(--s-sage)">What We Offer</p>
        <h1 class="text-4xl md:text-5xl font-semibold" style="font-family: var(--font-serif); color: var(--s-ink);">Our Services</h1>
        <p class="mt-3 text-sm max-w-md" style="color: var(--s-muted);">All treatments performed by licensed therapists. New to Solé? Start with a Swedish massage or Signature Facial.</p>
      </div>
      <a href="/demos/pro/book"
        style="background: var(--s-sage); color: #fff; font-size: 0.75rem; letter-spacing: 0.1em; flex-shrink: 0;"
        class="inline-flex px-7 py-4 font-medium uppercase tracking-wider hover:opacity-90 transition-opacity self-start md:self-auto">
        Book Online
      </a>
    </div>
  </section>

  <!-- Service categories -->
  <section style="background: var(--s-bg-alt);" class="px-6 py-16">
    <div class="max-w-5xl mx-auto space-y-16">
      {categories.map((cat, ci) => (
        <div class="reveal">
          <h2 class="text-2xl font-semibold mb-6 pb-4" style={`font-family: var(--font-serif); color: var(--s-ink); border-bottom: 1px solid var(--s-border);`}>
            {cat.name}
          </h2>
          <div class="space-y-px" style="border: 1px solid var(--s-border);">
            {cat.services.map((svc, si) => (
              <div class="px-6 py-5 flex flex-col md:flex-row md:items-start justify-between gap-4" style={`background: var(--s-bg); ${si < cat.services.length - 1 ? 'border-bottom: 1px solid var(--s-border);' : ''}`}>
                <div class="flex-1">
                  <div class="flex items-baseline gap-3 mb-1.5">
                    <h3 class="font-semibold" style="font-family: var(--font-serif); color: var(--s-ink);">{svc.name}</h3>
                    <span class="text-xs" style="color: var(--s-muted);">{svc.duration}</span>
                  </div>
                  <p class="text-sm leading-relaxed" style="color: var(--s-muted); max-width: 560px;">{svc.description}</p>
                </div>
                <div class="flex items-center gap-4 flex-shrink-0">
                  <span class="text-sm font-medium" style="color: var(--s-gold);">{svc.price}</span>
                  <a href="/demos/pro/book"
                    style="background: var(--s-sage); color: #fff; font-size: 0.7rem; letter-spacing: 0.08em;"
                    class="px-4 py-2 uppercase tracking-wider hover:opacity-90 transition-opacity whitespace-nowrap">
                    Book
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Booking CTA -->
  <section style="background: var(--s-bg-dark);" class="px-6 py-16">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="reveal text-3xl font-semibold text-white mb-3" style="font-family: var(--font-serif);">
        <em>Ready when you are.</em>
      </h2>
      <p class="reveal text-sm mb-8" style="color: rgba(255,255,255,0.45);">Pick your service and find a time that works. Online booking is open 24/7.</p>
      <a href="/demos/pro/book"
        style="background: var(--s-sage); color: #fff; font-size: 0.75rem; letter-spacing: 0.1em;"
        class="reveal inline-flex px-10 py-4 font-medium uppercase tracking-wider hover:opacity-90 transition-opacity">
        Book an Appointment
      </a>
    </div>
  </section>
</SoleLayout>
