---
import SoleLayout from "../../../layouts/SoleLayout.astro";

const categories = [
  {
    name: "Massage Therapy",
    img: "https://images.unsplash.com/photo-1600334129128-685c5582fd35?w=1200&q=80",
    services: [
      { name: "Swedish Massage", duration: "60 / 90 min", price: "$95 / $130", description: "Classic relaxation massage using long, flowing strokes to ease tension and improve circulation." },
      { name: "Deep Tissue Massage", duration: "60 / 90 min", price: "$110 / $145", description: "Targets the deeper layers of muscle and connective tissue. Ideal for chronic pain and athletes." },
      { name: "Hot Stone Therapy", duration: "90 min", price: "$140", description: "Heated basalt stones placed on key points and used to deeply warm and relax muscle tissue." },
      { name: "Prenatal Massage", duration: "60 min", price: "$105", description: "Specially adapted for expecting mothers. Safe positioning with full support from the second trimester." },
      { name: "Couples Retreat", duration: "90 min", price: "$240 for two", description: "Side-by-side massages in our couples suite. Your choice of Swedish or deep tissue." },
    ],
  },
  {
    name: "Facial Treatments",
    img: "https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=1200&q=80",
    services: [
      { name: "Signature Facial", duration: "60 min", price: "$115", description: "Custom to your skin type — includes deep cleanse, exfoliation, extractions, mask, and massage." },
      { name: "Brightening Vitamin C Facial", duration: "60 min", price: "$125", description: "Targets dullness and uneven tone using professional-grade Vitamin C. Leaves skin visibly radiant." },
      { name: "Hydrating Moisture Facial", duration: "60 min", price: "$115", description: "For dry or dehydrated skin. Hyaluronic acid and barrier repair restore suppleness." },
      { name: "Acne-Clarifying Facial", duration: "75 min", price: "$130", description: "Salicylic acid exfoliation, deep extractions, and a calming mask for acne-prone skin." },
    ],
  },
  {
    name: "Enhancements",
    img: "https://images.unsplash.com/photo-1519823551278-64ac92734fb1?w=1200&q=80",
    services: [
      { name: "CBD Muscle Relief", duration: "+15 min", price: "+$25", description: "Topical CBD oil applied to areas of tension. Anti-inflammatory, fast-absorbing." },
      { name: "Scalp Massage", duration: "+15 min", price: "+$20", description: "Tension-releasing scalp and neck work added to any massage." },
      { name: "Foot Reflexology", duration: "+15 min", price: "+$20", description: "Warm towel wrap and targeted pressure work on the feet." },
      { name: "Eye Contour Treatment", duration: "+15 min", price: "+$25", description: "Depuffing, brightening eye treatment added to any facial." },
    ],
  },
];
---

<SoleLayout title="Services — Solé Wellness Studio" page="Services">
  <style>
    .cat-hero { position: relative; overflow: hidden; }
    .cat-hero img { transition: transform 8s linear; }
    .cat-hero:hover img { transform: scale(1.04); }
  </style>

  <!-- Page header -->
  <section class="relative py-24 px-6 overflow-hidden">
    <img src="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?w=1920&q=80" alt="" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0" style="background: rgba(22,45,22,0.78);"></div>
    <div class="relative z-10 max-w-3xl mx-auto text-center">
      <p class="reveal text-xs uppercase tracking-[0.35em] mb-4" style="color: rgba(255,255,255,0.5);">Solé Wellness Studio</p>
      <h1 class="reveal text-4xl md:text-6xl font-medium text-white" style="font-family: var(--font-serif); font-style: italic;">Our Services</h1>
      <p class="reveal text-sm mt-4" style="color: rgba(255,255,255,0.6);">All treatments by licensed therapists. New? Start with a Swedish massage or Signature Facial.</p>
      <a href="/demos/pro/book"
        style="background: var(--s-sage); color: #fff; font-size: 0.7rem; letter-spacing: 0.15em;"
        class="reveal inline-flex mt-8 px-10 py-4 uppercase tracking-wider hover:opacity-90 transition-opacity">
        Book Online
      </a>
    </div>
  </section>

  <!-- Categories -->
  {categories.map((cat, ci) => (
    <section style={`background: ${ci % 2 === 0 ? 'var(--s-bg)' : 'var(--s-bg-alt)'}; border-bottom: 1px solid var(--s-border);`} class="px-6 py-16">
      <div class="max-w-6xl mx-auto">
        <!-- Category image header -->
        <div class={`reveal cat-hero mb-10 overflow-hidden`} style="height: 220px; position: relative;">
          <img src={cat.img} alt={cat.name} class="w-full h-full object-cover" style="object-position: center 40%;" />
          <div class="absolute inset-0 flex items-end p-6" style="background: linear-gradient(to top, rgba(22,45,22,0.85) 0%, transparent 60%);">
            <h2 class="text-2xl font-semibold text-white" style="font-family: var(--font-serif); font-style: italic;">{cat.name}</h2>
          </div>
        </div>

        <!-- Services list -->
        <div class="space-y-px" style="border: 1px solid var(--s-border);">
          {cat.services.map((svc, si) => (
            <div class={`reveal reveal-delay-${si % 3} flex flex-col md:flex-row md:items-center justify-between px-4 sm:px-6 py-5 gap-4`}
              style={`background: ${ci % 2 === 0 ? 'var(--s-bg)' : 'var(--s-bg-alt)'}; ${si < cat.services.length - 1 ? 'border-bottom: 1px solid var(--s-border);' : ''}`}>
              <div class="flex-1 min-w-0">
                <div class="flex items-baseline gap-3 mb-1 flex-wrap">
                  <h3 class="font-semibold break-words" style="font-family: var(--font-serif); color: var(--s-ink);">{svc.name}</h3>
                  <span class="text-xs whitespace-nowrap" style="color: var(--s-muted);">{svc.duration}</span>
                </div>
                <p class="text-sm leading-relaxed max-w-lg break-words" style="color: var(--s-muted);">{svc.description}</p>
              </div>
              <div class="flex items-center gap-4 flex-shrink-0">
                <span class="font-medium whitespace-nowrap" style="color: var(--s-gold);">{svc.price}</span>
                <a href="/demos/pro/book"
                  style="background: var(--s-sage); color: #fff; font-size: 0.65rem; letter-spacing: 0.1em;"
                  class="px-4 py-2 uppercase tracking-wider hover:opacity-90 transition-opacity whitespace-nowrap">
                  Book
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Final CTA -->
  <section style="background: var(--s-bg-dark);" class="px-6 py-20 text-center">
    <h2 class="reveal text-3xl font-medium text-white mb-3" style="font-family: var(--font-serif); font-style: italic;">Ready when you are.</h2>
    <p class="reveal text-sm mb-8" style="color: rgba(255,255,255,0.45);">Online booking open 24/7. Same-day appointments often available.</p>
    <a href="/demos/pro/book"
      style="background: var(--s-sage); color: #fff; font-size: 0.7rem; letter-spacing: 0.15em;"
      class="reveal inline-flex px-10 py-4 uppercase tracking-wider hover:opacity-90 transition-opacity">
      Book an Appointment
    </a>
  </section>
</SoleLayout>
