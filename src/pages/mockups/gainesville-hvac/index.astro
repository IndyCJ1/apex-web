---
import GHvacLayout from "../../../layouts/GHvacLayout.astro";
import { business } from "./_business";
---

<GHvacLayout page="Home" snap={true}>

  <!-- Hero -->
  <section class="gh-snap-section gh-hatch" style="padding: 2.5rem 1.5rem; position: relative; overflow: hidden;">
    <div style="max-width: 1280px; margin: 0 auto; position: relative;">

      <!-- Top spec row -->
      <div class="gh-reveal" style="display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; margin-bottom: 1.5rem; align-items: center;">
        <span class="gh-spec" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.3rem 0.6rem; background: var(--gh-warm); color: var(--gh-bg); font-weight: 600;">
          <span style="display: inline-block; width: 6px; height: 6px; background: var(--gh-bg); border-radius: 50%;"></span>
          NOW SCHEDULING
        </span>
        <span class="gh-spec" style="color: var(--gh-muted);">SERVING HALL COUNTY AND SURROUNDING AREAS</span>
      </div>

      <h1 class="gh-display gh-reveal gh-reveal-1" style="font-size: clamp(2.25rem, 5vw, 3.75rem); color: var(--gh-ink); max-width: 16ch;">
        Heating &amp; cooling, done <span style="color: var(--gh-orange);">right.</span>
      </h1>

      <div style="display: grid; grid-template-columns: 1fr; gap: 1.5rem; margin-top: 1.5rem;" class="gh-grid-split">
        <p class="gh-reveal gh-reveal-2" style="font-size: 1rem; line-height: 1.6; color: var(--gh-ink); max-width: 38rem;">
          {business.name} is a locally owned heating and cooling company serving Gainesville and the surrounding North Georgia area since {business.established}. Honest diagnostics, transparent pricing, and same-visit repairs on most service calls.
        </p>

        <div class="gh-reveal gh-reveal-3" style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
          <a href={`tel:${business.phoneDigits}`} class="gh-btn gh-btn-orange">
            ◉ Call {business.phone}
          </a>
          <a href="/mockups/gainesville-hvac/contact" class="gh-btn gh-btn-ghost">
            Request Service →
          </a>
        </div>
      </div>

      <hr class="gh-rule-strong" style="margin-top: 2rem;" />

      <!-- Trust signals row -->
      <div class="gh-reveal gh-reveal-4" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1.25rem; padding: 1.25rem 0 0;">
        {business.trustSignals.map((s) => (
          <div class="gh-spec">
            <span class="gh-spec-label">{s.label}</span>
            <span class="gh-spec-value" style="font-size: 1rem; letter-spacing: 0.1em;">{s.value}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 01 — Services -->
  <section class="gh-snap-section" style="padding: 4rem 1.5rem; background: var(--gh-bg-2);">
    <div style="max-width: 1280px; margin: 0 auto;">

      <div class="gh-reveal" style="display: grid; grid-template-columns: 1fr; gap: 2rem; margin-bottom: 3.5rem; align-items: end;">
        <div>
          <p class="gh-section-num" style="margin-bottom: 0.85rem;">01 / SERVICES</p>
          <h2 class="gh-display" style="font-size: clamp(1.85rem, 4vw, 3rem); color: var(--gh-ink); max-width: 18ch;">
            Heating, cooling, and indoor air services.
          </h2>
        </div>
      </div>

      <div class="gh-services-grid" style="display: grid; grid-template-columns: 1fr; gap: 1px; background: var(--gh-line); border: 2px solid var(--gh-line);">
        <style>
          @media (min-width: 640px)  { .gh-services-grid { grid-template-columns: repeat(2, 1fr) !important; } }
          @media (min-width: 980px)  { .gh-services-grid { grid-template-columns: repeat(3, 1fr) !important; } }
        </style>
        {business.services.map((svc, i) => (
          <a href="/mockups/gainesville-hvac/services" class={`gh-reveal gh-reveal-${(i % 6) + 1} gh-service-card`} style="background: var(--gh-bg); padding: 1.85rem 1.65rem; text-decoration: none; color: var(--gh-ink); display: flex; flex-direction: column; gap: 0.85rem; transition: background 0.2s;">
            <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 1rem;">
              <span class="gh-section-num">{svc.num}</span>
              <span class="gh-mono" style="font-size: 0.65rem; letter-spacing: 0.15em; color: var(--gh-muted); text-transform: uppercase;">{svc.starting}</span>
            </div>
            <h3 class="gh-display" style="font-size: 1.4rem; color: var(--gh-ink);">{svc.name}</h3>
            <p style="font-size: 0.92rem; line-height: 1.6; color: var(--gh-muted); flex: 1;">{svc.summary}</p>
            <span class="gh-mono" style="font-size: 0.7rem; letter-spacing: 0.15em; color: var(--gh-orange); text-transform: uppercase; margin-top: auto;">DETAILS →</span>
          </a>
        ))}
      </div>

      <style>
        .gh-service-card:hover { background: var(--gh-paper) !important; }
      </style>
    </div>
  </section>

  <!-- 02 — Why us / split with image -->
  <section class="gh-snap-section" style="padding: 4rem 1.5rem; background: var(--gh-bg);">
    <div style="max-width: 1280px; margin: 0 auto;">

      <div class="gh-reveal" style="margin-bottom: 3.5rem;">
        <p class="gh-section-num" style="margin-bottom: 0.85rem;">02 / WHY HOMEOWNERS CHOOSE US</p>
        <h2 class="gh-display" style="font-size: clamp(1.85rem, 4vw, 3rem); color: var(--gh-ink); max-width: 18ch;">
          Built on craftsmanship, fair pricing, and reliability.
        </h2>
      </div>

      <div style="display: grid; grid-template-columns: 1fr; gap: 3rem;" class="gh-grid-image-split">

        <!-- Reasons list -->
        <div style="display: flex; flex-direction: column; gap: 0;">
          {[
            { num: "A", title: "Transparent on-site diagnostics.", body: "When our technician identifies an issue, we show you what's wrong and provide an upfront written quote before any repair work begins." },
            { num: "B", title: "Common parts stocked on every truck.", body: "Capacitors, contactors, blower motors, ignitors, and common refrigerants. The majority of service calls are completed in a single visit." },
            { num: "C", title: "Flat-rate pricing on common services.", body: "Tune-ups, routine repairs, and maintenance plans are flat-rate, not billed hourly — so you know the exact cost before we begin." },
            { num: "D", title: "Maintenance plans that pay for themselves.", body: "Two scheduled visits per year, priority service, no diagnostic fees, and 15% off repairs. Most plan customers recover the cost within the first year." },
          ].map((r, i) => (
            <div class={`gh-reveal gh-reveal-${i + 1}`} style="display: grid; grid-template-columns: 50px 1fr; gap: 1.25rem; padding: 1.4rem 0; border-bottom: 1px solid var(--gh-rule);">
              <div class="gh-display" style="font-size: 2rem; color: var(--gh-orange); line-height: 1;">{r.num}</div>
              <div>
                <h3 class="gh-display" style="font-size: 1.2rem; color: var(--gh-ink); margin-bottom: 0.4rem;">{r.title}</h3>
                <p style="font-size: 0.92rem; line-height: 1.65; color: var(--gh-muted);">{r.body}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Image / spec card -->
        <div class="gh-reveal gh-reveal-2" style="position: relative;">
          <div style="position: relative; aspect-ratio: 4/5; overflow: hidden; border: 2px solid var(--gh-line);">
            <img src="https://images.unsplash.com/photo-1621905251918-48416bd8575a?w=1000&q=85" alt="HVAC technician servicing a residential air conditioning unit" style="width: 100%; height: 100%; object-fit: cover; filter: contrast(1.05) saturate(0.85);" />
          </div>
          <div style="background: var(--gh-bg-2); color: var(--gh-ink); padding: 1.5rem 1.75rem; margin-top: -2px; border: 2px solid var(--gh-line);">
            <p class="gh-spec gh-spec-label" style="color: var(--gh-muted);">WHAT YOU CAN COUNT ON</p>
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; margin-top: 1rem;">
              <div class="gh-spec">
                <span class="gh-spec-label" style="color: var(--gh-muted);">RESPONSE</span>
                <span class="gh-display" style="display: block; color: var(--gh-ink); font-size: 1.55rem; margin-top: 0.25rem;">SAME DAY</span>
              </div>
              <div class="gh-spec">
                <span class="gh-spec-label" style="color: var(--gh-muted);">EMERGENCY</span>
                <span class="gh-display" style="display: block; color: var(--gh-warm); font-size: 1.55rem; margin-top: 0.25rem;">24 / 7</span>
              </div>
              <div class="gh-spec">
                <span class="gh-spec-label" style="color: var(--gh-muted);">QUOTES</span>
                <span class="gh-display" style="display: block; color: var(--gh-ink); font-size: 1.55rem; margin-top: 0.25rem;">UPFRONT</span>
              </div>
              <div class="gh-spec">
                <span class="gh-spec-label" style="color: var(--gh-muted);">WARRANTY</span>
                <span class="gh-display" style="display: block; color: var(--gh-cool); font-size: 1.55rem; margin-top: 0.25rem;">FACTORY</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <style>
        @media (min-width: 900px) {
          .gh-grid-image-split { grid-template-columns: 1.4fr 1fr !important; gap: 5rem !important; }
        }
      </style>
    </div>
  </section>

  <!-- 03 — Service area band -->
  <section class="gh-snap-section" style="padding: 4rem 1.5rem; background: var(--gh-bg-2); color: var(--gh-ink); position: relative; overflow: hidden; border-top: 1px solid var(--gh-line); border-bottom: 1px solid var(--gh-line);">
    <!-- Diagonal stripe accent -->
    <div aria-hidden="true" style="position: absolute; top: 0; right: 0; width: 200px; height: 100%; background: repeating-linear-gradient(45deg, var(--gh-orange) 0 12px, transparent 12px 24px); opacity: 0.18;"></div>

    <div style="max-width: 1280px; margin: 0 auto; position: relative;">
      <p class="gh-section-num gh-reveal" style="margin-bottom: 0.85rem;">03 / SERVICE AREA</p>
      <h2 class="gh-display gh-reveal gh-reveal-1" style="font-size: clamp(1.85rem, 4vw, 3rem); color: var(--gh-ink); max-width: 18ch; margin-bottom: 2.5rem;">
        Serving <span style="color: var(--gh-cool);">North Georgia</span> communities.
      </h2>

      <p class="gh-reveal gh-reveal-2" style="color: var(--gh-muted); max-width: 40rem; line-height: 1.65; margin-bottom: 2.5rem; font-size: 1rem;">
        We focus our coverage area to keep response times short and service quality consistent. If you're in any of these communities, you're within our service area.
      </p>

      <ul class="gh-reveal gh-reveal-3" style="list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 0.5rem 1.5rem;">
        {business.serviceArea.map((city) => (
          <li class="gh-display" style="font-size: 1.6rem; color: var(--gh-ink); padding-bottom: 0.5rem; border-bottom: 1px solid var(--gh-line);">
            {city}
          </li>
        ))}
      </ul>

      <div class="gh-reveal gh-reveal-4" style="margin-top: 3rem;">
        <a href="/mockups/gainesville-hvac/service-area" class="gh-btn gh-btn-orange">
          See Full Map →
        </a>
      </div>
    </div>
  </section>

  <!-- 04 — Reviews -->
  <section class="gh-snap-section" style="padding: 4rem 1.5rem; background: var(--gh-bg);">
    <div style="max-width: 1280px; margin: 0 auto;">

      <div class="gh-reveal" style="display: flex; flex-wrap: wrap; align-items: end; justify-content: space-between; gap: 1.5rem; margin-bottom: 3.5rem;">
        <div>
          <p class="gh-section-num" style="margin-bottom: 0.85rem;">04 / WHAT NEIGHBORS SAY</p>
          <h2 class="gh-display" style="font-size: clamp(1.85rem, 4vw, 3rem); color: var(--gh-ink); max-width: 16ch;">
            Recent reviews from Google.
          </h2>
        </div>
        <div class="gh-spec" style="text-align: right;">
          <span class="gh-spec-label">VERIFIED RATING</span>
          <span class="gh-display" style="display: block; font-size: 2.2rem; color: var(--gh-orange); letter-spacing: 0.05em; margin-top: 0.4rem;">★ ★ ★ ★ ★</span>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem;">
        {business.reviews.map((r, i) => (
          <article class={`gh-reveal gh-reveal-${(i % 4) + 1}`} style="background: var(--gh-paper); border: 2px solid var(--gh-line); padding: 1.75rem 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; position: relative;">
            <span aria-hidden="true" style="position: absolute; top: -1rem; left: 1.5rem; background: var(--gh-orange); color: var(--gh-bg); font-family: var(--font-display); font-size: 1.5rem; padding: 0 0.6rem; line-height: 1.6;">✦</span>

            <div style="display: flex; gap: 0.2rem; color: var(--gh-orange); font-size: 0.95rem;">
              {Array(r.rating).fill(0).map(() => <span aria-hidden="true">★</span>)}
            </div>

            <p style="font-size: 0.95rem; line-height: 1.65; color: var(--gh-ink); flex: 1;">"{r.quote}"</p>

            <hr class="gh-rule" />

            <div style="display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;">
              <div>
                <p class="gh-display" style="font-size: 1rem; color: var(--gh-ink);">{r.name}</p>
                <p class="gh-mono" style="font-size: 0.65rem; letter-spacing: 0.12em; color: var(--gh-muted); text-transform: uppercase; margin-top: 0.2rem;">Verified · {r.date}</p>
              </div>
              <p class="gh-mono" style="font-size: 0.62rem; letter-spacing: 0.1em; color: var(--gh-muted); text-transform: uppercase; text-align: right;">{r.service}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 05 — Big CTA -->
  <section class="gh-snap-section" style="padding: 4rem 1.5rem; background: var(--gh-warm); color: var(--gh-bg); position: relative; overflow: hidden;">
    <!-- Subtle pattern -->
    <div aria-hidden="true" style="position: absolute; inset: 0; background-image: repeating-linear-gradient(135deg, transparent 0 14px, rgba(20,24,31,0.06) 14px 15px); pointer-events: none;"></div>

    <div style="max-width: 1280px; margin: 0 auto; position: relative;">
      <p class="gh-section-num gh-reveal" style="color: var(--gh-bg); margin-bottom: 0.5rem;">05 / GET STARTED</p>

      <h2 class="gh-display gh-reveal gh-reveal-1" style="font-size: clamp(2.25rem, 5.5vw, 4rem); color: var(--gh-bg); max-width: 16ch; line-height: 0.95;">
        Schedule service today.
      </h2>

      <div class="gh-reveal gh-reveal-2" style="margin-top: 3rem; display: flex; flex-wrap: wrap; gap: 1rem; align-items: center;">
        <a href={`tel:${business.phoneDigits}`} class="gh-btn" style="font-size: 0.9rem; padding: 1.25rem 2rem; background: var(--gh-bg); border-color: var(--gh-bg); color: var(--gh-warm);">
          ◉ Call {business.phone}
        </a>
        <a href="/mockups/gainesville-hvac/contact" class="gh-btn" style="font-size: 0.9rem; padding: 1.25rem 2rem; background: transparent; border-color: var(--gh-bg); color: var(--gh-bg);">
          Or send a message →
        </a>
      </div>

      <p class="gh-reveal gh-reveal-3 gh-mono" style="margin-top: 2.5rem; font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gh-bg); opacity: 0.85;">
        ◉ {business.hours.weekdays}  ·  {business.hours.saturday}  ·  {business.hours.emergency}
      </p>
    </div>
  </section>

</GHvacLayout>
