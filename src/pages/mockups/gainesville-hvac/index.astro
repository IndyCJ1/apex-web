---
import GHvacLayout from "../../../layouts/GHvacLayout.astro";
import { business } from "./_business";
---

<GHvacLayout page="Home">

  <!-- Hero -->
  <section style="padding: 5rem 1.5rem 4rem; position: relative; overflow: hidden;" class="gh-hatch">
    <div style="max-width: 1280px; margin: 0 auto; position: relative;">

      <!-- Top spec row -->
      <div class="gh-reveal" style="display: flex; flex-wrap: wrap; gap: 0.6rem 1.25rem; margin-bottom: 3rem; align-items: center;">
        <span class="gh-spec" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.35rem 0.65rem; background: var(--gh-ink); color: var(--gh-bg); font-weight: 600;">
          <span style="display: inline-block; width: 6px; height: 6px; background: var(--gh-orange); border-radius: 50%;"></span>
          AVAILABLE NOW
        </span>
        <span class="gh-spec" style="color: var(--gh-muted);">— SERVICING ALL OF HALL COUNTY &amp; SURROUNDING</span>
      </div>

      <h1 class="gh-display gh-reveal gh-reveal-1" style="font-size: clamp(3rem, 9vw, 8.5rem); color: var(--gh-ink); max-width: 12ch;">
        Heating &amp;<br/>cooling, done<br/><span style="color: var(--gh-orange);">right.</span>
      </h1>

      <div style="display: grid; grid-template-columns: 1fr; gap: 2.5rem; margin-top: 3rem;" class="gh-grid-split">
        <p class="gh-reveal gh-reveal-2" style="font-size: 1.05rem; line-height: 1.65; color: var(--gh-ink); max-width: 38rem;">
          {business.name} is a locally owned heating and cooling company serving Gainesville and the surrounding North Georgia area since {business.established}. Honest diagnostics, fair pricing, and the parts that actually fail — on the truck.
        </p>

        <div class="gh-reveal gh-reveal-3" style="display: flex; flex-wrap: wrap; gap: 0.85rem;">
          <a href={`tel:${business.phoneDigits}`} class="gh-btn gh-btn-orange">
            ◉ Call {business.phone}
          </a>
          <a href="/mockups/gainesville-hvac/contact" class="gh-btn gh-btn-ghost">
            Request Service →
          </a>
        </div>
      </div>

      <hr class="gh-rule-strong" style="margin-top: 4.5rem;" />

      <!-- Trust signals row -->
      <div class="gh-reveal gh-reveal-4" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1.5rem; padding: 2rem 0; border-bottom: 1px solid var(--gh-rule);">
        {business.trustSignals.map((s) => (
          <div class="gh-spec">
            <span class="gh-spec-label">{s.label}</span>
            <span class="gh-spec-value" style="font-size: 1.1rem; letter-spacing: 0.12em;">{s.value}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 01 — Services -->
  <section style="padding: 6rem 1.5rem; background: var(--gh-bg-2);">
    <div style="max-width: 1280px; margin: 0 auto;">

      <div class="gh-reveal" style="display: grid; grid-template-columns: 1fr; gap: 2rem; margin-bottom: 3.5rem; align-items: end;">
        <div>
          <p class="gh-section-num" style="margin-bottom: 0.85rem;">01 / WHAT WE DO</p>
          <h2 class="gh-display" style="font-size: clamp(2.5rem, 5.5vw, 4.5rem); color: var(--gh-ink); max-width: 14ch;">
            Six services. Straight answers.
          </h2>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1px; background: var(--gh-line); border: 2px solid var(--gh-line);">
        {business.services.map((svc, i) => (
          <a href="/mockups/gainesville-hvac/services" class={`gh-reveal gh-reveal-${i % 4} gh-service-card`} style="background: var(--gh-bg); padding: 2.25rem 2rem; text-decoration: none; color: var(--gh-ink); display: flex; flex-direction: column; gap: 1rem; transition: background 0.2s;">
            <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 1rem;">
              <span class="gh-section-num">{svc.num}</span>
              <span class="gh-mono" style="font-size: 0.65rem; letter-spacing: 0.15em; color: var(--gh-muted); text-transform: uppercase;">{svc.starting}</span>
            </div>
            <h3 class="gh-display" style="font-size: 1.85rem; color: var(--gh-ink);">{svc.name}</h3>
            <p style="font-size: 0.92rem; line-height: 1.6; color: var(--gh-muted); flex: 1;">{svc.summary}</p>
            <span class="gh-mono" style="font-size: 0.7rem; letter-spacing: 0.15em; color: var(--gh-orange); text-transform: uppercase; margin-top: auto;">DETAILS →</span>
          </a>
        ))}
      </div>

      <style>
        .gh-service-card:hover { background: var(--gh-paper) !important; }
      </style>
    </div>
  </section>

  <!-- 02 — Why us / split with image -->
  <section style="padding: 6rem 1.5rem; background: var(--gh-bg);">
    <div style="max-width: 1280px; margin: 0 auto;">

      <div class="gh-reveal" style="margin-bottom: 3.5rem;">
        <p class="gh-section-num" style="margin-bottom: 0.85rem;">02 / WHY HOMEOWNERS CALL US</p>
        <h2 class="gh-display" style="font-size: clamp(2.5rem, 5.5vw, 4.5rem); color: var(--gh-ink); max-width: 18ch;">
          The HVAC company you'd recommend to your mother.
        </h2>
      </div>

      <div style="display: grid; grid-template-columns: 1fr; gap: 3rem;" class="gh-grid-image-split">

        <!-- Reasons list -->
        <div style="display: flex; flex-direction: column; gap: 0;">
          {[
            { num: "A", title: "Diagnostic in your hand, not a sales pitch.", body: "When the tech finds the problem, you see what's broken. We quote the repair on the spot. No 'we'll call you tomorrow with a number.'" },
            { num: "B", title: "We carry the parts that actually fail.", body: "Capacitors, contactors, blower motors, ignitors, common refrigerant. 90% of repairs are done same-visit, not after a parts run." },
            { num: "C", title: "Fixed-price work where it makes sense.", body: "You shouldn't get billed by the hour for predictable jobs. Tune-ups, common repairs, and maintenance plans are flat-rate so you know what you're paying." },
            { num: "D", title: "Maintenance plans that earn their keep.", body: "Two visits a year, priority scheduling, no diagnostic fees, 15% off repairs. Most plan customers save the cost back in their first year." },
          ].map((r, i) => (
            <div class={`gh-reveal gh-reveal-${i}`} style="display: grid; grid-template-columns: 64px 1fr; gap: 1.5rem; padding: 1.75rem 0; border-bottom: 1px solid var(--gh-rule);">
              <div class="gh-display" style="font-size: 2.5rem; color: var(--gh-orange); line-height: 1;">{r.num}</div>
              <div>
                <h3 class="gh-display" style="font-size: 1.4rem; color: var(--gh-ink); margin-bottom: 0.5rem;">{r.title}</h3>
                <p style="font-size: 0.92rem; line-height: 1.65; color: var(--gh-muted);">{r.body}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Image / spec card -->
        <div class="gh-reveal gh-reveal-2" style="position: relative;">
          <div style="position: relative; aspect-ratio: 4/5; overflow: hidden; border: 2px solid var(--gh-line);">
            <img src="https://images.unsplash.com/photo-1621905251918-48416bd8575a?w=1000&q=85" alt="HVAC technician servicing a residential air conditioning unit" style="width: 100%; height: 100%; object-fit: cover; filter: contrast(1.05) saturate(0.85);" />
          </div>
          <div style="background: var(--gh-ink); color: var(--gh-bg); padding: 1.5rem 1.75rem; margin-top: -2px; border: 2px solid var(--gh-line);">
            <p class="gh-spec gh-spec-label" style="color: rgba(255,255,255,0.45);">WHAT YOU CAN COUNT ON</p>
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; margin-top: 1rem;">
              <div class="gh-spec">
                <span class="gh-spec-label" style="color: rgba(255,255,255,0.45);">RESPONSE</span>
                <span class="gh-display" style="display: block; color: var(--gh-bg); font-size: 1.55rem; margin-top: 0.25rem;">SAME DAY</span>
              </div>
              <div class="gh-spec">
                <span class="gh-spec-label" style="color: rgba(255,255,255,0.45);">EMERGENCY</span>
                <span class="gh-display" style="display: block; color: var(--gh-orange); font-size: 1.55rem; margin-top: 0.25rem;">24 / 7</span>
              </div>
              <div class="gh-spec">
                <span class="gh-spec-label" style="color: rgba(255,255,255,0.45);">QUOTES</span>
                <span class="gh-display" style="display: block; color: var(--gh-bg); font-size: 1.55rem; margin-top: 0.25rem;">UPFRONT</span>
              </div>
              <div class="gh-spec">
                <span class="gh-spec-label" style="color: rgba(255,255,255,0.45);">WARRANTY</span>
                <span class="gh-display" style="display: block; color: var(--gh-bg); font-size: 1.55rem; margin-top: 0.25rem;">FACTORY</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <style>
        @media (min-width: 900px) {
          .gh-grid-image-split { grid-template-columns: 1.4fr 1fr !important; gap: 5rem !important; }
        }
      </style>
    </div>
  </section>

  <!-- 03 — Service area band -->
  <section style="padding: 5rem 1.5rem; background: var(--gh-ink); color: var(--gh-bg); position: relative; overflow: hidden;">
    <!-- Diagonal stripe accent -->
    <div aria-hidden="true" style="position: absolute; top: 0; right: 0; width: 200px; height: 100%; background: repeating-linear-gradient(45deg, var(--gh-orange) 0 12px, transparent 12px 24px); opacity: 0.18;"></div>

    <div style="max-width: 1280px; margin: 0 auto; position: relative;">
      <p class="gh-section-num gh-reveal" style="margin-bottom: 0.85rem;">03 / SERVICE AREA</p>
      <h2 class="gh-display gh-reveal gh-reveal-1" style="font-size: clamp(2.5rem, 5.5vw, 4.5rem); color: var(--gh-bg); max-width: 16ch; margin-bottom: 2.5rem;">
        Not everyone. Just <span style="color: var(--gh-orange);">your neighbors</span>.
      </h2>

      <p class="gh-reveal gh-reveal-2" style="color: rgba(255,255,255,0.7); max-width: 40rem; line-height: 1.65; margin-bottom: 2.5rem; font-size: 1rem;">
        We stay close to home so we can keep our response times low. If you're in any of these towns, you're in our service area.
      </p>

      <ul class="gh-reveal gh-reveal-3" style="list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 0.5rem 1.5rem;">
        {business.serviceArea.map((city) => (
          <li class="gh-display" style="font-size: 1.6rem; color: var(--gh-bg); padding-bottom: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.12);">
            {city}
          </li>
        ))}
      </ul>

      <div class="gh-reveal gh-reveal-4" style="margin-top: 3rem;">
        <a href="/mockups/gainesville-hvac/service-area" class="gh-btn gh-btn-orange">
          See Full Map →
        </a>
      </div>
    </div>
  </section>

  <!-- 04 — Reviews -->
  <section style="padding: 6rem 1.5rem; background: var(--gh-bg);">
    <div style="max-width: 1280px; margin: 0 auto;">

      <div class="gh-reveal" style="display: flex; flex-wrap: wrap; align-items: end; justify-content: space-between; gap: 1.5rem; margin-bottom: 3.5rem;">
        <div>
          <p class="gh-section-num" style="margin-bottom: 0.85rem;">04 / WHAT NEIGHBORS SAY</p>
          <h2 class="gh-display" style="font-size: clamp(2.5rem, 5.5vw, 4.5rem); color: var(--gh-ink); max-width: 16ch;">
            Recent reviews from Google.
          </h2>
        </div>
        <div class="gh-spec" style="text-align: right;">
          <span class="gh-spec-label">VERIFIED RATING</span>
          <span class="gh-display" style="display: block; font-size: 2.2rem; color: var(--gh-orange); letter-spacing: 0.05em; margin-top: 0.4rem;">★ ★ ★ ★ ★</span>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem;">
        {business.reviews.map((r, i) => (
          <article class={`gh-reveal gh-reveal-${i % 4}`} style="background: var(--gh-paper); border: 2px solid var(--gh-line); padding: 2rem 1.75rem; display: flex; flex-direction: column; gap: 1.25rem; position: relative;">
            <span aria-hidden="true" style="position: absolute; top: -1rem; left: 1.5rem; background: var(--gh-orange); color: var(--gh-bg); font-family: var(--font-display); font-size: 1.5rem; padding: 0 0.6rem; line-height: 1.6;">✦</span>

            <div style="display: flex; gap: 0.2rem; color: var(--gh-orange); font-size: 0.95rem;">
              {Array(r.rating).fill(0).map(() => <span aria-hidden="true">★</span>)}
            </div>

            <p style="font-size: 0.95rem; line-height: 1.65; color: var(--gh-ink); flex: 1;">"{r.quote}"</p>

            <hr class="gh-rule" />

            <div style="display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;">
              <div>
                <p class="gh-display" style="font-size: 1rem; color: var(--gh-ink);">{r.name}</p>
                <p class="gh-mono" style="font-size: 0.65rem; letter-spacing: 0.12em; color: var(--gh-muted); text-transform: uppercase; margin-top: 0.2rem;">Verified · {r.date}</p>
              </div>
              <p class="gh-mono" style="font-size: 0.62rem; letter-spacing: 0.1em; color: var(--gh-muted); text-transform: uppercase; text-align: right;">{r.service}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 05 — Big CTA -->
  <section style="padding: 6rem 1.5rem 7rem; background: var(--gh-orange); color: var(--gh-ink); position: relative; overflow: hidden;">
    <!-- Subtle pattern -->
    <div aria-hidden="true" style="position: absolute; inset: 0; background-image: repeating-linear-gradient(135deg, transparent 0 14px, rgba(20,24,31,0.06) 14px 15px); pointer-events: none;"></div>

    <div style="max-width: 1280px; margin: 0 auto; position: relative;">
      <p class="gh-section-num gh-reveal" style="color: var(--gh-ink); margin-bottom: 0.85rem;">05 / READY?</p>

      <h2 class="gh-display gh-reveal gh-reveal-1" style="font-size: clamp(3rem, 8vw, 7rem); color: var(--gh-ink); max-width: 16ch; line-height: 0.92;">
        Pick up the phone. We'll pick up ours.
      </h2>

      <div class="gh-reveal gh-reveal-2" style="margin-top: 3rem; display: flex; flex-wrap: wrap; gap: 1rem; align-items: center;">
        <a href={`tel:${business.phoneDigits}`} class="gh-btn" style="font-size: 0.9rem; padding: 1.25rem 2rem;">
          ◉ Call {business.phone}
        </a>
        <a href="/mockups/gainesville-hvac/contact" class="gh-btn gh-btn-ghost" style="font-size: 0.9rem; padding: 1.25rem 2rem;">
          Or send a message →
        </a>
      </div>

      <p class="gh-reveal gh-reveal-3 gh-mono" style="margin-top: 2.5rem; font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gh-ink); opacity: 0.7;">
        ◉ {business.hours.weekdays}  ·  {business.hours.saturday}  ·  {business.hours.emergency}
      </p>
    </div>
  </section>

</GHvacLayout>
