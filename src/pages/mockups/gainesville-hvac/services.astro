---
import GHvacLayout from "../../../layouts/GHvacLayout.astro";
import { business } from "./_business";
---

<GHvacLayout title={`Services — ${business.name}`} page="Services">

  <!-- Page header -->
  <section style="padding: 5rem 1.5rem 3rem; background: var(--gh-bg);" class="gh-hatch">
    <div style="max-width: 1280px; margin: 0 auto;">
      <p class="gh-section-num gh-reveal">SECTION 01 / SERVICES</p>
      <h1 class="gh-display gh-reveal gh-reveal-1" style="font-size: clamp(3rem, 8vw, 7rem); color: var(--gh-ink); margin-top: 1rem; max-width: 14ch;">
        What we do<br/><span style="color: var(--gh-orange);">all day.</span>
      </h1>
      <p class="gh-reveal gh-reveal-2" style="font-size: 1.05rem; line-height: 1.65; color: var(--gh-ink); max-width: 38rem; margin-top: 2rem;">
        Six core services — from a $89 diagnostic call to a full system replacement. No service we won't quote, but also no service we'll talk you into if you don't need it.
      </p>
    </div>
  </section>

  <!-- Services list -->
  <section style="padding: 4rem 1.5rem 6rem; background: var(--gh-bg);">
    <div style="max-width: 1280px; margin: 0 auto;">
      <hr class="gh-rule-strong" />

      {business.services.map((svc, i) => (
        <article class={`gh-reveal gh-reveal-${i % 3}`} style="display: grid; grid-template-columns: 1fr; gap: 2rem; padding: 3.5rem 0; border-bottom: 1px solid var(--gh-rule);">

          <header style="display: grid; grid-template-columns: auto 1fr; gap: 2rem; align-items: baseline;">
            <span class="gh-display" style="font-size: clamp(3rem, 6vw, 5rem); color: var(--gh-orange); line-height: 1;">{svc.num}</span>
            <div>
              <h2 class="gh-display" style="font-size: clamp(2rem, 4.5vw, 3.5rem); color: var(--gh-ink); line-height: 1;">{svc.name}</h2>
              <p class="gh-mono" style="font-size: 0.7rem; letter-spacing: 0.18em; color: var(--gh-muted); text-transform: uppercase; margin-top: 0.85rem;">{svc.starting}</p>
            </div>
          </header>

          <div style="display: grid; grid-template-columns: 1fr; gap: 2rem;" class="gh-svc-body">
            <div>
              <p style="font-size: 1rem; line-height: 1.7; color: var(--gh-ink); margin-bottom: 1rem; font-weight: 600;">{svc.summary}</p>
              <p style="font-size: 0.92rem; line-height: 1.7; color: var(--gh-muted);">{svc.detail}</p>

              <div style="margin-top: 1.75rem; display: flex; flex-wrap: wrap; gap: 0.75rem;">
                <a href={`tel:${business.phoneDigits}`} class="gh-btn">◉ Call {business.phone}</a>
                <a href="/mockups/gainesville-hvac/contact" class="gh-btn gh-btn-ghost">Request quote →</a>
              </div>
            </div>

            <aside style="background: var(--gh-bg-2); border: 2px solid var(--gh-line); padding: 1.5rem;">
              <p class="gh-spec gh-spec-label">FIELD NOTES</p>
              <ul style="list-style: none; padding: 0; margin: 1rem 0 0; display: flex; flex-direction: column; gap: 0.85rem;">
                {[
                  { k: "Typical visit", v: i === 1 ? "1–4 hrs" : i === 2 ? "1–3 hrs" : i === 3 ? "30 min" : "1–2 hrs" },
                  { k: "Parts on truck", v: i === 0 || i === 2 ? "Common" : i === 4 ? "Most" : "—" },
                  { k: "Same-day", v: i === 5 ? "By appt" : "Usually" },
                  { k: "Warranty", v: i === 1 ? "10 yr parts / 2 yr labor" : "1 yr labor" },
                ].map((row) => (
                  <li style="display: grid; grid-template-columns: 1fr auto; gap: 1rem; padding-bottom: 0.85rem; border-bottom: 1px dashed var(--gh-rule); font-size: 0.85rem;">
                    <span style="color: var(--gh-muted);">{row.k}</span>
                    <span style="color: var(--gh-ink); font-weight: 600; text-align: right;">{row.v}</span>
                  </li>
                ))}
              </ul>
            </aside>
          </div>

          <style>
            @media (min-width: 768px) {
              .gh-svc-body { grid-template-columns: 1.6fr 1fr !important; gap: 3rem !important; }
            }
          </style>
        </article>
      ))}
    </div>
  </section>

  <!-- Bottom CTA -->
  <section style="padding: 5rem 1.5rem; background: var(--gh-ink); color: var(--gh-bg);">
    <div style="max-width: 800px; margin: 0 auto; text-align: center;">
      <h2 class="gh-display gh-reveal" style="font-size: clamp(2rem, 5vw, 3.5rem); color: var(--gh-bg);">
        Don't see what you need?<br/><span style="color: var(--gh-orange);">Call us anyway.</span>
      </h2>
      <p class="gh-reveal gh-reveal-1" style="margin-top: 1.5rem; color: rgba(255,255,255,0.65); line-height: 1.65;">
        If we can't do it, we know who can. We work with the same handful of trusted electricians, plumbers, and insulators in the area for the jobs that need them.
      </p>
      <a href={`tel:${business.phoneDigits}`} class="gh-btn gh-btn-orange gh-reveal gh-reveal-2" style="margin-top: 2.5rem;">
        ◉ Call {business.phone}
      </a>
    </div>
  </section>

</GHvacLayout>
