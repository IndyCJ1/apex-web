  <script is:inline>
    (function() {
      // Mobile nav
      var toggle = document.getElementById('fh-toggle');
      var panel  = document.getElementById('fh-panel');
      if (toggle && panel) {
        toggle.addEventListener('click', function() {
          var open = panel.classList.toggle('hidden') ? 'false' : 'true';
          toggle.setAttribute('aria-expanded', open);
        });
        panel.addEventListener('click', function(e) {
          if (e.target.tagName === 'A') {
            panel.classList.add('hidden');
            toggle.setAttribute('aria-expanded', 'false');
          }
        });
      }

      // Today's hours highlight
      var today = new Date().getDay();
      var rows = document.querySelectorAll('#hours-list [data-day]');
      rows.forEach(function(row) {
        if (parseInt(row.getAttribute('data-day'), 10) === today) {
          row.classList.add('fh-hours-today');
          var dayEl = row.querySelector('.fh-day');
          var timeEl = row.querySelector('.fh-time');
          if (dayEl) dayEl.textContent = dayEl.textContent + ' (today)';
        }
      });

      // Trailer form — demo submit
      var trailerForm = document.getElementById('trailer-form');
      var trailerSuccess = document.getElementById('trailer-success');
      if (trailerForm && trailerSuccess) {
        trailerForm.addEventListener('submit', function(e) {
          e.preventDefault();
          trailerForm.classList.add('hidden');
          trailerSuccess.classList.remove('hidden');
        });
      }

      // FAM Club form — demo submit
      var famForm = document.getElementById('fam-form');
      var famSuccess = document.getElementById('fam-success');
      if (famForm && famSuccess) {
        famForm.addEventListener('submit', function(e) {
          e.preventDefault();
          famForm.classList.add('hidden');
          famSuccess.classList.remove('hidden');
        });
      }
    })();
  </script>

