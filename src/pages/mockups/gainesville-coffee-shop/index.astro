    <!-- ───── Visit ───── -->
    <section class="gcs-section gcs-section-visit" id="visit">
      <div class="gcs-container">

        <div style="text-align: center; max-width: 640px; margin: 0 auto 3.5rem;" class="gcs-reveal">
          <span class="gcs-eyebrow">Find us</span>
          <h2 class="gcs-h2">631 Broad Street.</h2>
          <p style="font-family: var(--gcs-display); font-style: italic; font-size: 1.1rem; color: var(--gcs-muted); margin-top: 0.85rem;">
            Inside Lawrence Pharmacy, right near Northeast Georgia Medical Center. Park out front, walk through the pharmacy, the counter's on your left.
          </p>
        </div>

        <div class="gcs-visit-grid">

          <div class="gcs-reveal">
            <div class="gcs-visit-block">
              <div class="gcs-visit-label">Address</div>
              <h4>{business.address}</h4>
              <p style="color: var(--gcs-muted); font-size: 0.95rem; margin-top: 0.25rem;">{business.cityState}</p>
              <p style="margin-top: 0.85rem;">
                <a href="https://maps.google.com/?q=631+Broad+St+SE+Gainesville+GA+30501" target="_blank" rel="noopener noreferrer">Get directions ↗</a>
              </p>
            </div>
            <div class="gcs-visit-block">
              <div class="gcs-visit-label">Contact</div>
              <h4><a href={`tel:${business.phoneDigits}`}>{business.phone}</a></h4>
              <p style="margin-top: 0.35rem;"><a href={`mailto:${business.email}`}>{business.email}</a></p>
            </div>
            <div class="gcs-visit-block">
              <div class="gcs-visit-label">Order online</div>
              <h4><a href={business.chownow} target="_blank" rel="noopener noreferrer">ChowNow →</a></h4>
              <p style="color: var(--gcs-muted); font-size: 0.9rem; margin-top: 0.3rem;">Free delivery in Gainesville, no minimum.</p>
            </div>
            <div class="gcs-visit-block">
              <div class="gcs-visit-label">Sister kitchen</div>
              <h4>{business.sister}</h4>
              <p style="color: var(--gcs-muted); font-size: 0.9rem; margin-top: 0.3rem;">Same folks — dockside food and lake views at Gainesville Marina when the weather's right.</p>
            </div>
          </div>

          <div class="gcs-reveal gcs-d-1">
            <div class="gcs-visit-block">
              <div class="gcs-visit-label">Hours</div>
              <ul class="gcs-hours-list">
                {hours.map((h) => (
