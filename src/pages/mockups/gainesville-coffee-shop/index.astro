    </footer>

    <script is:inline>
      (function () {
        // Reveal animations
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -80px 0px' }
        );
        document.querySelectorAll('.gcs-reveal').forEach(function (el) { io.observe(el); });

        // Open / Closed status banner — counter open M-F 8am-2pm
        function applyStatus() {
          var d = new Date();
          var dow = d.getDay(); // 0 Sun .. 6 Sat
          var minutes = d.getHours() * 60 + d.getMinutes();
          var pill = document.getElementById('gcsStatusPill');
          var label = document.getElementById('gcsStatusLabel');
          var text = document.getElementById('gcsStatusText');
          if (!pill || !label || !text) return;

          var isWeekday = (dow >= 1 && dow <= 5);
          var openMin = 8 * 60;        // 8:00 AM
          var breakfastEnd = 11 * 60;  // 11:00 AM
          var closeMin = 14 * 60;      // 2:00 PM

          if (isWeekday && minutes >= openMin && minutes < closeMin) {
            pill.classList.remove('closed');
            label.textContent = 'Open now';
            if (minutes < breakfastEnd) {
              text.textContent = 'Breakfast until 11 · Lunch until 2 PM today';
            } else {
              text.textContent = 'Lunch until 2 PM today';
            }
          } else if (isWeekday && minutes < openMin) {
            pill.classList.add('closed');
            label.textContent = 'Closed';
            text.textContent = 'Opens at 8 AM today';
          } else if (dow === 6 || dow === 0) {
            pill.classList.add('closed');
            label.textContent = 'Closed';
            text.textContent = (dow === 6 ? 'Back Monday' : 'Back Monday') + ' at 8 AM';
          } else {
            pill.classList.add('closed');
            label.textContent = 'Closed';
            // After 2pm on a weekday
            if (dow === 5) {
              text.textContent = 'Back Monday at 8 AM';
            } else {
              text.textContent = 'Back tomorrow at 8 AM';
            }
          }
        }
        applyStatus();
        setInterval(applyStatus, 60000);

        // Highlight today's row in the hours list
        var hoursOrder = [1, 2, 3, 4, 5, 6, 0]; // Mon..Sun
        var todayIdx = hoursOrder.indexOf(new Date().getDay());
        if (todayIdx >= 0) {
          var rows = document.querySelectorAll('.gcs-hours-list li');
          if (rows[todayIdx]) rows[todayIdx].classList.add('today');
        }
      })();
    </script>

  </body>
</html>
