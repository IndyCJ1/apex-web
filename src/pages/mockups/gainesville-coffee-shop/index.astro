    <!-- ───── Story (1958) ───── -->
    <section class="gcs-section gcs-section-story gcs-story" id="story">
      <div class="gcs-container">
        <div class="gcs-story-grid">

          <div class="gcs-story-photo gcs-reveal"></div>

          <div class="gcs-reveal gcs-d-1">
            <span class="gcs-eyebrow">Since '58</span>
            <h2 class="gcs-h2">Same <em>corner</em>, same chili, same wave from the register.</h2>
            <p>Lawrence Pharmacy opened the doors at 631 Broad Street on January 29, 1958. The lunch counter came with it. Most of what's changed since then is the price.</p>
            <p>Stephen Adams runs the pharmacy now. The Coffee Shop runs the counter — breakfast at 8, lunch at 11, last order at 2. We've been making the same chili the same way for sixty-something years. Some things hold up.</p>
            <p class="pull">"Best chili dog in Hall County. Two locations: here, and that's it."</p>
            <p>If you grew up in Gainesville, you ate here. If you didn't, your boss did. Either way, the door's open — come find the counter.</p>
            <div class="gcs-stat-strip">
              <div class="gcs-stat">
                <div class="num">1958</div>
                <div class="label">On Broad Street</div>
              </div>
              <div class="gcs-stat">
                <div class="num">3</div>
                <div class="label">Generations served</div>
              </div>
              <div class="gcs-stat">
                <div class="num">$0</div>
                <div class="label">Delivery minimum</div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ───── Testimonials ───── -->
    <section class="gcs-section gcs-testimonials">
      <div class="gcs-container">
        <div style="text-align: center; max-width: 640px; margin: 0 auto;" class="gcs-reveal">
          <span class="gcs-eyebrow">From the regulars</span>
          <h2 class="gcs-h2">The counter <em>remembers.</em></h2>
        </div>
        <div class="gcs-quote-grid">
          {testimonials.map((t, i) => (
            <figure class={`gcs-quote gcs-reveal gcs-d-${i + 1}`}>
              <span class="mark">"</span>
              <p>{t.quote}</p>
              <figcaption class="source">
                {t.name}
