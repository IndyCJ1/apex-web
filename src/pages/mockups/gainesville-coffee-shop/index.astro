---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,follow" />
    <meta name="description" content="The Coffee Shop at Lawrence Pharmacy — breakfast, lunch, and free delivery in Gainesville, GA since 1958." />
    <title>The Coffee Shop at Lawrence Pharmacy · Gainesville, GA</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;600;700;800&family=Caveat:wght@500;700&display=swap" rel="stylesheet" />

    <style is:global>
      :root {
        --gcs-paper:    #FAF6EC;
        --gcs-cream:    #F2E9D5;
        --gcs-cream-2:  #E8DCC0;
        --gcs-red:      #B5402E;
        --gcs-red-2:    #8E2F22;
        --gcs-green:    #3E5C46;
        --gcs-green-2:  #2C4231;
        --gcs-mustard:  #C99A2E;
        --gcs-mustard-2:#A87E20;
        --gcs-ink:      #1A1714;
        --gcs-ink-2:    #2B2723;
        --gcs-muted:    #6B6357;
        --gcs-line:     rgba(26, 23, 20, 0.12);

        --gcs-display:  'DM Serif Display', 'Cormorant Garamond', Georgia, serif;
        --gcs-body:     'Inter', system-ui, -apple-system, sans-serif;
        --gcs-script:   'Caveat', cursive;
      }

      *, *::before, *::after { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      html, body { background: var(--gcs-paper); margin: 0; padding: 0; }
      body {
        color: var(--gcs-ink);
        font-family: var(--gcs-body);
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
        width: 100%;
        overflow-x: hidden;
      }
      h1, h2, h3, h4 { font-family: var(--gcs-display); font-weight: 400; letter-spacing: -0.015em; line-height: 1.1; margin: 0; }
      p { margin: 0; }
      a { color: inherit; }
      img { display: block; max-width: 100%; height: auto; }
      ::selection { background: var(--gcs-red); color: var(--gcs-paper); }
      h1, h2, h3, p, li, span, a { overflow-wrap: anywhere; }

      .gcs-display { font-family: var(--gcs-display); }
      .gcs-script  { font-family: var(--gcs-script); }
      .gcs-italic  { font-style: italic; }

      /* ─── Header ─── */
      .gcs-header {
        position: sticky;
        top: 0;
        z-index: 60;
        background: rgba(250, 246, 236, 0.94);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--gcs-line);
      }
      .gcs-header-inner {
        width: 100%;
        max-width: 1280px;
        margin: 0 auto;
        padding: 0.9rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
      }
      .gcs-logo {
        display: flex;
        flex-direction: column;
        line-height: 1;
        text-decoration: none;
        color: var(--gcs-ink);
      }
      .gcs-logo-main {
        font-family: var(--gcs-display);
        font-size: 1.4rem;
        letter-spacing: -0.01em;
      }
      .gcs-logo-sub {
        font-family: var(--gcs-body);
        font-size: 0.66rem;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--gcs-muted);
        margin-top: 0.3rem;
      }
      .gcs-nav { display: flex; gap: 1.75rem; align-items: center; }
      .gcs-nav a {
        font-family: var(--gcs-body);
        font-size: 0.86rem;
        font-weight: 600;
        color: var(--gcs-ink-2);
        text-decoration: none;
        transition: color 0.2s;
      }
      .gcs-nav a:hover { color: var(--gcs-red); }
      .gcs-header-phone {
        font-family: var(--gcs-display);
        font-size: 1rem;
        color: var(--gcs-ink);
        text-decoration: none;
      }
      .gcs-header-phone:hover { color: var(--gcs-red); }

      /* ─── Buttons ─── */
      .gcs-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.55rem;
        padding: 0.9rem 1.6rem;
        font-family: var(--gcs-body);
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        text-decoration: none;
        border: none;
        cursor: pointer;
        border-radius: 4px;
        transition: transform 0.15s, background 0.15s, color 0.15s, box-shadow 0.15s;
        line-height: 1;
      }
      .gcs-btn-red    { background: var(--gcs-red); color: var(--gcs-paper); }
      .gcs-btn-red:hover { background: var(--gcs-red-2); transform: translateY(-1px); }
      .gcs-btn-green  { background: var(--gcs-green); color: var(--gcs-paper); }
      .gcs-btn-green:hover { background: var(--gcs-green-2); transform: translateY(-1px); }
      .gcs-btn-ink    { background: var(--gcs-ink); color: var(--gcs-paper); }
      .gcs-btn-ink:hover { background: var(--gcs-ink-2); transform: translateY(-1px); }
      .gcs-btn-ghost  { background: transparent; color: var(--gcs-ink); border: 1.5px solid var(--gcs-ink); }
      .gcs-btn-ghost:hover { background: var(--gcs-ink); color: var(--gcs-paper); }
      .gcs-btn-ghost-light { background: transparent; color: var(--gcs-paper); border: 1.5px solid var(--gcs-paper); }
      .gcs-btn-ghost-light:hover { background: var(--gcs-paper); color: var(--gcs-ink); }
      .gcs-btn-lg { padding: 1.1rem 1.85rem; font-size: 0.88rem; }

      /* ─── Section utilities ─── */
      .gcs-section { padding: 5.5rem 1.5rem; position: relative; width: 100%; }
      .gcs-section-tight { padding: 3rem 1.5rem; }
      .gcs-container {
        width: 100%;
        max-width: 1280px;
        margin: 0 auto;
        position: relative;
      }
      .gcs-container-narrow {
        width: 100%;
        max-width: 920px;
        margin: 0 auto;
        position: relative;
      }

      .gcs-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        font-family: var(--gcs-body);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--gcs-red);
        margin-bottom: 1rem;
      }
      .gcs-eyebrow::before,
      .gcs-eyebrow::after {
        content: "";
        display: inline-block;
        width: 22px;
        height: 1.5px;
        background: var(--gcs-red);
      }

      .gcs-h2 { font-size: clamp(2rem, 5vw, 3.4rem); letter-spacing: -0.02em; }
      .gcs-h2 em { font-style: italic; color: var(--gcs-red); }

      /* ─── Hero ─── */
      .gcs-hero {
        position: relative;
        padding: 4.5rem 1.5rem 5.5rem;
        background: var(--gcs-paper);
        overflow: hidden;
      }
      .gcs-hero-grid {
        width: 100%;
        max-width: 1280px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1.1fr 1fr;
        gap: 4rem;
        align-items: center;
      }
      .gcs-hero-est {
        font-family: var(--gcs-script);
        font-size: clamp(1.6rem, 2.4vw, 2.1rem);
        color: var(--gcs-red);
        margin-bottom: 0.5rem;
        line-height: 1;
      }
      .gcs-hero h1 {
        font-family: var(--gcs-display);
        font-size: clamp(2.6rem, 6.5vw, 5rem);
        color: var(--gcs-ink);
        line-height: 0.98;
        letter-spacing: -0.02em;
      }
      .gcs-hero h1 em {
        font-style: italic;
        color: var(--gcs-red);
      }
      .gcs-hero-tag-row {
        margin-top: 1.5rem;
        display: flex;
        gap: 1.25rem;
        align-items: center;
        font-family: var(--gcs-body);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--gcs-green);
      }
      .gcs-hero-tag-row .dot { width: 5px; height: 5px; border-radius: 50%; background: var(--gcs-green); }
      .gcs-hero p.lead {
        font-family: var(--gcs-display);
        font-size: clamp(1.05rem, 1.8vw, 1.3rem);
        color: var(--gcs-ink);
        max-width: 520px;
        margin-top: 1.75rem;
        line-height: 1.5;
        font-style: italic;
      }
      .gcs-hero-cta-row { display: flex; gap: 0.85rem; flex-wrap: wrap; margin-top: 2.25rem; }

      /* Photo collage in hero */
      .gcs-hero-photo {
        position: relative;
        aspect-ratio: 4/5;
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: 1fr 1fr;
        gap: 0.5rem;
      }
      .gcs-hero-photo > div {
        background-size: cover;
        background-position: center;
        border-radius: 4px;
      }
      .gcs-hero-photo > div:nth-child(1) {
        grid-row: 1 / span 2;
        background-image: url("https://images.unsplash.com/photo-1542444459-db63c9b07a7e?w=900&q=85");
      }
      .gcs-hero-photo > div:nth-child(2) {
        background-image: url("https://images.unsplash.com/photo-1551782450-a2132b4ba21d?w=600&q=85");
      }
      .gcs-hero-photo > div:nth-child(3) {
        background-image: url("https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?w=600&q=85");
      }
      .gcs-hero-stamp {
        position: absolute;
        bottom: -1rem;
        right: -1rem;
        width: 130px;
        height: 130px;
        background: var(--gcs-red);
        color: var(--gcs-paper);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        font-family: var(--gcs-display);
        font-size: 0.95rem;
        line-height: 1.2;
        padding: 1rem;
        transform: rotate(-12deg);
        box-shadow: 0 8px 24px -8px rgba(181, 64, 46, 0.4);
        z-index: 2;
      }
      .gcs-hero-stamp em { font-style: italic; display: block; font-size: 1.5rem; }

      /* ─── Open status banner ─── */
      .gcs-status {
        background: var(--gcs-cream);
        border-bottom: 1px solid var(--gcs-line);
        padding: 1.25rem 1.5rem;
      }
      .gcs-status-inner {
        width: 100%;
        max-width: 1280px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        flex-wrap: wrap;
      }
      .gcs-status-left {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        font-family: var(--gcs-body);
        font-size: 0.92rem;
        font-weight: 600;
        color: var(--gcs-ink);
      }
      .gcs-status-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        background: var(--gcs-green);
        color: var(--gcs-paper);
        padding: 0.35rem 0.85rem;
        border-radius: 999px;
        font-family: var(--gcs-body);
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }
      .gcs-status-pill.closed { background: var(--gcs-red); }
      .gcs-status-pill .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gcs-paper); animation: gcs-pulse 2s infinite; }
      @keyframes gcs-pulse {
        0%   { opacity: 1; }
        50%  { opacity: 0.4; }
        100% { opacity: 1; }
      }
      .gcs-status-right {
        font-family: var(--gcs-body);
        font-size: 0.82rem;
        color: var(--gcs-muted);
        display: flex;
        gap: 1.25rem;
        align-items: center;
      }
      .gcs-status-right a { color: var(--gcs-ink); font-weight: 700; text-decoration: none; border-bottom: 1.5px solid var(--gcs-red); padding-bottom: 1px; }
      .gcs-status-right a:hover { color: var(--gcs-red); }

      /* ─── Menu section ─── */
      .gcs-section-menu { background: var(--gcs-paper); }
      .gcs-menu-grid {
        margin-top: 3.5rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2.5rem;
      }
      .gcs-menu-col {
        background: var(--gcs-cream);
        border: 1px solid var(--gcs-line);
        border-radius: 6px;
        padding: 2rem 1.75rem;
      }
      .gcs-menu-col h3 {
        font-family: var(--gcs-display);
        font-size: 1.85rem;
        color: var(--gcs-ink);
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.5rem;
        padding-bottom: 0.85rem;
        border-bottom: 2px solid var(--gcs-line);
      }
      .gcs-menu-col h3 .gcs-script { font-size: 1.3rem; color: var(--gcs-red); }
      .gcs-menu-list { display: grid; grid-template-columns: 1fr; gap: 0; }
      .gcs-menu-row {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 1rem;
        align-items: baseline;
        padding: 0.85rem 0;
        border-bottom: 1px dotted var(--gcs-line);
      }
      .gcs-menu-row:last-child { border-bottom: none; }
      .gcs-menu-row .name { font-weight: 700; font-size: 1rem; color: var(--gcs-ink); }
      .gcs-menu-row .desc { font-size: 0.85rem; color: var(--gcs-muted); margin-top: 0.15rem; line-height: 1.45; }
      .gcs-menu-row .price { font-family: var(--gcs-display); font-size: 1.1rem; color: var(--gcs-red); white-space: nowrap; }
      .gcs-menu-row .flag {
        display: inline-block;
        background: var(--gcs-mustard);
        color: var(--gcs-ink);
        font-family: var(--gcs-body);
        font-size: 0.62rem;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        padding: 0.15rem 0.5rem;
        border-radius: 3px;
        margin-left: 0.5rem;
        vertical-align: middle;
      }

      .gcs-drinks-sides {
        margin-top: 2.5rem;
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 2.5rem;
      }
      .gcs-sides-col h3 {
        font-family: var(--gcs-display);
        font-size: 1.45rem;
        color: var(--gcs-ink);
        margin-bottom: 1rem;
        padding-bottom: 0.6rem;
        border-bottom: 2px solid var(--gcs-line);
      }
      .gcs-sides-list {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.55rem 1.5rem;
      }
      .gcs-sides-list > div {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        font-size: 0.92rem;
        padding: 0.4rem 0;
        border-bottom: 1px dotted var(--gcs-line);
      }
      .gcs-sides-list .name { flex: 1; font-weight: 600; color: var(--gcs-ink); }
      .gcs-sides-list .price { font-family: var(--gcs-display); color: var(--gcs-red); white-space: nowrap; }

      .gcs-menu-footnote {
        margin-top: 2.5rem;
        text-align: center;
        font-family: var(--gcs-display);
        font-style: italic;
        font-size: 1.1rem;
        color: var(--gcs-muted);
      }

      /* ─── Delivery callout ─── */
      .gcs-delivery {
        background: var(--gcs-green);
        color: var(--gcs-paper);
        padding: 5rem 1.5rem;
      }
      .gcs-delivery-grid {
        width: 100%;
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 3.5rem;
        align-items: center;
      }
      .gcs-delivery .gcs-eyebrow { color: var(--gcs-mustard); }
      .gcs-delivery .gcs-eyebrow::before,
      .gcs-delivery .gcs-eyebrow::after { background: var(--gcs-mustard); }
      .gcs-delivery h2 { color: var(--gcs-paper); font-size: clamp(2rem, 5vw, 3.4rem); }
      .gcs-delivery h2 em { color: var(--gcs-mustard); font-style: italic; }
      .gcs-delivery p { color: rgba(250, 246, 236, 0.85); font-size: 1.05rem; line-height: 1.7; margin-top: 1.25rem; max-width: 32rem; }
      .gcs-delivery-cta-row { margin-top: 2rem; display: flex; gap: 0.85rem; flex-wrap: wrap; }
      .gcs-delivery-info {
        background: rgba(250, 246, 236, 0.06);
        border: 1px solid rgba(250, 246, 236, 0.15);
        border-radius: 6px;
        padding: 2rem;
      }
      .gcs-delivery-info .row {
        display: grid;
        grid-template-columns: 110px 1fr;
        gap: 1rem;
        padding: 0.85rem 0;
        border-bottom: 1px dashed rgba(250, 246, 236, 0.2);
      }
      .gcs-delivery-info .row:last-child { border-bottom: none; }
      .gcs-delivery-info .label {
        font-family: var(--gcs-body);
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--gcs-mustard);
      }
      .gcs-delivery-info .val { color: var(--gcs-paper); font-size: 0.95rem; font-weight: 500; }

      /* ─── Story / 1958 ─── */
      .gcs-section-story {
        background: var(--gcs-cream-2);
        position: relative;
      }
      .gcs-story-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 4rem;
        align-items: center;
      }
      .gcs-story-photo {
        aspect-ratio: 4/5;
        border-radius: 4px;
        overflow: hidden;
        background: url("https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=900&q=85") center/cover;
        position: relative;
      }
      .gcs-story-photo::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 60%, rgba(26, 23, 20, 0.25));
        pointer-events: none;
      }
      .gcs-story h2 { font-size: clamp(2.1rem, 5vw, 3.6rem); }
      .gcs-story h2 em { color: var(--gcs-red); font-style: italic; }
      .gcs-story p { font-size: 1.02rem; line-height: 1.75; color: var(--gcs-ink); margin-top: 1.1rem; }
      .gcs-story .pull {
        font-family: var(--gcs-display);
        font-size: 1.4rem;
        font-style: italic;
        color: var(--gcs-green);
        line-height: 1.4;
        margin: 1.75rem 0;
        padding: 0 0 0 1.5rem;
        border-left: 2.5px solid var(--gcs-red);
      }
      .gcs-stat-strip {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
        margin-top: 2.25rem;
        padding-top: 1.75rem;
        border-top: 1px solid var(--gcs-line);
      }
      .gcs-stat .num { font-family: var(--gcs-display); font-size: 2rem; color: var(--gcs-red); line-height: 1; }
      .gcs-stat .label { font-family: var(--gcs-body); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gcs-muted); margin-top: 0.4rem; }

      /* ─── Testimonials ─── */
      .gcs-testimonials { background: var(--gcs-paper); }
      .gcs-quote-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        margin-top: 3rem;
      }
      .gcs-quote {
        background: var(--gcs-cream);
        padding: 2rem 1.75rem;
        border-radius: 4px;
        border-top: 4px solid var(--gcs-red);
      }
      .gcs-quote .mark {
        font-family: var(--gcs-display);
        font-size: 3rem;
        line-height: 0.4;
        color: var(--gcs-red);
        margin-bottom: 1rem;
        display: block;
        font-style: italic;
      }
      .gcs-quote p { font-family: var(--gcs-display); font-style: italic; font-size: 1.05rem; line-height: 1.55; color: var(--gcs-ink); margin-bottom: 1.5rem; }
      .gcs-quote .source { font-size: 0.86rem; color: var(--gcs-ink); font-weight: 700; }
      .gcs-quote .source small { display: block; font-weight: 500; font-size: 0.78rem; color: var(--gcs-muted); margin-top: 0.15rem; }

      /* ─── Visit ─── */
      .gcs-section-visit { background: var(--gcs-cream); }
      .gcs-visit-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
      }
      .gcs-visit-block {
        padding-bottom: 1.85rem;
        margin-bottom: 1.85rem;
        border-bottom: 1px solid var(--gcs-line);
      }
      .gcs-visit-block:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
      .gcs-visit-label {
        font-family: var(--gcs-body);
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--gcs-muted);
        margin-bottom: 0.75rem;
      }
      .gcs-visit-block h4 { font-family: var(--gcs-display); font-size: 1.5rem; color: var(--gcs-ink); margin-bottom: 0.35rem; line-height: 1.2; }
      .gcs-visit-block a { color: var(--gcs-red); text-decoration: none; font-weight: 600; }
      .gcs-visit-block a:hover { text-decoration: underline; }

      .gcs-hours-list { list-style: none; padding: 0; margin: 0; }
      .gcs-hours-list li {
        display: grid;
        grid-template-columns: 110px 1fr;
        gap: 1rem;
        padding: 0.65rem 0;
        font-size: 0.96rem;
        border-bottom: 1px dashed var(--gcs-line);
      }
      .gcs-hours-list li:last-child { border-bottom: none; }
      .gcs-hr-day { font-weight: 700; color: var(--gcs-ink); }
      .gcs-hr-time { color: var(--gcs-muted); }
      .gcs-hours-list li.closed .gcs-hr-time { color: var(--gcs-red); font-style: italic; }
      .gcs-hours-list li.today {
        background: rgba(181, 64, 46, 0.08);
        border-radius: 4px;
        padding-left: 0.65rem;
        padding-right: 0.65rem;
      }

      /* ─── Footer ─── */
      .gcs-footer {
        background: var(--gcs-ink);
        color: rgba(250, 246, 236, 0.7);
        padding: 3.5rem 1.5rem 2rem;
      }
      .gcs-footer-inner { width: 100%; max-width: 1280px; margin: 0 auto; }
      .gcs-footer-top {
        display: grid;
        grid-template-columns: 1.4fr 1fr 1fr 1fr;
        gap: 3rem;
        padding-bottom: 2.5rem;
        border-bottom: 1px solid rgba(250, 246, 236, 0.12);
      }
      .gcs-footer .brand { font-family: var(--gcs-display); font-size: 1.4rem; color: var(--gcs-paper); margin-bottom: 0.5rem; }
      .gcs-footer .brand-sub { font-size: 0.74rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gcs-mustard); margin-bottom: 0.85rem; }
      .gcs-footer h5 { font-family: var(--gcs-body); font-size: 0.72rem; font-weight: 800; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gcs-mustard); margin-bottom: 0.9rem; }
      .gcs-footer p { font-size: 0.88rem; line-height: 1.65; }
      .gcs-footer ul { list-style: none; padding: 0; margin: 0; }
      .gcs-footer li { padding: 0.35rem 0; }
      .gcs-footer a { color: rgba(250, 246, 236, 0.7); text-decoration: none; font-size: 0.88rem; }
      .gcs-footer a:hover { color: var(--gcs-mustard); }
      .gcs-footer-bottom {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: center;
        justify-content: space-between;
        padding-top: 1.75rem;
        font-size: 0.78rem;
      }
      .gcs-footer-bottom a { color: var(--gcs-paper); font-weight: 700; text-decoration: underline; }

      /* ─── Reveal animations ─── */
      .gcs-reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.85s cubic-bezier(0.16, 1, 0.3, 1), transform 0.85s cubic-bezier(0.16, 1, 0.3, 1); will-change: opacity, transform; }
      .gcs-reveal.is-visible { opacity: 1; transform: none; }
      .gcs-d-1 { transition-delay: 0.08s; }
      .gcs-d-2 { transition-delay: 0.16s; }
      .gcs-d-3 { transition-delay: 0.24s; }
      .gcs-d-4 { transition-delay: 0.32s; }
      @media (prefers-reduced-motion: reduce) {
        .gcs-reveal { opacity: 1; transform: none; transition: none; }
        html { scroll-behavior: auto; }
        .gcs-status-pill .dot { animation: none; }
      }

      /* ─── Responsive ─── */
      @media (max-width: 900px) {
        .gcs-nav { display: none; }
        .gcs-section { padding: 4rem 1.25rem; }
        .gcs-hero { padding: 3rem 1.25rem 4rem; }
        .gcs-hero-grid { grid-template-columns: 1fr; gap: 3rem; }
        .gcs-hero-photo { max-width: 480px; margin: 0 auto; }
        .gcs-menu-grid { grid-template-columns: 1fr; gap: 1.5rem; }
        .gcs-drinks-sides { grid-template-columns: 1fr; gap: 2rem; }
        .gcs-sides-list { grid-template-columns: 1fr; }
        .gcs-delivery-grid, .gcs-story-grid, .gcs-visit-grid { grid-template-columns: 1fr; gap: 2.5rem; }
        .gcs-quote-grid { grid-template-columns: 1fr; }
        .gcs-stat-strip { grid-template-columns: 1fr 1fr 1fr; gap: 0.75rem; }
        .gcs-footer-top { grid-template-columns: 1fr 1fr; gap: 2rem; }
        .gcs-header-phone { display: none; }
      }
      @media (max-width: 520px) {
        .gcs-header-inner { padding: 0.7rem 1rem; gap: 1rem; }
        .gcs-footer-top { grid-template-columns: 1fr; gap: 2rem; }
        .gcs-stat-strip { grid-template-columns: 1fr; gap: 1rem; }
        .gcs-btn { width: 100%; }
        .gcs-hero-cta-row .gcs-btn, .gcs-delivery-cta-row .gcs-btn { width: auto; }
        .gcs-hero-stamp { width: 100px; height: 100px; font-size: 0.78rem; bottom: -0.5rem; right: -0.5rem; }
        .gcs-hero-stamp em { font-size: 1.15rem; }
      }
    </style>
  </head>

  <body>

    <!-- ───── Header ───── -->
    <header class="gcs-header">
      <div class="gcs-header-inner">
        <a href="#top" class="gcs-logo">
          <span class="gcs-logo-main">The Coffee Shop</span>
          <span class="gcs-logo-sub">at Lawrence Pharmacy · Est. {business.pharmacyFounded}</span>
        </a>
        <nav class="gcs-nav">
          <a href="#menu">Menu</a>
          <a href="#delivery">Delivery</a>
          <a href="#story">Since '58</a>
          <a href="#visit">Visit</a>
        </nav>
        <a href={`tel:${business.phoneDigits}`} class="gcs-header-phone">{business.phone}</a>
      </div>
    </header>

    <!-- ───── Hero ───── -->
    <section class="gcs-hero" id="top">
      <div class="gcs-hero-grid">

        <div>
          <p class="gcs-hero-est gcs-reveal">since 1958.</p>
          <h1 class="gcs-reveal gcs-d-1">
            Breakfast and lunch<br/>from the <em>corner of Broad.</em>
          </h1>
          <div class="gcs-hero-tag-row gcs-reveal gcs-d-2">
            <span class="dot"></span><span>Counter Service</span>
            <span class="dot"></span><span>Free Delivery</span>
            <span class="dot"></span><span>Open M–F</span>
          </div>
          <p class="lead gcs-reveal gcs-d-3">
            A working diner counter inside Lawrence Pharmacy. Chili dogs that haven't changed since you were a kid. Free delivery in Gainesville, no minimum. Done by 2.
          </p>
          <div class="gcs-hero-cta-row gcs-reveal gcs-d-4">
            <a href={business.chownow} target="_blank" rel="noopener noreferrer" class="gcs-btn gcs-btn-red gcs-btn-lg">Order online</a>
            <a href="#menu" class="gcs-btn gcs-btn-ghost gcs-btn-lg">See the menu</a>
          </div>
        </div>

        <div class="gcs-hero-photo gcs-reveal gcs-d-2">
          <div></div>
          <div></div>
          <div></div>
          <div class="gcs-hero-stamp">
            <span>since<em>1958</em>on Broad</span>
          </div>
        </div>

      </div>
    </section>

    <!-- ───── Open status banner ───── -->
    <div class="gcs-status">
      <div class="gcs-status-inner">
        <div class="gcs-status-left">
          <span class="gcs-status-pill" id="gcsStatusPill"><span class="dot"></span><span id="gcsStatusLabel">Open now</span></span>
          <span id="gcsStatusText">Breakfast until 11 · Lunch until 2 PM today</span>
        </div>
        <div class="gcs-status-right">
          <span>Free local delivery</span>
          <span aria-hidden="true">·</span>
          <a href={business.chownow} target="_blank" rel="noopener noreferrer">Order on ChowNow →</a>
        </div>
      </div>
    </div>

    <!-- ───── Menu ───── -->
    <section class="gcs-section gcs-section-menu" id="menu">
      <div class="gcs-container">

        <div style="text-align: center; max-width: 720px; margin: 0 auto;" class="gcs-reveal">
          <span class="gcs-eyebrow">The Menu</span>
          <h2 class="gcs-h2">Counter food, <em>done right.</em></h2>
          <p style="font-family: var(--gcs-display); font-style: italic; color: var(--gcs-muted); font-size: 1.1rem; margin-top: 1rem;">
            Cathead biscuits. Eggs cracked-to-order. Twenty-some sandwiches. Free refills on coffee.
          </p>
        </div>

        <div class="gcs-menu-grid">

          <!-- Breakfast -->
          <div class="gcs-menu-col gcs-reveal gcs-d-1">
            <h3>Breakfast <span class="gcs-script">8 – 11 am.</span></h3>
            <div class="gcs-menu-list">
              {breakfast.map((item) => (
                <div class="gcs-menu-row">
                  <div>
                    <div class="name">{item.name}{item.flag && <span class="flag">{item.flag}</span>}</div>
                    {item.desc && <div class="desc">{item.desc}</div>}
                  </div>
                  <div class="price">{item.price}</div>
                </div>
              ))}
            </div>
            <div style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1.5px solid var(--gcs-line);">
              <div style="font-family: var(--gcs-body); font-size: 0.7rem; font-weight: 800; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gcs-muted); margin-bottom: 0.65rem;">À la carte</div>
              {breakfastAlacarte.map((item) => (
                <div class="gcs-menu-row">
                  <div><div class="name">{item.name}</div></div>
                  <div class="price">{item.price}</div>
                </div>
              ))}
            </div>
            <p style="font-family: var(--gcs-display); font-style: italic; font-size: 0.85rem; color: var(--gcs-muted); margin-top: 1rem; line-height: 1.5;">
              All egg plates & sandwiches with biscuit and/or egg whites available for $1.00 more.
            </p>
          </div>

          <!-- Sandwiches -->
          <div class="gcs-menu-col gcs-reveal gcs-d-2">
            <h3>Sandwiches <span class="gcs-script">11 – 2 pm.</span></h3>
            <div class="gcs-menu-list">
              {sandwiches.map((item) => (
                <div class="gcs-menu-row">
                  <div>
                    <div class="name">{item.name}{item.flag && <span class="flag">{item.flag}</span>}</div>
                    {item.desc && <div class="desc">{item.desc}</div>}
                  </div>
                  <div class="price">{item.price}</div>
                </div>
              ))}
            </div>
          </div>

        </div>

        <!-- Combo callout -->
        <div class="gcs-reveal" style="margin-top: 2rem; background: var(--gcs-mustard); color: var(--gcs-ink); padding: 1.5rem 1.85rem; border-radius: 6px; display: grid; grid-template-columns: 1fr auto; gap: 1.5rem; align-items: center;">
          <div>
            <div style="font-family: var(--gcs-body); font-size: 0.7rem; font-weight: 800; letter-spacing: 0.22em; text-transform: uppercase; margin-bottom: 0.4rem;">Combos · pick any two</div>
            <div style="font-family: var(--gcs-display); font-size: 1.1rem; line-height: 1.45;">
              Half ham, turkey, or roast beef melt — or tuna or chicken salad — paired with a half BLT, grilled cheese, egg salad, or pimento. Served with a side salad or cup of soup.
            </div>
            <div style="font-family: var(--gcs-display); font-size: 0.92rem; font-style: italic; margin-top: 0.4rem; opacity: 0.75;">
              Sub gumbo or chili for $1.49.
            </div>
          </div>
          <div style="font-family: var(--gcs-display); font-size: 2.4rem; color: var(--gcs-red); white-space: nowrap; line-height: 1;">$7.99</div>
        </div>

        <!-- Soups & Salads / Drinks & Extras -->
        <div class="gcs-drinks-sides" style="margin-top: 2.5rem;">

          <div class="gcs-sides-col gcs-reveal">
            <h3>Soups &amp; Salads</h3>
            <div style="font-family: var(--gcs-body); font-size: 0.7rem; font-weight: 800; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gcs-muted); margin-bottom: 0.65rem;">Soups</div>
            <div class="gcs-menu-list">
              {soups.map((item) => (
                <div class="gcs-menu-row">
                  <div>
                    <div class="name">{item.name}</div>
                    {item.desc && <div class="desc">{item.desc}</div>}
                  </div>
                  <div class="price">{item.price}</div>
                </div>
              ))}
            </div>
            <div style="font-family: var(--gcs-body); font-size: 0.7rem; font-weight: 800; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gcs-muted); margin: 1.25rem 0 0.65rem;">Salads</div>
            <div class="gcs-menu-list">
              {salads.map((item) => (
                <div class="gcs-menu-row">
                  <div>
                    <div class="name">{item.name}</div>
                    {item.desc && <div class="desc">{item.desc}</div>}
                  </div>
                  <div class="price">{item.price}</div>
                </div>
              ))}
            </div>
            <p style="font-family: var(--gcs-display); font-style: italic; font-size: 0.85rem; color: var(--gcs-muted); margin-top: 1rem; line-height: 1.5;">
              Add grilled or blackened chicken, fish, or shrimp to any salad for $3.99.
            </p>
          </div>

          <div class="gcs-sides-col gcs-reveal gcs-d-1">
            <h3>Drinks &amp; Extras</h3>
            <div style="font-family: var(--gcs-body); font-size: 0.7rem; font-weight: 800; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gcs-muted); margin-bottom: 0.65rem;">Drinks</div>
            <div class="gcs-menu-list">
              {drinks.map((item) => (
                <div class="gcs-menu-row">
                  <div>
                    <div class="name">{item.name}</div>
                    {item.desc && <div class="desc">{item.desc}</div>}
                  </div>
                  <div class="price">{item.price}</div>
                </div>
              ))}
            </div>
            <div style="font-family: var(--gcs-body); font-size: 0.7rem; font-weight: 800; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gcs-muted); margin: 1.25rem 0 0.65rem;">Sides &amp; Add-ons</div>
            <div class="gcs-menu-list">
              {sides.map((item) => (
                <div class="gcs-menu-row">
                  <div>
                    <div class="name">{item.name}</div>
                    {item.desc && <div class="desc">{item.desc}</div>}
                  </div>
                  <div class="price">{item.price}</div>
                </div>
              ))}
            </div>
          </div>

        </div>

        <p class="gcs-menu-footnote gcs-reveal">
          Cash, card, and a friendly nod accepted at the counter.
        </p>

      </div>
    </section>

    <!-- ───── Delivery callout ───── -->
    <section class="gcs-section gcs-delivery" id="delivery">
      <div class="gcs-delivery-grid">

        <div class="gcs-reveal">
          <span class="gcs-eyebrow">Free Delivery</span>
          <h2>We bring the <em>counter</em> to you.</h2>
          <p>Free delivery anywhere in Gainesville. No minimum order, no fees, no surge pricing. Call the shop or order online — we'll be there in 25 minutes or so, faster if it's slow.</p>
          <p style="font-family: var(--gcs-script); font-size: 1.55rem; color: var(--gcs-mustard); margin-top: 1.5rem; line-height: 1;">
            Office breakfast for a dozen? That's our specialty.
          </p>
          <div class="gcs-delivery-cta-row">
            <a href={business.chownow} target="_blank" rel="noopener noreferrer" class="gcs-btn gcs-btn-red gcs-btn-lg">Order on ChowNow</a>
