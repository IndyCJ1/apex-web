---
import Layout from "../../layouts/Layout.astro";
const features = [
  { title: "5-Page Custom Website", desc: "Home, About, Services, Contact + one more. Built for your brand — no templates.", icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" },
  { title: "Mobile Responsive", desc: "Looks perfect on every screen — phones, tablets, desktops. Over 60% of traffic is mobile.", icon: "M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" },
  { title: "Contact Form", desc: "Submissions go straight to your email. Customers reach you, you close the lead.", icon: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" },
  { title: "Basic On-Page SEO", desc: "Title tags, meta descriptions, heading structure, and sitemap so Google can find you.", icon: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" },
  { title: "Hosting & SSL Included", desc: "Fast servers, the padlock in the browser, and automatic backups — all in your monthly plan.", icon: "M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" },
  { title: "1 Hour of Edits/Month", desc: "Update hours, swap a photo, fix a typo. Same-day turnaround, no ticket system needed.", icon: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" },
];
---
<Layout title="Starter Package — Lanier Web">
  <header class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-border">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-lg font-extrabold text-ink"><span class="w-2.5 h-2.5 rounded-full bg-accent"></span>Lanier Web</a>
      <a href="/#packages" class="flex items-center gap-2 text-sm font-medium text-muted hover:text-ink transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>All Packages
      </a>
    </div>
  </header>

  <section class="px-6 pt-40 pb-20 bg-white relative overflow-hidden">
    <div class="absolute right-0 top-1/2 -translate-y-1/2 text-[18rem] font-extrabold select-none pointer-events-none" style="color: #F0F0F0; line-height: 1;">S</div>
    <div class="max-w-6xl mx-auto relative">
      <p class="reveal text-xs font-bold uppercase tracking-[0.2em] text-accent mb-4">Starter Package</p>
      <h1 class="reveal reveal-delay-1 font-extrabold leading-none mb-6" style="font-size: clamp(3rem, 7vw, 6rem)">
        Everything you need<br/>to get <span class="text-accent">online.</span>
      </h1>
      <div class="reveal reveal-delay-2 flex items-baseline gap-3 mb-8">
        <span class="text-5xl font-extrabold text-ink">$1,500</span><span class="text-muted">upfront</span>
        <span class="text-faint">+</span><span class="text-2xl font-extrabold text-ink">$50<span class="text-muted font-normal text-base">/mo</span></span>
      </div>
      <div class="reveal reveal-delay-3 flex flex-wrap gap-3">
        <a href="/#contact" class="bg-accent text-white px-8 py-3.5 font-bold text-sm rounded-full hover:bg-accent-dark transition-colors">Get Started →</a>
        <a href="/packages/plus" class="bg-off text-ink px-8 py-3.5 font-bold text-sm rounded-full hover:bg-border transition-colors">See Plus →</a>
      </div>
    </div>
  </section>

  <section class="px-6 py-20 bg-off">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-10"><p class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-2">What's Included</p><h2 class="text-3xl font-extrabold text-ink">Every feature, explained.</h2></div>
      <div class="grid md:grid-cols-2 gap-4">
        {features.map((f, i) => (
          <div class={`reveal reveal-delay-${i % 3} bg-white rounded-2xl p-6 border border-border hover:border-accent/30 hover:shadow-md transition-all duration-300`}>
            <div class="w-8 h-8 bg-accent-light rounded-lg flex items-center justify-center mb-4">
              <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={f.icon}/></svg>
            </div>
            <h3 class="font-bold text-ink mb-1.5">{f.title}</h3>
            <p class="text-sm text-muted leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="px-6 py-16 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-6">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-2">Live Demo</p>
        <h2 class="text-3xl font-extrabold text-ink">See it in action.</h2>
        <p class="text-muted text-sm mt-2">A real Starter-tier site — navigate between pages using the tabs below.</p>
      </div>

      <!-- Page tabs -->
      <div class="reveal flex items-center gap-2 mb-3 flex-wrap">
        {[
          { label: "Home", url: "https://hogtown-smoke.pages.dev" },
          { label: "Menu", url: "https://hogtown-smoke.pages.dev/#menu" },
          { label: "Our Story", url: "https://hogtown-smoke.pages.dev/#about" },
          { label: "Visit", url: "https://hogtown-smoke.pages.dev/#visit" },
        ].map((page, i) => (
          <button
            type="button"
            class="demo-tab px-4 py-2 text-xs font-semibold rounded-full border transition-all duration-200"
            style={i === 0 ? "background: #FF4500; color: white; border-color: #FF4500;" : "background: white; color: #737373; border-color: #E5E5E5;"}
            data-url={page.url}
          >
            {page.label}
          </button>
        ))}
        <a href="https://hogtown-smoke.pages.dev" target="_blank" rel="noopener noreferrer"
          class="ml-auto flex items-center gap-1.5 text-xs font-semibold text-accent hover:underline">
          Open full site
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>

      <div class="reveal rounded-2xl overflow-hidden border border-border shadow-lg">
        <div class="flex items-center gap-3 px-4 py-3 bg-off border-b border-border">
          <div class="flex gap-1.5"><div class="w-3 h-3 rounded-full bg-red-400"></div><div class="w-3 h-3 rounded-full bg-yellow-400"></div><div class="w-3 h-3 rounded-full bg-green-400"></div></div>
          <div id="demo-url-display" class="flex-1 bg-white border border-border rounded-lg px-3 py-1.5 text-xs text-faint font-mono truncate">hogtown-smoke.pages.dev</div>
        </div>
        <div class="h-[680px] bg-white"><iframe id="demo-frame" src="https://hogtown-smoke.pages.dev" title="Hogtown Smoke demo" loading="lazy" class="w-full h-full border-0"></iframe></div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function() {
      var allowed = [
        'https://hogtown-smoke.pages.dev',
        'https://hogtown-smoke.pages.dev/#menu',
        'https://hogtown-smoke.pages.dev/#about',
        'https://hogtown-smoke.pages.dev/#visit'
      ];
      var tabs = document.querySelectorAll('.demo-tab');
      tabs.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var url = btn.getAttribute('data-url') || '';
          if (allowed.indexOf(url) === -1) return;
          var frame = document.getElementById('demo-frame');
          var display = document.getElementById('demo-url-display');
          if (frame) frame.setAttribute('src', url);
          if (display) display.textContent = url.replace('https://', '');
          tabs.forEach(function(t) {
            t.style.background = 'white';
            t.style.color = '#737373';
            t.style.borderColor = '#E5E5E5';
          });
          btn.style.background = '#FF4500';
          btn.style.color = 'white';
          btn.style.borderColor = '#FF4500';
        });
      });
    })();
  </script>

  <section class="px-6 py-16 bg-accent">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="reveal text-3xl font-extrabold text-white mb-3">Ready to get online?</h2>
      <p class="reveal text-white/80 text-sm mb-8">I'll get back to you within 24 hours.</p>
      <div class="reveal flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/#contact" class="bg-white text-accent px-8 py-4 font-bold text-sm rounded-full hover:bg-off transition-colors">Get a Free Quote →</a>
        <a href="/packages/plus" class="bg-white/20 text-white px-8 py-4 font-bold text-sm rounded-full hover:bg-white/30 transition-colors">Need more? See Plus →</a>
      </div>
    </div>
  </section>

  <footer class="border-t border-border px-6 py-8 bg-white">
    <div class="max-w-6xl mx-auto flex items-center justify-between text-xs text-faint">
      <div class="flex items-center gap-2 font-extrabold text-ink text-sm"><span class="w-2 h-2 rounded-full bg-accent"></span>Lanier Web</div>
      <div>© 2026 Lanier Web · Gainesville, GA</div>
    </div>
  </footer>
</Layout>
