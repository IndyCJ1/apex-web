---
import Layout from "../../layouts/Layout.astro";

const features = [
  {
    title: "5-Page Custom Website",
    description: "Home, About, Services, Contact, plus one page of your choice. Built from scratch around your brand — no templates, no cookie-cutter layouts.",
    icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
  },
  {
    title: "Mobile Responsive Design",
    description: "Your site looks great on every screen — phone, tablet, and desktop. Over 60% of web traffic is mobile. This is non-negotiable.",
    icon: "M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z",
  },
  {
    title: "Contact Form",
    description: "A working contact form that sends submissions directly to your email. Customers reach you, you close the lead.",
    icon: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
  },
  {
    title: "Basic On-Page SEO",
    description: "Title tags, meta descriptions, proper heading structure, image alt text, and sitemap so Google can find and rank your site.",
    icon: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z",
  },
  {
    title: "Hosting & SSL Included",
    description: "Your site is hosted on fast infrastructure with SSL (the padlock in the browser) included in your monthly plan. No extra bills.",
    icon: "M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z",
  },
  {
    title: "1 Hour of Edits Per Month",
    description: "Need to change your hours, update a photo, or fix a typo? Send me a message. Changes are made same day — no ticket system, no waiting.",
    icon: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z",
  },
];
---

<Layout title="Starter Package — Apex Web">
  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-cream border-b border-border">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="text-xl font-semibold tracking-tight" style="font-family: var(--font-display)">Apex Web</a>
      <a href="/#packages" class="flex items-center gap-2 text-sm text-ink-muted hover:text-ink transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        All Packages
      </a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="px-6 pt-40 pb-20 bg-cream">
    <div class="max-w-6xl mx-auto">
      <p class="reveal text-xs font-medium text-ink-muted uppercase tracking-[0.2em] mb-4">Starter Package</p>
      <h1 class="reveal reveal-delay-1 text-5xl md:text-7xl font-semibold leading-none mb-8" style="font-family: var(--font-display)">
        Everything you need<br class="hidden md:block" />
        <em class="text-ink-muted font-normal">to get online.</em>
      </h1>
      <div class="reveal reveal-delay-2 flex items-baseline gap-3 mb-6">
        <span class="text-5xl font-bold text-ink" style="font-family: var(--font-display)">$1,500</span>
        <span class="text-ink-muted">upfront</span>
        <span class="text-ink-faint">+</span>
        <span class="text-2xl font-semibold text-ink" style="font-family: var(--font-display)">$50<span class="text-ink-muted text-base font-normal">/mo</span></span>
      </div>
      <div class="reveal reveal-delay-3 flex gap-4 flex-wrap">
        <a href="/#contact" class="bg-ink text-cream px-8 py-3.5 text-sm font-medium hover:bg-terracotta transition-colors">
          Get Started
        </a>
        <a href="/packages/plus" class="border border-border text-ink-muted px-8 py-3.5 text-sm font-medium hover:border-ink hover:text-ink transition-colors">
          See Plus Package →
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="px-6 py-20 bg-cream-dark">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-12">
        <h2 class="text-3xl font-semibold" style="font-family: var(--font-display)">What's included</h2>
        <p class="text-ink-muted text-sm mt-2">Every feature explained — no fine print, no surprises.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-px bg-border">
        {features.map((f, i) => (
          <div class={`reveal reveal-delay-${i % 3} bg-cream-dark p-8 hover:bg-cream transition-colors`}>
            <div class="w-8 h-8 border border-ink/15 flex items-center justify-center mb-5">
              <svg class="w-4 h-4 text-ink-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={f.icon}/>
              </svg>
            </div>
            <h3 class="font-semibold text-ink mb-2" style="font-family: var(--font-display)">{f.title}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Live Demo -->
  <section class="px-6 py-20 bg-cream">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-8">
        <h2 class="text-3xl font-semibold" style="font-family: var(--font-display)">See it in action</h2>
        <p class="text-ink-muted text-sm mt-2">A real example of a Starter-tier site — click around and explore.</p>
      </div>
      <div class="reveal border border-border shadow-lg overflow-hidden">
        <div class="flex items-center gap-3 px-4 py-3 bg-cream-dark border-b border-border">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-red-400/70"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-400/70"></div>
            <div class="w-3 h-3 rounded-full bg-green-400/70"></div>
          </div>
          <div class="flex-1 bg-white border border-border rounded px-3 py-1.5 text-xs text-ink-muted font-mono truncate">
            hogtown-smoke.pages.dev
          </div>
          <a href="https://hogtown-smoke.pages.dev" target="_blank" rel="noopener"
            class="text-ink-faint hover:text-ink transition-colors flex-shrink-0" title="Open in new tab">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>
        <div class="h-[600px] bg-white">
          <iframe src="https://hogtown-smoke.pages.dev" title="Hogtown Smoke BBQ demo" loading="lazy" class="w-full h-full border-0"></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Who it's for -->
  <section class="px-6 py-20 bg-cream">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-10">
        <h2 class="text-3xl font-semibold" style="font-family: var(--font-display)">Who this is for</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { title: "New businesses", body: "Just getting started and need a clean, credible presence online fast." },
          { title: "Simple services", body: "Plumbers, cleaners, landscapers — businesses with a few core services and a contact number." },
          { title: "Tight budgets", body: "You need a professional site without agency prices. This is it." },
        ].map((item, i) => (
          <div class={`reveal reveal-delay-${i} border border-border p-6`}>
            <h3 class="font-semibold text-ink mb-2" style="font-family: var(--font-display)">{item.title}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-6 py-20 bg-forest">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="reveal text-4xl font-semibold text-cream mb-4" style="font-family: var(--font-display)">Ready to get online?</h2>
      <p class="reveal text-sm mb-8" style="color: rgba(255,255,255,0.55)">Send me a message and I'll get back to you within 24 hours.</p>
      <div class="reveal flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/#contact" class="bg-terracotta text-cream px-8 py-4 text-sm font-medium hover:bg-terracotta-dark transition-colors">
          Get a Free Quote
        </a>
        <a href="/packages/plus" class="border border-white/20 text-cream px-8 py-4 text-sm font-medium hover:bg-white/10 transition-colors">
          Need more? See Plus →
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-white/10 px-6 py-8 bg-ink">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-3 text-xs" style="color: rgba(255,255,255,0.35)">
      <div>© 2026 Apex Web. All rights reserved.</div>
      <div>Built in Gainesville, GA.</div>
    </div>
  </footer>
</Layout>
