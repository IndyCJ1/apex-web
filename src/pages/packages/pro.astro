---
import Layout from "../../layouts/Layout.astro";

const included = [
  "5-page custom website", "Mobile responsive design", "Contact form", "Basic on-page SEO",
  "Hosting & SSL included", "1 hr edits/month", "Up to 10 pages", "Blog or CMS",
  "Google Business setup", "Monthly content updates", "Analytics dashboard",
];

const proFeatures = [
  {
    title: "Online Booking or E-Commerce",
    description: "Let customers book appointments, reserve tables, or buy products directly on your site. Payments, confirmations, and calendar sync all handled.",
    icon: "M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z",
  },
  {
    title: "Custom Integrations",
    description: "Connect your site to tools you already use — CRMs, POS systems, email marketing platforms, scheduling apps. No switching, just connecting.",
    icon: "M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z",
  },
  {
    title: "Priority Support",
    description: "You're at the front of the line. Message me and I respond within 2 hours on business days. Site issue? I'm on it immediately.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
  },
  {
    title: "Monthly Performance Reports",
    description: "Every month: traffic, leads generated, top pages, conversion rates, and what changed. Know exactly what your site is doing for your business.",
    icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
  },
  {
    title: "Quarterly Strategy Calls",
    description: "Every three months: a 30-minute call to review performance, talk through what's working, and plan what to build or change next. Your site evolves with your business.",
    icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
  },
];
---

<Layout title="Pro Package — Apex Web">
  <nav class="fixed top-0 left-0 right-0 z-50 bg-cream border-b border-border">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="text-xl font-semibold tracking-tight" style="font-family: var(--font-display)">Apex Web</a>
      <a href="/#packages" class="flex items-center gap-2 text-sm text-ink-muted hover:text-ink transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        All Packages
      </a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="px-6 pt-40 pb-20 bg-forest border-b-4 border-terracotta">
    <div class="max-w-6xl mx-auto">
      <div class="reveal inline-flex items-center gap-2 border border-white/20 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.15em] mb-6" style="color: rgba(255,255,255,0.6)">
        Full Service
      </div>
      <p class="reveal text-xs font-medium uppercase tracking-[0.2em] mb-4" style="color: rgba(255,255,255,0.45)">Pro Package</p>
      <h1 class="reveal reveal-delay-1 text-5xl md:text-7xl font-semibold leading-none mb-8 text-cream" style="font-family: var(--font-display)">
        Your website as a<br class="hidden md:block" />
        <em class="text-terracotta font-normal">growth engine.</em>
      </h1>
      <div class="reveal reveal-delay-2 flex items-baseline gap-3 mb-6">
        <span class="text-5xl font-bold text-cream" style="font-family: var(--font-display)">$6,000+</span>
        <span style="color: rgba(255,255,255,0.5)">upfront</span>
        <span style="color: rgba(255,255,255,0.3)">+</span>
        <span class="text-2xl font-semibold text-cream" style="font-family: var(--font-display)">$300<span class="text-base font-normal" style="color: rgba(255,255,255,0.5)">/mo</span></span>
      </div>
      <div class="reveal reveal-delay-3 flex gap-4 flex-wrap">
        <a href="/#contact" class="bg-terracotta text-cream px-8 py-3.5 text-sm font-medium hover:bg-terracotta-dark transition-colors">
          Get Started
        </a>
        <a href="/packages/plus" class="border border-white/20 text-cream px-8 py-3.5 text-sm font-medium hover:bg-white/10 transition-colors">
          ← See Plus Package
        </a>
      </div>
    </div>
  </section>

  <!-- Includes -->
  <section class="px-6 py-10 bg-cream-dark border-b border-border">
    <div class="max-w-6xl mx-auto">
      <p class="text-xs font-medium text-ink-muted uppercase tracking-[0.15em] mb-4">Everything in Starter + Plus, plus:</p>
      <div class="flex flex-wrap gap-2">
        {included.map((f) => (
          <div class="flex items-center gap-2 bg-white border border-border px-3 py-1.5 text-xs text-ink">
            <svg class="w-3 h-3 text-ink-muted flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            {f}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pro features -->
  <section class="px-6 py-20 bg-cream-dark">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-12">
        <h2 class="text-3xl font-semibold" style="font-family: var(--font-display)">What makes Pro different</h2>
        <p class="text-ink-muted text-sm mt-2">The capabilities that turn your site into a revenue tool.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-px bg-border">
        {proFeatures.map((f, i) => (
          <div class={`reveal reveal-delay-${i % 3} bg-cream-dark p-8 hover:bg-cream transition-colors`}>
            <div class="w-8 h-8 border border-forest/20 flex items-center justify-center mb-5">
              <svg class="w-4 h-4 text-forest" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={f.icon}/>
              </svg>
            </div>
            <h3 class="font-semibold text-ink mb-2" style="font-family: var(--font-display)">{f.title}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who it's for -->
  <section class="px-6 py-20 bg-cream">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-10">
        <h2 class="text-3xl font-semibold" style="font-family: var(--font-display)">Who this is for</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { title: "High-volume service", body: "Spas, dental offices, gyms — businesses where online booking means more revenue without more admin." },
          { title: "Selling products", body: "You want to sell online. We build a real e-commerce store — payments, inventory, and order management." },
          { title: "Serious about growth", body: "You want data, strategy, and a partner who checks in quarterly — not just a site that sits there." },
        ].map((item, i) => (
          <div class={`reveal reveal-delay-${i} border border-border p-6`}>
            <h3 class="font-semibold text-ink mb-2" style="font-family: var(--font-display)">{item.title}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-6 py-20 bg-ink">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="reveal text-4xl font-semibold text-cream mb-4" style="font-family: var(--font-display)">Ready to scale?</h2>
      <p class="reveal text-sm mb-8" style="color: rgba(255,255,255,0.45)">Tell me about your business. We'll figure out exactly what you need.</p>
      <div class="reveal flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/#contact" class="bg-terracotta text-cream px-8 py-4 text-sm font-medium hover:bg-terracotta-dark transition-colors">
          Get a Free Quote
        </a>
        <a href="/packages/plus" class="border border-white/20 text-cream px-8 py-4 text-sm font-medium hover:bg-white/10 transition-colors">
          ← Not there yet? See Plus
        </a>
      </div>
    </div>
  </section>

  <footer class="border-t border-white/10 px-6 py-8 bg-ink">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-3 text-xs" style="color: rgba(255,255,255,0.35)">
      <div>© 2026 Apex Web. All rights reserved.</div>
      <div>Built in Gainesville, FL.</div>
    </div>
  </footer>
</Layout>
