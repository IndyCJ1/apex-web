---
import Layout from "../../layouts/Layout.astro";
const proFeatures = [
  { title: "Online Booking or E-Commerce", desc: "Let customers book appointments or buy products directly. Payments, confirmations, calendar sync — all handled.", icon: "M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" },
  { title: "Custom Integrations", desc: "Connect CRMs, POS systems, email platforms, scheduling apps. No switching tools — just connecting them.", icon: "M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" },
  { title: "Priority Support", desc: "Front of the queue. Response within 2 hours on business days. Site down? I'm on it immediately.", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { title: "Monthly Performance Reports", desc: "Traffic, leads, top pages, conversion rates — a clear monthly report on what your site is doing for you.", icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" },
  { title: "Quarterly Strategy Calls", desc: "30-minute check-in every quarter. Review performance, plan what to build next. Your site evolves with your business.", icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" },
];
const allIncludes = ["5-page site", "Mobile responsive", "Contact form", "SEO basics", "Hosting & SSL", "1hr edits/mo", "Up to 10 pages", "Blog/CMS", "Google Business", "Content updates", "Analytics"];
---
<Layout title="Pro Package — Apex Web">
  <header class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-border">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-lg font-extrabold text-ink"><span class="w-2.5 h-2.5 rounded-full bg-accent"></span>Apex Web</a>
      <a href="/#packages" class="flex items-center gap-2 text-sm font-medium text-muted hover:text-ink transition-colors"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>All Packages</a>
    </div>
  </header>

  <section class="px-6 pt-40 pb-20 bg-white relative overflow-hidden">
    <div class="absolute right-0 top-1/2 -translate-y-1/2 text-[18rem] font-extrabold select-none pointer-events-none" style="color: #F0F0F0; line-height: 1;">P</div>
    <div class="max-w-6xl mx-auto relative">
      <p class="reveal text-xs font-bold uppercase tracking-[0.2em] text-accent mb-4">Pro Package</p>
      <h1 class="reveal reveal-delay-1 font-extrabold leading-none mb-6" style="font-size: clamp(3rem, 7vw, 6rem)">
        Your website as a<br/><span class="text-accent">growth engine.</span>
      </h1>
      <div class="reveal reveal-delay-2 flex items-baseline gap-3 mb-8">
        <span class="text-5xl font-extrabold text-ink">$6,000+</span><span class="text-muted">upfront</span>
        <span class="text-faint">+</span><span class="text-2xl font-extrabold text-ink">$300<span class="text-muted font-normal text-base">/mo</span></span>
      </div>
      <div class="reveal reveal-delay-3 flex flex-wrap gap-3">
        <a href="/#contact" class="bg-accent text-white px-8 py-3.5 font-bold text-sm rounded-full hover:bg-accent-dark transition-colors">Get Started →</a>
        <a href="/packages/plus" class="bg-off text-ink px-8 py-3.5 font-bold text-sm rounded-full hover:bg-border transition-colors">← See Plus</a>
      </div>
    </div>
  </section>

  <section class="px-6 py-8 bg-off border-b border-border">
    <div class="max-w-6xl mx-auto">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-muted mb-3">Everything in Starter + Plus, plus:</p>
      <div class="flex flex-wrap gap-2">{allIncludes.map((f) => (<div class="flex items-center gap-2 bg-white border border-border rounded-full px-3 py-1.5 text-xs font-medium text-ink"><svg class="w-3 h-3 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>{f}</div>))}</div>
    </div>
  </section>

  <section class="px-6 py-20 bg-off">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-10"><p class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-2">Pro Features</p><h2 class="text-3xl font-extrabold text-ink">Capabilities that drive revenue.</h2></div>
      <div class="grid md:grid-cols-2 gap-4">
        {proFeatures.map((f, i) => (
          <div class={`reveal reveal-delay-${i % 3} bg-white rounded-2xl p-6 border border-border hover:border-accent/30 hover:shadow-md transition-all duration-300`}>
            <div class="w-8 h-8 bg-accent-light rounded-lg flex items-center justify-center mb-4"><svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={f.icon}/></svg></div>
            <h3 class="font-bold text-ink mb-1.5">{f.title}</h3>
            <p class="text-sm text-muted leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="px-6 py-16 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-8"><p class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-2">Live Demo</p><h2 class="text-3xl font-extrabold text-ink">See it in action.</h2><p class="text-muted text-sm mt-2">A real Pro-tier site — click around.</p></div>
      <div class="reveal rounded-2xl overflow-hidden border border-border shadow-lg">
        <div class="flex items-center gap-3 px-4 py-3 bg-off border-b border-border">
          <div class="flex gap-1.5"><div class="w-3 h-3 rounded-full bg-red-400"></div><div class="w-3 h-3 rounded-full bg-yellow-400"></div><div class="w-3 h-3 rounded-full bg-green-400"></div></div>
          <div class="flex-1 bg-white border border-border rounded-lg px-3 py-1.5 text-xs text-faint font-mono truncate">cuesseler-web.pages.dev/demos/pro</div>
          <a href="/demos/pro" target="_blank" rel="noopener" class="text-faint hover:text-ink transition-colors"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg></a>
        </div>
        <div class="h-[600px] bg-white"><iframe src="/demos/pro" title="Solé Wellness demo" loading="lazy" class="w-full h-full border-0"></iframe></div>
      </div>
    </div>
  </section>

  <section class="px-6 py-16 bg-accent">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="reveal text-3xl font-extrabold text-white mb-3">Ready to scale?</h2>
      <p class="reveal text-white/80 text-sm mb-8">Tell me about your business. We'll figure out what you need.</p>
      <div class="reveal flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/#contact" class="bg-white text-accent px-8 py-4 font-bold text-sm rounded-full hover:bg-off transition-colors">Get a Free Quote →</a>
        <a href="/packages/plus" class="bg-white/20 text-white px-8 py-4 font-bold text-sm rounded-full hover:bg-white/30 transition-colors">← Not there yet? See Plus</a>
      </div>
    </div>
  </section>

  <footer class="border-t border-border px-6 py-8 bg-white">
    <div class="max-w-6xl mx-auto flex items-center justify-between text-xs text-faint">
      <div class="flex items-center gap-2 font-extrabold text-ink text-sm"><span class="w-2 h-2 rounded-full bg-accent"></span>Apex Web</div>
      <div>© 2026 Apex Web · Gainesville, GA</div>
    </div>
  </footer>
</Layout>
