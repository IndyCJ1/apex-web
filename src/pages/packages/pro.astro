---
import Layout from "../../layouts/Layout.astro";

const proFeatures = [
  { title: "Online Booking or E-Commerce", desc: "Let customers book appointments or buy products on your site. Payments, confirmations, calendar sync — all handled.", icon: "M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" },
  { title: "Custom Integrations", desc: "Connect your site to CRMs, POS systems, email marketing, scheduling apps. No switching tools — just connecting them.", icon: "M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" },
  { title: "Priority Support", desc: "Front of the line. Response within 2 hours on business days. Site issue? I'm on it immediately.", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { title: "Monthly Performance Reports", desc: "Traffic, leads, top pages, conversion rates — a clear monthly report on what your site is doing for your business.", icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" },
  { title: "Quarterly Strategy Calls", desc: "30-minute check-in every quarter. Review performance, plan what to build next. Your site evolves with your business.", icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" },
];

const allIncludes = ["5-page site", "Mobile responsive", "Contact form", "SEO basics", "Hosting & SSL", "1hr edits/mo", "Up to 10 pages", "Blog/CMS", "Google Business", "Content updates", "Analytics"];
---

<Layout title="Pro Package — Apex Web">
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-edge" style="background: rgba(7,7,15,0.8); backdrop-filter: blur(16px);">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="text-lg font-bold text-text" style="font-family: var(--font-display)">Apex<span class="gradient-text">Web</span></a>
      <a href="/#packages" class="flex items-center gap-2 text-sm text-muted hover:text-text transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        All Packages
      </a>
    </div>
  </nav>

  <section class="px-6 pt-40 pb-20 bg-bg dot-grid relative overflow-hidden">
    <div class="absolute -top-20 right-0 w-[600px] h-[600px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(6,182,212,0.1) 0%, transparent 65%); filter: blur(60px);"></div>
    <div class="absolute top-40 left-0 w-[400px] h-[400px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(124,58,237,0.08) 0%, transparent 65%); filter: blur(50px);"></div>
    <div class="max-w-6xl mx-auto relative">
      <p class="reveal text-xs font-medium uppercase tracking-[0.25em] text-muted mb-3" style="font-family: var(--font-mono)">// pro package</p>
      <h1 class="reveal reveal-delay-1 text-5xl md:text-7xl font-extrabold text-text mb-6 leading-none" style="font-family: var(--font-display)">
        Your website as a<br/><span class="gradient-text">growth engine.</span>
      </h1>
      <div class="reveal reveal-delay-2 flex items-baseline gap-3 mb-6">
        <span class="text-5xl font-extrabold text-text" style="font-family: var(--font-display)">$6,000+</span>
        <span class="text-muted">upfront</span>
        <span class="text-faint">+</span>
        <span class="text-2xl font-bold text-text" style="font-family: var(--font-display)">$300<span class="text-muted text-base font-normal">/mo</span></span>
      </div>
      <div class="reveal reveal-delay-3 flex gap-3 flex-wrap">
        <a href="/#contact" class="gradient-bg text-white px-8 py-3.5 text-sm font-semibold rounded-lg hover:opacity-90 transition-opacity">Get Started</a>
        <a href="/packages/plus" class="glass text-text px-8 py-3.5 text-sm font-semibold rounded-lg hover:border-edge-2 transition-colors">← See Plus</a>
      </div>
    </div>
  </section>

  <section class="px-6 py-10 bg-surface border-b border-edge">
    <div class="max-w-6xl mx-auto">
      <p class="text-xs text-muted uppercase tracking-[0.2em] mb-3" style="font-family: var(--font-mono)">Everything in Starter + Plus, plus:</p>
      <div class="flex flex-wrap gap-2">
        {allIncludes.map((f) => (
          <div class="glass rounded-full px-3 py-1.5 text-xs text-muted flex items-center gap-2">
            <svg class="w-3 h-3 text-violet" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            {f}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="px-6 py-20 bg-surface">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-10">
        <p class="text-xs font-medium uppercase tracking-[0.25em] text-muted mb-2" style="font-family: var(--font-mono)">// what makes pro different</p>
        <h2 class="text-3xl font-bold text-text" style="font-family: var(--font-display)">Capabilities that drive revenue.</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-4">
        {proFeatures.map((f, i) => (
          <div class={`reveal reveal-delay-${i % 3} glass rounded-xl p-6 hover:border-cyan/20 transition-all duration-300`}>
            <div class="w-8 h-8 gradient-bg rounded-lg flex items-center justify-center mb-4">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={f.icon}/></svg>
            </div>
            <h3 class="font-semibold text-text mb-1.5" style="font-family: var(--font-display)">{f.title}</h3>
            <p class="text-sm text-muted leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="px-6 py-16 bg-bg">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-8">
        <p class="text-xs font-medium uppercase tracking-[0.25em] text-muted mb-2" style="font-family: var(--font-mono)">// demo site</p>
        <h2 class="text-3xl font-bold text-text" style="font-family: var(--font-display)">See it in action.</h2>
        <p class="text-muted text-sm mt-2">A real Pro-tier site — click around and explore.</p>
      </div>
      <div class="reveal glass rounded-xl overflow-hidden">
        <div class="flex items-center gap-3 px-4 py-3 border-b border-edge" style="background: rgba(255,255,255,0.02)">
          <div class="flex gap-1.5"><div class="w-3 h-3 rounded-full bg-red-500/60"></div><div class="w-3 h-3 rounded-full bg-yellow-500/60"></div><div class="w-3 h-3 rounded-full bg-green-500/60"></div></div>
          <div class="flex-1 glass rounded px-3 py-1.5 text-xs text-faint font-mono truncate">cuesseler-web.pages.dev/demos/pro</div>
          <a href="/demos/pro" target="_blank" rel="noopener" class="text-faint hover:text-text transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>
        <div class="h-[600px] bg-white"><iframe src="/demos/pro" title="Solé Wellness demo" loading="lazy" class="w-full h-full border-0"></iframe></div>
      </div>
    </div>
  </section>

  <section class="px-6 py-16 bg-surface">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="reveal text-3xl font-bold text-text mb-3" style="font-family: var(--font-display)">Ready to scale?</h2>
      <p class="reveal text-muted text-sm mb-8">Tell me about your business. We'll figure out exactly what you need.</p>
      <div class="reveal flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/#contact" class="gradient-bg text-white px-8 py-4 text-sm font-semibold rounded-lg hover:opacity-90 transition-opacity">Get a Free Quote</a>
        <a href="/packages/plus" class="glass text-text px-8 py-4 text-sm font-semibold rounded-lg hover:border-edge-2 transition-colors">← Not there yet? See Plus</a>
      </div>
    </div>
  </section>

  <footer class="border-t border-edge px-6 py-8 bg-bg">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-faint">
      <div class="font-semibold text-muted" style="font-family: var(--font-display)">Apex<span class="gradient-text">Web</span></div>
      <div>© 2026 Apex Web · Gainesville, GA</div>
    </div>
  </footer>
</Layout>
