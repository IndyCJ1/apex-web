---
import Layout from "../../layouts/Layout.astro";

const starterFeatures = [
  "5-page custom website", "Mobile responsive design", "Contact form",
  "Basic on-page SEO", "Hosting & SSL included", "1 hr edits/month",
];

const plusFeatures = [
  {
    title: "Up to 10 Pages",
    description: "Room to grow. Add team bios, service detail pages, a gallery, testimonials. More pages means more ways for customers to find you on Google.",
    icon: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10",
  },
  {
    title: "Blog or CMS",
    description: "Update your own content without touching code. Write posts, add announcements, update menus — all from a simple dashboard. No developer needed.",
    icon: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z",
  },
  {
    title: "Google Business Setup",
    description: "Get listed on Google Maps and local search results. Critical for local businesses — customers searching nearby will find you.",
    icon: "M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z",
  },
  {
    title: "Monthly Content Updates",
    description: "Send me new photos, announcements, or seasonal specials. I'll update the site each month so your content stays fresh.",
    icon: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15",
  },
  {
    title: "Analytics Dashboard",
    description: "See who's visiting your site, where they're coming from, and what they click. Know what's working so you can make smarter decisions.",
    icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
  },
];
---

<Layout title="Plus Package — Apex Web">
  <nav class="fixed top-0 left-0 right-0 z-50 bg-cream border-b border-border">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="text-xl font-semibold tracking-tight" style="font-family: var(--font-display)">Apex Web</a>
      <a href="/#packages" class="flex items-center gap-2 text-sm text-ink-muted hover:text-ink transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        All Packages
      </a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="px-6 pt-40 pb-20 bg-cream border-b-4 border-terracotta">
    <div class="max-w-6xl mx-auto">
      <div class="reveal inline-flex items-center gap-2 border border-terracotta/30 bg-terracotta/5 px-3 py-1.5 text-xs font-semibold text-terracotta uppercase tracking-[0.15em] mb-6">
        Most Popular
      </div>
      <p class="reveal text-xs font-medium text-ink-muted uppercase tracking-[0.2em] mb-4">Plus Package</p>
      <h1 class="reveal reveal-delay-1 text-5xl md:text-7xl font-semibold leading-none mb-8" style="font-family: var(--font-display)">
        For businesses that<br class="hidden md:block" />
        <em class="text-terracotta font-normal">need to stay current.</em>
      </h1>
      <div class="reveal reveal-delay-2 flex items-baseline gap-3 mb-6">
        <span class="text-5xl font-bold text-ink" style="font-family: var(--font-display)">$3,500</span>
        <span class="text-ink-muted">upfront</span>
        <span class="text-ink-faint">+</span>
        <span class="text-2xl font-semibold text-ink" style="font-family: var(--font-display)">$125<span class="text-ink-muted text-base font-normal">/mo</span></span>
      </div>
      <div class="reveal reveal-delay-3 flex gap-4 flex-wrap">
        <a href="/#contact" class="bg-terracotta text-cream px-8 py-3.5 text-sm font-medium hover:bg-terracotta-dark transition-colors">
          Get Started
        </a>
        <a href="/packages/pro" class="border border-border text-ink-muted px-8 py-3.5 text-sm font-medium hover:border-ink hover:text-ink transition-colors">
          See Pro Package →
        </a>
      </div>
    </div>
  </section>

  <!-- Includes from Starter -->
  <section class="px-6 py-10 bg-cream-dark border-b border-border">
    <div class="max-w-6xl mx-auto">
      <p class="text-xs font-medium text-ink-muted uppercase tracking-[0.15em] mb-4">Everything in Starter, plus:</p>
      <div class="flex flex-wrap gap-2">
        {starterFeatures.map((f) => (
          <div class="flex items-center gap-2 bg-white border border-border px-3 py-1.5 text-xs text-ink">
            <svg class="w-3 h-3 text-ink-muted flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            {f}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Plus features -->
  <section class="px-6 py-20 bg-cream-dark">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-12">
        <h2 class="text-3xl font-semibold" style="font-family: var(--font-display)">What you get on top</h2>
        <p class="text-ink-muted text-sm mt-2">The features that make Plus worth upgrading to.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-px bg-border">
        {plusFeatures.map((f, i) => (
          <div class={`reveal reveal-delay-${i % 3} bg-cream-dark p-8 hover:bg-cream transition-colors`}>
            <div class="w-8 h-8 border border-terracotta/20 flex items-center justify-center mb-5">
              <svg class="w-4 h-4 text-terracotta" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={f.icon}/>
              </svg>
            </div>
            <h3 class="font-semibold text-ink mb-2" style="font-family: var(--font-display)">{f.title}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Live Demo -->
  <section class="px-6 py-20 bg-cream">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-8">
        <h2 class="text-3xl font-semibold" style="font-family: var(--font-display)">See it in action</h2>
        <p class="text-ink-muted text-sm mt-2">A real example of a Plus-tier site — click around and explore.</p>
      </div>
      <div class="reveal border border-border shadow-lg overflow-hidden">
        <div class="flex items-center gap-3 px-4 py-3 bg-cream-dark border-b border-border">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-red-400/70"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-400/70"></div>
            <div class="w-3 h-3 rounded-full bg-green-400/70"></div>
          </div>
          <div class="flex-1 bg-white border border-border rounded px-3 py-1.5 text-xs text-ink-muted font-mono truncate">
            cuesseler-web.pages.dev/demos/plus
          </div>
          <a href="/demos/plus" target="_blank" rel="noopener"
            class="text-ink-faint hover:text-ink transition-colors flex-shrink-0" title="Open in new tab">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>
        <div class="h-[600px] bg-white">
          <iframe src="/demos/plus" title="The Perch Coffee Co. demo" loading="lazy" class="w-full h-full border-0"></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Who it's for -->
  <section class="px-6 py-20 bg-cream">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-10">
        <h2 class="text-3xl font-semibold" style="font-family: var(--font-display)">Who this is for</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { title: "Growing businesses", body: "You've got traction and need a site that can grow with you — more pages, more content." },
          { title: "Content-driven", body: "Restaurants, salons, gyms — businesses that update menus, hours, or promos regularly." },
          { title: "Local search focus", body: "You want to rank on Google Maps and show up when someone nearby searches for what you do." },
        ].map((item, i) => (
          <div class={`reveal reveal-delay-${i} border border-border p-6`}>
            <h3 class="font-semibold text-ink mb-2" style="font-family: var(--font-display)">{item.title}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-6 py-20 bg-forest">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="reveal text-4xl font-semibold text-cream mb-4" style="font-family: var(--font-display)">Let's build it.</h2>
      <p class="reveal text-sm mb-8" style="color: rgba(255,255,255,0.55)">Most popular for a reason. Get in touch and we'll talk through what you need.</p>
      <div class="reveal flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/#contact" class="bg-terracotta text-cream px-8 py-4 text-sm font-medium hover:bg-terracotta-dark transition-colors">
          Get a Free Quote
        </a>
        <div class="flex gap-3 justify-center">
          <a href="/packages/starter" class="border border-white/20 text-cream px-6 py-4 text-sm font-medium hover:bg-white/10 transition-colors">← Starter</a>
          <a href="/packages/pro" class="border border-white/20 text-cream px-6 py-4 text-sm font-medium hover:bg-white/10 transition-colors">Pro →</a>
        </div>
      </div>
    </div>
  </section>

  <footer class="border-t border-white/10 px-6 py-8 bg-ink">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-3 text-xs" style="color: rgba(255,255,255,0.35)">
      <div>© 2026 Apex Web. All rights reserved.</div>
      <div>Built in Gainesville, GA.</div>
    </div>
  </footer>
</Layout>
